---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import { Picture } from "astro:assets";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the entry directly from the prop on render
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <!-- Reading progress bar -->
  <div
    id="progress-bar"
    class="fixed top-0 left-0 h-[3px] z-50 bg-gradient-to-r from-primary to-primary-strong"
    style="width: 0%;">
  </div>

  <Container>
    <div class="mx-auto max-w-3xl mt-14 text-center">
      <span class="text-primary uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div
        class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap justify-between border-t border-primary-soft pt-6">
        <div class="flex gap-2 items-center">
          <span class="text-default text-lg font-medium">
            {entry.data.author}
          </span>
          <span class="text-default-soft">•</span>
          <time
            class="text-default-soft"
            datetime={entry.data.publishDate.toISOString()}>
            {entry.data.publishDate.toDateString()}
          </time>
        </div>
        <div class="flex flex-wrap gap-3 items-center">
          <span>Share</span>
          <button
            class="w-7 h-7 bg-primary-soft rounded-full flex justify-center items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              version="1.1"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="10"
              height="10"
              x="0"
              y="0"
              viewBox="0 0 155.139 155.139"
              style="enable-background:new 0 0 512 512"
              xml:space="preserve"
              class="">
              <g>
                <path
                  d="M89.584 155.139V84.378h23.742l3.562-27.585H89.584V39.184c0-7.984 2.208-13.425 13.67-13.425l14.595-.006V1.08C115.325.752 106.661 0 96.577 0 75.52 0 61.104 12.853 61.104 36.452v20.341H37.29v27.585h23.814v70.761h28.48z"
                  style=""
                  fill="#00ac8a"
                  data-original="#010002"
                  opacity="1"
                  class="">
                </path>
              </g>
            </svg>
          </button>
          <button
            class="w-7 h-7 bg-primary-soft rounded-full flex justify-center items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              version="1.1"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="10"
              height="10"
              x="0"
              y="0"
              viewBox="0 0 512 512"
              style="enable-background:new 0 0 512 512"
              xml:space="preserve"
              class="">
              <g>
                <path
                  d="M512 97.248c-19.04 8.352-39.328 13.888-60.48 16.576 21.76-12.992 38.368-33.408 46.176-58.016-20.288 12.096-42.688 20.64-66.56 25.408C411.872 60.704 384.416 48 354.464 48c-58.112 0-104.896 47.168-104.896 104.992 0 8.32.704 16.32 2.432 23.936-87.264-4.256-164.48-46.08-216.352-109.792-9.056 15.712-14.368 33.696-14.368 53.056 0 36.352 18.72 68.576 46.624 87.232-16.864-.32-33.408-5.216-47.424-12.928v1.152c0 51.008 36.384 93.376 84.096 103.136-8.544 2.336-17.856 3.456-27.52 3.456-6.72 0-13.504-.384-19.872-1.792 13.6 41.568 52.192 72.128 98.08 73.12-35.712 27.936-81.056 44.768-130.144 44.768-8.608 0-16.864-.384-25.12-1.44C46.496 446.88 101.6 464 161.024 464c193.152 0 298.752-160 298.752-298.688 0-4.64-.16-9.12-.384-13.568 20.832-14.784 38.336-33.248 52.608-54.496z"
                  style=""
                  fill="#00ac8a"
                  data-original="#03a9f4"
                  opacity="1"
                  class="">
                </path>
              </g>
            </svg>
          </button>
          <button
            class="w-7 h-7 bg-primary-soft rounded-full flex justify-center items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              version="1.1"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="10"
              height="10"
              x="0"
              y="0"
              viewBox="0 0 100 100"
              style="enable-background:new 0 0 512 512"
              xml:space="preserve"
              class="">
              <g>
                <path
                  d="M90 90V60.7c0-14.4-3.1-25.4-19.9-25.4-8.1 0-13.5 4.4-15.7 8.6h-.2v-7.3H38.3V90h16.6V63.5c0-7 1.3-13.7 9.9-13.7 8.5 0 8.6 7.9 8.6 14.1v26H90zM11.3 36.6h16.6V90H11.3zM19.6 10c-5.3 0-9.6 4.3-9.6 9.6s4.3 9.7 9.6 9.7 9.6-4.4 9.6-9.7-4.3-9.6-9.6-9.6z"
                  fill="#00ac8a"
                  opacity="1"
                  data-original="#000000"
                  class="">
                </path>
              </g>
            </svg>
          </button>
        </div>
      </div>
      <div class="mt-6">
        <Picture
          src={entry.data.image}
          alt="Blog Main Image"
          class="w-full rounded-lg aspect-video object-cover object-center bg-primary-soft/50"
        />
      </div>
    </div>

    <div class="max-w-6xl mx-auto mt-12 lg:flex lg:gap-10">
      <!-- Main content column -->
      <div class="max-w-3xl mx-auto lg:mx-0 flex-1 min-w-0">
        <div
          id="article-content"
          class="prose prose-lg prose-blockquote:bg-primary-soft prose-blockquote:px-10 prose-blockquote:py-6 prose-blockquote:text-2xl prose-blockquote:not-italic prose-blockquote:border prose-blockquote:border-primary-accent prose-blockquote:rounded-md">
          <Content />
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          {
            entry.data.tags.map((tag) => (
              <span class="text-sm text-gray-500">#{tag}</span>
            ))
          }
        </div>
        <div class="text-center mt-8 mb-16">
          <a
            href="/blog"
            class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition">
            ← Back to Blog
          </a>
        </div>
      </div>

      <!-- Desktop TOC sidebar -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div
          id="toc-sidebar"
          class="sticky top-24 opacity-0 transition-opacity duration-300">
          <div
            class="bg-white border border-muted-strong rounded-2xl p-5 shadow-sm">
            <button
              id="toc-toggle"
              class="flex items-center justify-between w-full text-left mb-3"
              aria-expanded="true">
              <span class="text-sm font-semibold text-default">
                En este artículo
              </span>
              <svg
                id="toc-toggle-icon"
                class="w-4 h-4 text-default-soft transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m19.5 8.25-7.5 7.5-7.5-7.5"
                />
              </svg>
            </button>
            <div class="mb-4 pb-3 border-b border-muted-strong">
              <div class="flex items-center justify-between">
                <span class="text-default-soft text-xs">Progreso</span>
                <span
                  id="toc-progress-text"
                  class="text-primary text-xs font-medium">0%</span>
              </div>
              <div class="mt-2 h-1 bg-muted rounded-full overflow-hidden">
                <div
                  id="toc-progress-bar"
                  class="h-full bg-gradient-to-r from-primary to-primary-strong rounded-full transition-all duration-150"
                  style="width: 0%;">
                </div>
              </div>
            </div>
            <nav
              id="toc-list"
              class="space-y-1"
              aria-label="Tabla de contenidos">
            </nav>
          </div>
        </div>
      </aside>
    </div>
  </Container>

  <!-- Mobile TOC button -->
  <button
    id="mobile-toc-btn"
    class="lg:hidden fixed bottom-6 right-6 z-40 bg-white border border-muted-strong text-default px-4 py-2.5 rounded-full shadow-lg flex items-center gap-2 transition-all duration-300 hover:border-primary"
    aria-label="Abrir tabla de contenidos">
    <svg
      class="w-4 h-4 text-primary"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
      />
    </svg>
    <span class="text-xs font-medium">Contenido</span>
  </button>

  <!-- Mobile TOC drawer -->
  <div
    id="mobile-toc-overlay"
    class="lg:hidden fixed inset-0 z-50 pointer-events-none opacity-0 transition-opacity duration-300">
    <div
      class="absolute inset-0 bg-default/60 backdrop-blur-sm"
      id="mobile-toc-backdrop">
    </div>
    <div
      id="mobile-toc-drawer"
      class="absolute bottom-0 left-0 right-0 bg-white border-t border-muted-strong rounded-t-2xl transform translate-y-full transition-transform duration-300 max-h-[70vh] flex flex-col shadow-2xl">
      <div class="flex items-center justify-between p-5 border-b border-muted-strong">
        <span class="text-sm font-semibold text-default">En este artículo</span>
        <button
          id="mobile-toc-close"
          class="text-default-soft hover:text-default transition-colors p-1"
          aria-label="Cerrar tabla de contenidos">
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18 18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>
      <div class="px-5 pt-4 pb-2">
        <div class="flex items-center justify-between">
          <span class="text-default-soft text-xs">Progreso</span>
          <span
            id="mobile-toc-progress-text"
            class="text-primary text-xs font-medium">0%</span>
        </div>
        <div class="mt-2 h-1 bg-muted rounded-full overflow-hidden">
          <div
            id="mobile-toc-progress-bar"
            class="h-full bg-gradient-to-r from-primary to-primary-strong rounded-full transition-all duration-150"
            style="width: 0%;">
          </div>
        </div>
      </div>
      <nav
        id="mobile-toc-list"
        class="p-5 pt-3 overflow-y-auto space-y-1"
        aria-label="Tabla de contenidos móvil">
      </nav>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const articleContent = document.getElementById("article-content");
      const progressBar = document.getElementById("progress-bar");
      const tocSidebar = document.getElementById("toc-sidebar");
      const tocList = document.getElementById("toc-list");
      const mobileTocList = document.getElementById("mobile-toc-list");
      const tocToggle = document.getElementById("toc-toggle");
      const tocToggleIcon = document.getElementById("toc-toggle-icon");
      const tocProgressBar = document.getElementById("toc-progress-bar");
      const tocProgressText = document.getElementById("toc-progress-text");
      const mobileTocProgressBar = document.getElementById(
        "mobile-toc-progress-bar",
      );
      const mobileTocProgressText = document.getElementById(
        "mobile-toc-progress-text",
      );
      const mobileTocBtn = document.getElementById("mobile-toc-btn");
      const mobileTocOverlay = document.getElementById("mobile-toc-overlay");
      const mobileTocDrawer = document.getElementById("mobile-toc-drawer");
      const mobileTocClose = document.getElementById("mobile-toc-close");
      const mobileTocBackdrop = document.getElementById("mobile-toc-backdrop");

      if (!articleContent) return;

      const headings = Array.from(
        articleContent.querySelectorAll("h2, h3"),
      ) as HTMLElement[];
      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = "heading-" + index;
        }
      });

      function itemClasses(
        isH3: boolean,
        state: "idle" | "hover-mobile" | "active-desktop" | "active-mobile",
      ): string {
        const indent = isH3 ? "pl-6" : "pl-3";
        const base =
          "block text-sm py-1.5 pr-3 transition-all duration-200 rounded-md " +
          indent;
        if (state === "active-desktop") {
          return (
            base +
            " text-primary font-medium border-l-2 border-primary bg-primary-soft"
          );
        }
        if (state === "active-mobile") {
          return base + " text-primary font-medium bg-primary-soft";
        }
        if (state === "hover-mobile") {
          return (
            base + " text-default-soft hover:text-default hover:bg-muted"
          );
        }
        return (
          base +
          " text-default-soft hover:text-default border-l-2 border-transparent"
        );
      }

      function createTocItem(
        heading: HTMLElement,
        index: number,
        isMobile: boolean,
      ): HTMLAnchorElement {
        const link = document.createElement("a");
        link.href = "#" + heading.id;
        link.textContent = heading.textContent || "";
        link.dataset.index = String(index);
        const isH3 = heading.tagName === "H3";
        link.className = itemClasses(
          isH3,
          isMobile ? "hover-mobile" : "idle",
        );
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const target = document.getElementById(heading.id);
          if (target) {
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            if (isMobile) closeMobileDrawer();
          }
        });
        return link;
      }

      if (headings.length > 0) {
        headings.forEach((heading, index) => {
          if (tocList) tocList.appendChild(createTocItem(heading, index, false));
          if (mobileTocList)
            mobileTocList.appendChild(createTocItem(heading, index, true));
        });
      } else {
        if (tocSidebar) tocSidebar.style.display = "none";
        if (mobileTocBtn) mobileTocBtn.style.display = "none";
      }

      // TOC toggle (collapse/expand)
      let tocExpanded = true;
      if (tocToggle && tocList) {
        tocToggle.addEventListener("click", () => {
          tocExpanded = !tocExpanded;
          tocList.style.display = tocExpanded ? "block" : "none";
          if (tocToggleIcon) {
            tocToggleIcon.style.transform = tocExpanded
              ? ""
              : "rotate(-90deg)";
          }
          tocToggle.setAttribute("aria-expanded", String(tocExpanded));
        });
      }

      // IntersectionObserver for active heading
      let activeIndex = -1;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const idx = headings.indexOf(entry.target as HTMLElement);
              if (idx !== -1) activeIndex = idx;
            }
          });
          updateActiveItem();
        },
        { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
      );

      headings.forEach((h) => observer.observe(h));

      function updateActiveItem() {
        if (tocList) {
          const items = tocList.querySelectorAll("a");
          items.forEach((item, i) => {
            const heading = headings[i];
            const isH3 = !!heading && heading.tagName === "H3";
            item.className = itemClasses(
              isH3,
              i === activeIndex ? "active-desktop" : "idle",
            );
          });
        }
        if (mobileTocList) {
          const items = mobileTocList.querySelectorAll("a");
          items.forEach((item, i) => {
            const heading = headings[i];
            const isH3 = !!heading && heading.tagName === "H3";
            item.className = itemClasses(
              isH3,
              i === activeIndex ? "active-mobile" : "hover-mobile",
            );
          });
        }
      }

      function onScroll() {
        const article = articleContent!;
        const articleTop = article.offsetTop;
        const articleHeight = article.offsetHeight;
        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;

        const progress = Math.min(
          Math.max(
            (scrollY - articleTop + windowHeight * 0.3) / articleHeight,
            0,
          ),
          1,
        );
        const pct = Math.round(progress * 100);

        if (progressBar) progressBar.style.width = pct + "%";
        if (tocProgressBar) tocProgressBar.style.width = pct + "%";
        if (tocProgressText) tocProgressText.textContent = pct + "%";
        if (mobileTocProgressBar)
          mobileTocProgressBar.style.width = pct + "%";
        if (mobileTocProgressText)
          mobileTocProgressText.textContent = pct + "%";

        if (tocSidebar) {
          tocSidebar.style.opacity = scrollY > 300 ? "1" : "0";
        }
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      function openMobileDrawer() {
        if (!mobileTocOverlay || !mobileTocDrawer) return;
        mobileTocOverlay.style.pointerEvents = "auto";
        mobileTocOverlay.style.opacity = "1";
        mobileTocDrawer.style.transform = "translateY(0)";
        document.body.style.overflow = "hidden";
      }

      function closeMobileDrawer() {
        if (!mobileTocOverlay || !mobileTocDrawer) return;
        mobileTocOverlay.style.opacity = "0";
        mobileTocDrawer.style.transform = "translateY(100%)";
        mobileTocOverlay.style.pointerEvents = "none";
        document.body.style.overflow = "";
      }

      if (mobileTocBtn) mobileTocBtn.addEventListener("click", openMobileDrawer);
      if (mobileTocClose)
        mobileTocClose.addEventListener("click", closeMobileDrawer);
      if (mobileTocBackdrop)
        mobileTocBackdrop.addEventListener("click", closeMobileDrawer);
    });
  </script>
</Layout>
