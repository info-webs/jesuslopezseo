---
import Navbar from "@components/navbar/navbar.astro";
import Footer from "@components/footer.astro";
import Container from "@components/container.astro";
import "@fontsource-variable/rethink-sans";

const siteUrl = "https://jesuslopezseo.com";
const pageUrl = `${siteUrl}/hermes`;
const ogImage = `${siteUrl}/opengraph.jpg`;

const pageTitle =
  "Hermes Pro Setup — Tu agente IA personal instalado en 48h | Jesús López";
const pageDescription =
  "Instalación gestionada del agente IA Hermes en tu propio servidor. Conectado a Slack o Telegram, con tus herramientas (Notion, Gmail, Calendar...). 599€ + 59€/mes. Sin código, sin servidores que mantener.";

const faqs = [
  {
    q: "¿Qué es Hermes exactamente?",
    a: "Hermes es un agente IA open source desarrollado por Nous Research. Convierte modelos de lenguaje (Claude, GPT, Llama, etc.) en un asistente que ejecuta tareas reales: leer emails, buscar archivos, programar eventos, redactar respuestas. Lo controlas en lenguaje natural desde Slack o Telegram.",
  },
  {
    q: "¿Cuánto cuesta el LLM aparte?",
    a: "Tú pones tu API key de OpenRouter o Anthropic. Para uso normal (50-100 mensajes/día) suele costar entre 10-30€/mes en tokens. Si lo usas masivamente, puede subir. Te asesoro en el onboarding.",
  },
  {
    q: "¿De quién es el VPS?",
    a: "Tuyo. Lo contratas tú a tu nombre (te paso instrucciones), yo lo configuro con permisos delegados. Si dejas de trabajar conmigo, mantienes acceso completo.",
  },
  {
    q: "¿Qué pasa si Hermes se rompe o sale una versión nueva?",
    a: "Para eso está el mantenimiento mensual. Yo me ocupo de actualizaciones, parches de seguridad y arreglos. Si cancelas el mantenimiento, sigue funcionando pero tú decides cuándo actualizar.",
  },
  {
    q: "¿Puedo añadir MCPs después de la instalación?",
    a: "Sí, 49€ por MCP nuevo. Si están en mi catálogo es plug-and-play. Si es uno custom, te hago presupuesto.",
  },
  {
    q: "¿Es legal/ético usar Hermes comercialmente?",
    a: "Sí, su licencia Apache 2.0 lo permite explícitamente. Tu instalación es privada, solo para ti o tu equipo.",
  },
  {
    q: "¿Funciona en español?",
    a: "Perfectamente. El idioma del agente depende del modelo LLM que uses (Claude, GPT-4, etc.). Todos manejan español nativo.",
  },
  {
    q: "¿Qué pasa si quiero cancelar?",
    a: "Cancelas el mantenimiento cuando quieras desde el formulario o por email, sin permanencia. Tu Hermes sigue funcionando en tu VPS. Si quieres además darlo de baja del VPS, te ayudo con la migración o el apagado limpio.",
  },
];

const mcps = [
  { name: "Slack", cls: "bg-purple-50 text-purple-700 border-purple-200" },
  { name: "Telegram", cls: "bg-blue-50 text-blue-700 border-blue-200" },
  { name: "Notion", cls: "bg-gray-50 text-gray-700 border-gray-300" },
  { name: "Gmail", cls: "bg-red-50 text-red-700 border-red-200" },
  {
    name: "Google Calendar",
    cls: "bg-blue-50 text-blue-800 border-blue-200",
  },
  {
    name: "Google Drive",
    cls: "bg-yellow-50 text-yellow-700 border-yellow-200",
  },
  { name: "GitHub", cls: "bg-gray-50 text-gray-800 border-gray-300" },
  { name: "Linear", cls: "bg-violet-50 text-violet-700 border-violet-200" },
  { name: "Stripe", cls: "bg-indigo-50 text-indigo-700 border-indigo-200" },
  {
    name: "Supabase",
    cls: "bg-emerald-50 text-emerald-700 border-emerald-200",
  },
  { name: "Make", cls: "bg-orange-50 text-orange-700 border-orange-200" },
  { name: "Semrush", cls: "bg-orange-50 text-orange-800 border-orange-300" },
];

const setupItems = [
  "VPS provisionado a tu nombre (Hetzner o Contabo — 5-8€/mes que pagas tú directo al proveedor)",
  "Hermes Agent instalado, securizado y con backups automáticos",
  "Conexión a Slack o Telegram (a elegir)",
  "Hasta 5 MCPs preconfigurados del catálogo",
  "API key del LLM (OpenRouter o Anthropic) configurada con tu cuenta",
  "Onboarding 1h en videollamada",
  "Documentación PDF personalizada",
];

const maintItems = [
  "Actualizaciones de Hermes cuando hay versión nueva",
  "Monitorización 24/7 del VPS con alertas",
  "1 cambio de configuración al mes (añadir MCP, cambiar modelo, etc.)",
  "Soporte por email con respuesta en 48h",
  "Backup semanal automático con retención de 30 días",
];

const diffPoints = [
  {
    title: "Tu agente, tu servidor, tus datos",
    desc: "No son nuestros. Tu instalación es privada, en hardware que controlas tú directamente.",
  },
  {
    title: "Pago único + mantenimiento opcional",
    desc: "No SaaS con cuota por usuario. Pagas el setup y decides si quieres mantenimiento mensual.",
  },
  {
    title: "Open source (Apache 2.0)",
    desc: "Hermes es libre. Si dejas de pagarme, sigue tuyo y funcionando. Para siempre.",
  },
  {
    title: "18+ años en infraestructura web",
    desc: "No es mi primer rodeo. He montado servidores para sitios con millones de visitas.",
  },
];

const schemaService = {
  "@type": "Service",
  name: "Hermes Pro Setup",
  description: pageDescription,
  provider: {
    "@type": "Organization",
    name: "Posicionamiento Web Systems SL",
    url: siteUrl,
  },
  areaServed: ["España", "Europa"],
  serviceType: "AI Agent Installation",
  offers: [
    {
      "@type": "Offer",
      name: "Setup inicial",
      price: "599",
      priceCurrency: "EUR",
      description: "Instalación completa de Hermes Agent en tu VPS",
    },
    {
      "@type": "Offer",
      name: "Mantenimiento mensual",
      price: "59",
      priceCurrency: "EUR",
      description: "Actualizaciones, monitorización y soporte mensual",
    },
  ],
};

const schemaFaq = {
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const schemaBreadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: siteUrl },
    {
      "@type": "ListItem",
      position: 2,
      name: "Servicios",
      item: `${siteUrl}/servicios`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Hermes Pro Setup",
      item: pageUrl,
    },
  ],
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [schemaService, schemaFaq, schemaBreadcrumb],
});
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta
      property="og:title"
      content="Hermes Pro Setup — Tu agente IA personal instalado en 48h"
    />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@jesuslopezseo" />
    <meta
      name="twitter:title"
      content="Hermes Pro Setup — Tu agente IA personal instalado en 48h"
    />
    <meta name="twitter:description" content={pageDescription} />
    <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />
  </head>
  <body class="font-sans antialiased min-h-full flex flex-col">
    <Navbar />

    <main class="flex-1">

      <!-- ===== 1. HERO ===== -->
      <section class="bg-primary-soft pt-16 pb-12 md:pt-24 md:pb-0 overflow-hidden">
        <Container>
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <!-- Copy -->
            <div class="py-4 md:py-12">
              <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-4">
                Hermes Pro Setup
              </p>
              <h1
                class="text-4xl md:text-5xl font-bold text-primary-strong leading-tight">
                Tu agente IA personal en Slack o Telegram.
                <span class="text-primary block mt-2"
                  >Instalado, listo y funcionando en 48 horas.</span
                >
              </h1>
              <p class="mt-6 text-lg text-default leading-relaxed max-w-lg">
                Te montamos Hermes (Nous Research) en tu propio servidor,
                conectado a tus herramientas. Tú hablas con él como con un
                asistente humano. Sin código, sin servidores que mantener, sin
                curva de aprendizaje.
              </p>
              <div class="mt-8 flex flex-col sm:flex-row gap-4">
                <a
                  href="#contacto"
                  class="bg-primary text-white text-lg font-medium rounded-xl py-4 px-8 text-center transition hover:bg-primary-strong focus:ring-2 focus:ring-primary focus:ring-offset-2">
                  Reservar mi instalación
                </a>
                <a
                  href="#incluye"
                  class="bg-white text-primary-strong border-2 border-primary text-lg font-medium rounded-xl py-4 px-8 text-center transition hover:bg-primary-soft focus:ring-2 focus:ring-primary focus:ring-offset-2">
                  Ver qué incluye
                </a>
              </div>
            </div>

            <!-- Slack mockup -->
            <div class="flex justify-center md:justify-end">
              <div
                class="bg-white rounded-2xl shadow-2xl p-5 w-full max-w-sm border border-gray-100"
                aria-hidden="true">
                <!-- Header -->
                <div
                  class="flex items-center gap-2 pb-3 border-b border-gray-100">
                  <div
                    class="w-5 h-5 rounded flex items-center justify-center text-white text-[9px] font-bold"
                    style="background:#4A154B">
                    #
                  </div>
                  <span class="font-semibold text-sm text-gray-700"
                    >general</span
                  >
                </div>
                <!-- Messages -->
                <div class="pt-4 space-y-4">
                  <!-- User msg -->
                  <div class="flex items-start gap-2.5">
                    <div
                      class="w-8 h-8 rounded-lg bg-blue-500 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">
                      T
                    </div>
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <span class="font-semibold text-sm text-gray-800"
                          >Tú</span
                        >
                        <span class="text-[11px] text-gray-400">10:32</span>
                      </div>
                      <p class="text-sm text-gray-700 leading-relaxed">
                        @hermes dame un resumen de los emails sin responder
                      </p>
                    </div>
                  </div>
                  <!-- Hermes reply -->
                  <div class="flex items-start gap-2.5">
                    <div
                      class="w-8 h-8 rounded-lg bg-primary flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">
                      H
                    </div>
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <span class="font-semibold text-sm text-gray-800"
                          >Hermes</span
                        >
                        <span
                          class="text-[9px] bg-primary-soft text-primary-strong px-1.5 py-0.5 rounded font-medium"
                          >App</span
                        >
                        <span class="text-[11px] text-gray-400">10:32</span>
                      </div>
                      <p class="text-sm text-gray-700">
                        Tienes <strong>3 emails importantes</strong> sin
                        responder:
                      </p>
                      <ul class="text-sm text-gray-600 mt-2 space-y-1">
                        <li class="flex items-start gap-1.5">
                          <span class="text-primary mt-0.5">→</span>Propuesta de
                          Acme Corp (hace 2 días)
                        </li>
                        <li class="flex items-start gap-1.5">
                          <span class="text-primary mt-0.5">→</span>Revisión
                          contrato proveedor
                        </li>
                        <li class="flex items-start gap-1.5">
                          <span class="text-primary mt-0.5">→</span>Factura
                          #2847 pendiente
                        </li>
                      </ul>
                      <p class="text-sm text-primary mt-2.5 font-medium">
                        ¿Quieres que redacte respuesta para alguno?
                      </p>
                    </div>
                  </div>
                  <!-- User follow-up -->
                  <div class="flex items-start gap-2.5">
                    <div
                      class="w-8 h-8 rounded-lg bg-blue-500 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">
                      T
                    </div>
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <span class="font-semibold text-sm text-gray-800"
                          >Tú</span
                        >
                        <span class="text-[11px] text-gray-400">10:33</span>
                      </div>
                      <p class="text-sm text-gray-700">sí, el primero</p>
                    </div>
                  </div>
                </div>
                <!-- Typing -->
                <div
                  class="flex items-center gap-2.5 mt-4 pt-3 border-t border-gray-100">
                  <div
                    class="w-8 h-8 rounded-lg bg-primary flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">
                    H
                  </div>
                  <div class="flex gap-1 items-center">
                    <div
                      class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style="animation-delay:0ms">
                    </div>
                    <div
                      class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style="animation-delay:150ms">
                    </div>
                    <div
                      class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style="animation-delay:300ms">
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </Container>
      </section>

      <!-- ===== 2. PROBLEM ===== -->
      <section class="py-20 bg-white">
        <Container>
          <div class="text-center max-w-2xl mx-auto mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-primary-strong">
              ¿Por qué no funciona lo de siempre?
            </h2>
            <p class="mt-4 text-default-soft text-lg">
              Tres razones por las que los agentes IA comerciales no encajan en
              empresas que trabajan en serio.
            </p>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            <!-- Card 1 -->
            <div
              class="bg-muted-soft rounded-2xl p-8 border border-muted-strong">
              <div
                class="w-12 h-12 bg-danger-soft rounded-xl flex items-center justify-center mb-5">
                <svg
                  class="w-6 h-6 text-danger"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                Tu privacidad no es su prioridad
              </h3>
              <p class="text-default-soft leading-relaxed">
                Los agentes IA comerciales son cajas negras. Tus datos viven en
                su nube, sus servidores, sus modelos. Tú no controlas nada.
              </p>
            </div>
            <!-- Card 2 -->
            <div
              class="bg-muted-soft rounded-2xl p-8 border border-muted-strong">
              <div
                class="w-12 h-12 bg-warning-soft rounded-xl flex items-center justify-center mb-5">
                <svg
                  class="w-6 h-6 text-warning-strong"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                Montarlo tú es una pesadilla
              </h3>
              <p class="text-default-soft leading-relaxed">
                VPS, Linux, Python, YAMLs, claves API, proxies... y horas de
                fricción antes de que funcione algo. No es tu trabajo.
              </p>
            </div>
            <!-- Card 3 -->
            <div
              class="bg-muted-soft rounded-2xl p-8 border border-muted-strong">
              <div
                class="w-12 h-12 bg-info-soft rounded-xl flex items-center justify-center mb-5">
                <svg
                  class="w-6 h-6 text-info"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                SaaS que escala (tu factura)
              </h3>
              <p class="text-default-soft leading-relaxed">
                Las suscripciones SaaS escalan con cada usuario. Tú quieres
                pagar una vez y olvidarte. No 30€/mes por asiento.
              </p>
            </div>
          </div>
        </Container>
      </section>

      <!-- ===== 3. HOW IT WORKS ===== -->
      <section class="py-20 bg-muted-soft">
        <Container>
          <div class="text-center max-w-2xl mx-auto mb-14">
            <h2 class="text-3xl md:text-4xl font-bold text-primary-strong">
              Cómo funciona
            </h2>
            <p class="mt-4 text-default-soft text-lg">
              Tres pasos. Del formulario a un agente funcionando.
            </p>
          </div>
          <div class="grid md:grid-cols-3 gap-8">
            <div
              class="bg-white rounded-2xl p-8 border border-muted-strong shadow-sm">
              <div
                class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-6">
                1
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                Reservas tu instalación
              </h3>
              <p class="text-default-soft leading-relaxed">
                Rellenas el formulario con tu caso de uso. Te llamo en 24h para
                confirmar requisitos y arrancar.
              </p>
            </div>
            <div
              class="bg-white rounded-2xl p-8 border border-muted-strong shadow-sm">
              <div
                class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-6">
                2
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                Provisionamos tu Hermes
              </h3>
              <p class="text-default-soft leading-relaxed">
                Configuro un VPS a tu nombre, instalo Hermes, conecto Slack o
                Telegram, integro tus MCPs. Todo en menos de 48h.
              </p>
            </div>
            <div
              class="bg-white rounded-2xl p-8 border border-muted-strong shadow-sm">
              <div
                class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-6">
                3
              </div>
              <h3 class="text-xl font-bold text-primary-strong mb-3">
                Lo usas como un humano
              </h3>
              <p class="text-default-soft leading-relaxed">
                Le hablas en lenguaje natural desde tu móvil o escritorio. Lee
                tu calendario, busca en Notion, redacta emails, ejecuta
                automatizaciones.
              </p>
            </div>
          </div>
        </Container>
      </section>

      <!-- ===== 4. WHAT'S INCLUDED ===== -->
      <section id="incluye" class="py-20 bg-white">
        <Container>
          <div class="text-center max-w-2xl mx-auto mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-primary-strong">
              Qué incluye tu instalación
            </h2>
            <p class="mt-4 text-default-soft text-lg">
              Pago único para el setup. Mantenimiento mensual sin permanencia
              si lo quieres.
            </p>
          </div>
          <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            <!-- Setup -->
            <div
              class="bg-primary-soft rounded-2xl p-8 border-2 border-primary-accent">
              <div class="flex items-start justify-between mb-6 gap-4">
                <h3 class="text-2xl font-bold text-primary-strong">
                  Setup inicial
                </h3>
                <div class="text-right flex-shrink-0">
                  <span class="text-3xl font-bold text-primary">599€</span>
                  <span class="text-default-soft text-sm block">pago único</span
                  >
                </div>
              </div>
              <ul class="space-y-3">
                {
                  setupItems.map((item) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2.5"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      <span class="text-default text-sm leading-relaxed">
                        {item}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
            <!-- Maintenance -->
            <div
              class="bg-muted-soft rounded-2xl p-8 border border-muted-strong">
              <div class="flex items-start justify-between mb-6 gap-4">
                <h3 class="text-2xl font-bold text-primary-strong">
                  Mantenimiento
                </h3>
                <div class="text-right flex-shrink-0">
                  <span class="text-3xl font-bold text-primary">59€</span>
                  <span class="text-default-soft text-sm block">/mes</span>
                </div>
              </div>
              <ul class="space-y-3">
                {
                  maintItems.map((item) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2.5"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      <span class="text-default text-sm leading-relaxed">
                        {item}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
          <p class="text-center text-default-soft mt-8 max-w-xl mx-auto text-sm">
            Sin permanencia. Cancelas el mantenimiento cuando quieras y te
            quedas con tu Hermes funcionando.
          </p>
        </Container>
      </section>

      <!-- ===== 5. MCP CATALOG ===== -->
      <section class="py-20 bg-muted-soft">
        <Container>
          <div class="text-center max-w-2xl mx-auto mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-primary-strong">
              MCPs disponibles en tu instalación
            </h2>
