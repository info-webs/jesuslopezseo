                      </label>
                    ))
                  }
                </div>
                <div class="mt-3">
                  <input
                    type="text"
                    name="mcps_otros"
                    placeholder="Otros MCPs que necesites (separados por coma)"
                    class="w-full border-2 border-muted-strong rounded-xl py-3 px-4 text-sm placeholder:text-default-soft focus:border-primary focus:ring-1 focus:ring-primary outline-none transition"
                  />
                </div>
              </fieldset>

              <!-- Caso de uso -->
              <div>
                <label
                  for="caso_uso"
                  class="block text-sm font-medium text-default mb-1.5">
                  Cuéntame tu caso de uso principal <span
                    class="text-danger"
                    aria-hidden="true">*</span
