                    >(selecciona todos los que te interesen)</span
                  >
                </legend>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5">
                  {
                    [
                      "Slack",
                      "Telegram",
                      "Notion",
                      "Gmail",
                      "Google Calendar",
                      "Google Drive",
                      "GitHub",
                      "Linear",
                      "Stripe",
                      "Supabase",
                      "Make",
                      "Semrush",
                    ].map((mcp) => (
                      <label class="flex items-center gap-2 cursor-pointer">
