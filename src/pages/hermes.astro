                  >
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  autocomplete="name"
                  placeholder="María García"
                  class="peer w-full border-2 border-muted-strong rounded-xl py-3.5 px-4 placeholder:text-default-soft focus:border-primary focus:ring-1 focus:ring-primary outline-none transition [.validated_&]:invalid:border-pink-500"
                />
                <p
                  class="mt-1.5 hidden text-pink-600 text-sm [.validated_&]:peer-invalid:block">
                  Por favor, introduce tu nombre completo.
                </p>
              </div>

              <!-- Email -->
              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-default mb-1.5">
                  Email <span class="text-danger" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="maria@empresa.com"
                  class="peer w-full border-2 border-muted-strong rounded-xl py-3.5 px-4 placeholder:text-default-soft focus:border-primary focus:ring-1 focus:ring-primary outline-none transition [.validated_&]:invalid:border-pink-500"
                />
                <p
                  class="mt-1.5 hidden text-pink-600 text-sm [.validated_&]:peer-placeholder-shown:peer-invalid:block">
                  El email es obligatorio.
                </p>
                <p
                  class="mt-1.5 hidden text-pink-600 text-sm [.validated_&]:peer-[:not(:placeholder-shown)]:peer-invalid:block">
                  Introduce un email válido.
                </p>
              </div>

              <!-- Empresa -->
              <div>
                <label
                  for="empresa"
                  class="block text-sm font-medium text-default mb-1.5">
                  Empresa / proyecto <span class="text-default-soft font-normal"
                    >(opcional)</span
                  >
                </label>
                <input
                  type="text"
                  id="empresa"
                  name="empresa"
                  autocomplete="organization"
                  placeholder="Agencia SEO Madrid"
                  class="w-full border-2 border-muted-strong rounded-xl py-3.5 px-4 placeholder:text-default-soft focus:border-primary focus:ring-1 focus:ring-primary outline-none transition"
                />
              </div>

              <!-- Plataforma -->
              <fieldset>
                <legend class="block text-sm font-medium text-default mb-3">
                  Plataforma preferida <span
                    class="text-danger"
                    aria-hidden="true">*</span
                  >
                </legend>
                <div class="flex gap-8">
                  <label class="flex items-center gap-2.5 cursor-pointer">
                    <input
                      type="radio"
                      name="plataforma"
                      value="Slack"
                      required
                      class="w-4 h-4 accent-primary"
                    />
                    <span class="text-default">Slack</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer">
                    <input
                      type="radio"
                      name="plataforma"
                      value="Telegram"
                      class="w-4 h-4 accent-primary"
                    />
                    <span class="text-default">Telegram</span>
                  </label>
                </div>
              </fieldset>

              <!-- MCPs -->
              <fieldset>
                <legend class="block text-sm font-medium text-default mb-3">
