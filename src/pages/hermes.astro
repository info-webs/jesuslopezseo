              type="hidden"
              name="access_key"
              value="YOUR_WEB3FORMS_ACCESS_KEY"
            />
            <input
              type="hidden"
              name="subject"
              value="Nueva solicitud — Hermes Pro Setup"
            />
            <input
              type="hidden"
              name="from_name"
              value="Jesús López SEO — Hermes Form"
            />
            <input
              type="checkbox"
              class="hidden"
              style="display:none"
              name="botcheck"
            />

            <div class="space-y-6">
              <!-- Nombre -->
              <div>
                <label
                  for="nombre"
