---
import Container from "@components/container.astro";

const extensionUrl =
  "https://chromewebstore.google.com/detail/seo-tech-inspector/eogpbbpnoafhdefkljcnljjhebdeipbj?hl=es";
---

<div class="py-20 md:py-24">
  <Container>
    <div
      class="bg-primary-strong rounded-3xl px-6 py-12 md:px-16 md:py-16 relative overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 items-center">
        <div class="text-white">
          <span
            class="inline-flex items-center gap-2 bg-white/10 text-white text-sm font-medium px-3 py-1 rounded-full mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="4"></circle>
              <line x1="21.17" y1="8" x2="12" y2="8"></line>
              <line x1="3.95" y1="6.06" x2="8.54" y2="14"></line>
              <line x1="10.88" y1="21.94" x2="15.46" y2="14"></line>
            </svg>
            Extensión gratuita para Chrome
          </span>
          <h3
            class="text-3xl md:text-4xl font-bold leading-tight [text-wrap:balance]">
            Audita cualquier web en segundos con SEO Tech Inspector
          </h3>
          <p class="text-white/80 text-lg leading-8 mt-5 max-w-2xl">
            Inspecciona meta tags, encabezados, enlaces, datos estructurados y
            señales técnicas directamente desde tu navegador. Instálala gratis
            y acelera tus auditorías SEO.
          </p>
        </div>
        <div class="flex md:justify-end">
          <a
            href={extensionUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-white text-primary-strong text-lg font-medium rounded-lg py-4 px-7 transition hover:bg-primary-accent hover:text-white whitespace-nowrap">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="4"></circle>
              <line x1="21.17" y1="8" x2="12" y2="8"></line>
              <line x1="3.95" y1="6.06" x2="8.54" y2="14"></line>
              <line x1="10.88" y1="21.94" x2="15.46" y2="14"></line>
            </svg>
            Añadir a Chrome
          </a>
        </div>
      </div>
    </div>
  </Container>
</div>
