---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'Posicionamiento SEO', href: '/posicionamiento-web' },
  { label: 'Posicionamiento GEO', href: '/servicios/posicionamiento-geo-salamanca' },
  { label: 'Diseño Web', href: '/servicios/diseno-web' },
  { label: 'Community Manager', href: '/servicios/community-manager' },
  { label: 'Redacción de contenido', href: '/servicios/redaccion-contenido' },
  { label: 'Diseño gráfico', href: '/servicios/diseno-grafico' },
  { label: 'Posicionamiento ASO', href: '/servicios/posicionamiento-aso' },
  { label: 'Hosting SEO', href: '/servicios/hosting-seo' },
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="container footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="JesusLopezSEO">
          <span class="footer-logo-icon">J</span>
          <span class="footer-logo-name">JesusLopez<strong>SEO</strong></span>
        </a>
        <p class="footer-desc">
          Consultor SEO en Salamanca con más de 18 años de experiencia ayudando a empresas a crecer en Google.
        </p>
        <div class="footer-contact">
          <a href="tel:+34618015995" class="contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            618 015 995
          </a>
          <a href="mailto:jesus@jesuslopezseo.com" class="contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            jesus@jesuslopezseo.com
          </a>
          <span class="contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Plaza Mayor 11, Ático Derecha, Salamanca
          </span>
        </div>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Servicios</h4>
        <ul class="footer-links">
          {services.map(s => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick links -->
      <div class="footer-col">
        <h4 class="footer-heading">Empresa</h4>
        <ul class="footer-links">
          <li><a href="/">Inicio</a></li>
          <li><a href="/blog">Blog SEO</a></li>
          <li><a href="/contactar">Contacto</a></li>
          <li><a href="/pedir-presupuesto">Pedir presupuesto</a></li>
          <li><a href="/politica-de-cookies">Política de cookies</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div class="footer-col footer-cta-col">
        <h4 class="footer-heading">¿Hablamos?</h4>
        <p class="footer-cta-text">Cuéntanos tu proyecto y te preparamos un presupuesto sin compromiso.</p>
        <a href="/pedir-presupuesto" class="btn btn-primary">Solicitar presupuesto →</a>
        <div class="footer-hours">
          <strong>Horario de atención</strong>
          <span>Lun–Vie · 9:00–18:00</span>
        </div>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">© {currentYear} JesusLopezSEO. Todos los derechos reservados.</p>
      <div class="footer-bottom-links">
        <a href="/politica-de-cookies">Cookies</a>
        <span>·</span>
        <a href="/contactar">Contacto</a>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  margin-top: auto;
  background: var(--text-primary);
}

/* Top */
.footer-top {
  background: var(--text-primary);
  padding: 5rem 0 4rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
  gap: 3rem;
}

/* Brand */
.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}
.footer-logo-icon {
  width: 36px; height: 36px;
  background: var(--primary);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-serif);
  font-size: 1.125rem;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.footer-logo-name {
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: -0.02em;
}
.footer-logo-name strong { color: var(--primary); }

.footer-desc {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.footer-contact { display: flex; flex-direction: column; gap: 0.625rem; }
.contact-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: rgba(255,255,255,0.85);
  transition: color 200ms;
}
.contact-item:hover { color: var(--primary); }

/* Columns */
.footer-heading {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1.25rem;
}

.footer-links { display: flex; flex-direction: column; gap: 0.625rem; }
.footer-links a {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.85);
  transition: color 200ms;
}
.footer-links a:hover { color: var(--primary); }

/* CTA col */
.footer-cta-text {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.78);
  line-height: 1.6;
  margin-bottom: 1.25rem;
}

.footer-hours {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  margin-top: 1.25rem;
  padding: 0.875rem 1rem;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-md);
}
.footer-hours strong {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.95);
}
.footer-hours span {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.7);
}

/* Bottom */
.footer-bottom {
  background: #050505;
  padding: 1.25rem 0;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.footer-bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.footer-copy {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.55);
}
.footer-bottom-links {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.5);
}
.footer-bottom-links a { color: rgba(255,255,255,0.7); transition: color 200ms; }
.footer-bottom-links a:hover { color: var(--primary); }

/* Responsive */
@media (max-width: 1024px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-top { padding: 3rem 0 2.5rem; }
  .footer-bottom-inner { flex-direction: column; text-align: center; }
}

/* ── WhatsApp floating button ── */
.wa-btn {
  position: fixed;
  bottom: 1.5rem;
  left: 1.5rem;
  z-index: 9999;
  display: flex;
  align-items: center;
  gap: 0;
  background: #25D366;
  color: #fff;
  border-radius: 9999px;
  box-shadow: 0 4px 16px rgba(37,211,102,0.45), 0 2px 6px rgba(0,0,0,0.15);
  text-decoration: none;
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 600;
  overflow: hidden;
  transition: box-shadow 200ms ease, transform 200ms ease;
  cursor: pointer;
  border: none;
}
.wa-btn:hover {
  box-shadow: 0 6px 24px rgba(37,211,102,0.55), 0 2px 8px rgba(0,0,0,0.2);
  transform: translateY(-2px);
}
.wa-btn:hover .wa-label { max-width: 200px; padding: 0 1rem 0 0.5rem; opacity: 1; }
.wa-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  flex-shrink: 0;
}
.wa-label {
  max-width: 0;
  opacity: 0;
  overflow: hidden;
  white-space: nowrap;
  transition: max-width 300ms ease, opacity 250ms ease, padding 300ms ease;
  padding: 0;
  line-height: 52px;
}
/* On mobile: always show icon only, no hover expand */
@media (max-width: 640px) {
  .wa-btn { bottom: 5rem; left: 1rem; }
  .wa-btn:hover .wa-label { max-width: 0; padding: 0; opacity: 0; }
  .wa-icon { width: 48px; height: 48px; }
}
/* Hide behind mobile TOC button if present */
.mobile-toc-btn ~ .wa-btn { bottom: 5rem; }
</style>

<!-- WhatsApp floating button -->
<a
  href="https://wa.me/34618015995?text=Hola%20Jesús%2C%20me%20gustaría%20información%20sobre%20vuestros%20servicios%20SEO"
  class="wa-btn"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  title="Escríbenos por WhatsApp"
>
  <span class="wa-icon">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
    </svg>
  </span>
  <span class="wa-label">¿Hablamos?</span>
</a>
