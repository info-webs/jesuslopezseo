---
interface Props {
  currentPage: number;
  lastPage: number;
  total: number;
  rangeStart: number;
  rangeEnd: number;
  category?: string;
  basePath?: string;
}

const {
  currentPage,
  lastPage,
  total,
  rangeStart,
  rangeEnd,
  category,
  basePath = '/blog',
} = Astro.props;

function hrefFor(n: number): string {
  const params = new URLSearchParams();
  if (category) params.set('categoria', category);
  if (n > 1) params.set('page', String(n));
  const qs = params.toString();
  return qs ? `${basePath}?${qs}` : `${basePath}`;
}

type Item = { type: 'page'; n: number } | { type: 'ellipsis'; key: string };

function buildItems(cur: number, last: number): Item[] {
  if (last <= 7) {
    return Array.from({ length: last }, (_, i) => ({ type: 'page' as const, n: i + 1 }));
  }
  const items: Item[] = [{ type: 'page', n: 1 }];
  const wStart = Math.max(2, cur - 1);
  const wEnd = Math.min(last - 1, cur + 1);
  if (wStart > 2) items.push({ type: 'ellipsis', key: 'l' });
  for (let n = wStart; n <= wEnd; n++) items.push({ type: 'page', n });
  if (wEnd < last - 1) items.push({ type: 'ellipsis', key: 'r' });
  items.push({ type: 'page', n: last });
  return items;
}

const items = buildItems(currentPage, lastPage);
const prevHref = currentPage > 1 ? hrefFor(currentPage - 1) : null;
const nextHref = currentPage < lastPage ? hrefFor(currentPage + 1) : null;
---

{lastPage > 1 && (
  <nav class="pagination" aria-label="Paginación del blog">
    <p class="pagination-summary">
      Mostrando <strong>{rangeStart}</strong>–<strong>{rangeEnd}</strong> de <strong>{total}</strong> artículos
    </p>

    <ul class="pagination-list">
      <li>
        {prevHref ? (
          <a href={prevHref} rel="prev" aria-label="Página anterior" class="pag-btn pag-btn--nav">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            <span class="pag-label">Anterior</span>
          </a>
        ) : (
          <span class="pag-btn pag-btn--nav pag-btn--disabled" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            <span class="pag-label">Anterior</span>
          </span>
        )}
      </li>

      {items.map((item) =>
        item.type === 'ellipsis' ? (
          <li aria-hidden="true" class="pag-ellipsis">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="5" cy="12" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/>
            </svg>
          </li>
        ) : item.n === currentPage ? (
          <li>
            <span aria-current="page" class="pag-btn pag-btn--current">{item.n}</span>
          </li>
        ) : (
          <li>
            <a href={hrefFor(item.n)} aria-label={`Ir a la página ${item.n}`} class="pag-btn">{item.n}</a>
          </li>
        )
      )}

      <li>
        {nextHref ? (
          <a href={nextHref} rel="next" aria-label="Página siguiente" class="pag-btn pag-btn--nav pag-btn--next">
            <span class="pag-label">Siguiente</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        ) : (
          <span class="pag-btn pag-btn--nav pag-btn--disabled" aria-hidden="true">
            <span class="pag-label">Siguiente</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </span>
        )}
      </li>
    </ul>
  </nav>
)}

<style>
.pagination {
  margin-top: 3.5rem;
  padding-top: 2.25rem;
  border-top: 1px solid var(--surface-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
}
@media (min-width: 720px) {
  .pagination {
    flex-direction: row;
    justify-content: space-between;
  }
}

.pagination-summary {
  margin: 0;
  font-size: 0.875rem;
  color: var(--text-muted);
}
.pagination-summary strong {
  color: var(--text-primary);
  font-weight: 600;
}

.pagination-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.375rem;
  flex-wrap: wrap;
  justify-content: center;
}

.pag-btn {
  min-width: 40px;
  height: 40px;
  padding: 0 0.75rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary);
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius-lg, 0.75rem);
  text-decoration: none;
  transition: all 150ms ease;
  cursor: pointer;
  user-select: none;
}
.pag-btn:hover {
  color: var(--primary-dark);
  background: var(--amber-50);
  border-color: var(--amber-200);
  transform: translateY(-1px);
}

.pag-btn--current {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  font-weight: 600;
  box-shadow: 0 6px 16px -6px rgba(245, 158, 11, 0.55);
}
.pag-btn--current:hover {
  background: var(--primary);
  color: #fff;
  transform: none;
}

.pag-btn--nav {
  background: var(--surface-card);
  border-color: var(--surface-border);
  color: var(--text-primary);
  box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.04));
}
.pag-btn--nav:hover {
  border-color: var(--amber-200);
  background: var(--amber-50);
  color: var(--primary-dark);
}
.pag-btn--next {
  background: var(--text-primary);
  color: #fff;
  border-color: var(--text-primary);
}
.pag-btn--next:hover {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}

.pag-btn--disabled {
  opacity: 0.4;
  pointer-events: none;
  cursor: not-allowed;
}

.pag-ellipsis {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  color: var(--text-light);
}

@media (max-width: 560px) {
  .pag-label { display: none; }
  .pag-btn--nav { min-width: 40px; padding: 0; }
}
</style>
