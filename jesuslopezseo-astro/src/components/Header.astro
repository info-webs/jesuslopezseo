---
const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'SEO', href: '/posicionamiento-web' },
  { label: 'Diseño Web', href: '/servicios/diseno-web' },
  { label: 'Servicios', href: '#servicios', submenu: [
    { label: 'Community Manager', href: '/servicios/community-manager' },
    { label: 'Redacción de contenido', href: '/servicios/redaccion-contenido' },
    { label: 'Diseño gráfico', href: '/servicios/diseno-grafico' },
    { label: 'Posicionamiento ASO', href: '/servicios/posicionamiento-aso' },
    { label: 'Hosting SEO', href: '/servicios/hosting-seo' },
  ]},
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contactar' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="JesusLopezSEO — Inicio">
      <span class="logo-icon">J</span>
      <div class="logo-text">
        <span class="logo-name">JesusLopez<strong>SEO</strong></span>
        <span class="logo-tagline">Consultor SEO · Salamanca</span>
      </div>
    </a>

    <!-- Nav Desktop -->
    <nav class="nav-desktop" aria-label="Navegación principal">
      {navLinks.map(link => (
        link.submenu ? (
          <div class="nav-dropdown">
            <button class="nav-link nav-link--dropdown" aria-expanded="false" aria-haspopup="true">
              {link.label}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="dropdown-menu" role="menu">
              {link.submenu.map(sub => (
                <a href={sub.href} class="dropdown-item" role="menuitem">{sub.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`nav-link ${currentPath === link.href ? 'nav-link--active' : ''}`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>

    <!-- CTA -->
    <div class="header-actions">
      <a href="tel:+34618015995" class="btn-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        618 015 995
      </a>
      <a href="/pedir-presupuesto" class="btn btn-primary btn-sm">Pedir presupuesto</a>
      <button class="btn-mobile-menu" id="mobile-menu-btn" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="nav-mobile" id="mobile-nav" aria-hidden="true">
    <nav>
      {navLinks.map(link => (
        link.submenu ? (
          <details class="mobile-dropdown">
            <summary class="mobile-nav-link">{link.label}</summary>
            <div class="mobile-submenu">
              {link.submenu.map(sub => (
                <a href={sub.href} class="mobile-submenu-link">{sub.label}</a>
              ))}
            </div>
          </details>
        ) : (
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        )
      ))}
      <a href="/pedir-presupuesto" class="btn btn-primary" style="margin-top:1rem;width:100%;justify-content:center;">Pedir presupuesto</a>
    </nav>
  </div>
</header>

<style>
/* ── Header Layout ── */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(250,249,247,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid transparent;
  transition: border-color 250ms ease, box-shadow 250ms ease;
}
.header.scrolled {
  border-color: var(--surface-border);
  box-shadow: 0 2px 20px rgba(26,24,20,0.06);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  height: 72px;
  min-width: 0;
}

/* ── Logo ── */
.logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 1;
  min-width: 0;
  transition: opacity 200ms;
}
.logo:hover { opacity: 0.85; }

.logo-icon {
  width: 38px;
  height: 38px;
  background: var(--primary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(245,158,11,0.3);
}

.logo-text {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.logo-name {
  font-size: 1.0625rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  line-height: 1.1;
}
.logo-name strong { color: var(--primary-dark); }
.logo-tagline {
  font-size: 0.6875rem;
  color: var(--text-muted);
  letter-spacing: 0.03em;
  line-height: 1;
}

/* ── Desktop Nav ── */
.nav-desktop {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
  justify-content: center;
}

.nav-link {
  position: relative;
  padding: 0.5rem 0.875rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
  border-radius: var(--radius-md);
  transition: all 200ms;
  white-space: nowrap;
}
.nav-link:hover { color: var(--text-primary); background: var(--cream-100); }
.nav-link--active { color: var(--primary-dark); font-weight: 600; }
.nav-link--active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: var(--primary);
  border-radius: 2px;
}

.nav-link--dropdown {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

/* ── Dropdown ── */
.nav-dropdown {
  position: relative;
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 220px;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xl);
  padding: 0.5rem;
  opacity: 0;
  pointer-events: none;
  transform: translateX(-50%) translateY(-8px);
  transition: all 200ms ease;
}

.nav-dropdown:hover .dropdown-menu,
.nav-dropdown:focus-within .dropdown-menu {
  opacity: 1;
  pointer-events: all;
  transform: translateX(-50%) translateY(0);
}

.dropdown-item {
  display: block;
  padding: 0.625rem 0.875rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  transition: all 150ms;
}
.dropdown-item:hover {
  background: var(--amber-50);
  color: var(--primary-dark);
}

/* ── Header Actions ── */
.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.btn-phone {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-secondary);
  transition: color 200ms;
}
.btn-phone:hover { color: var(--primary-dark); }

/* ── Mobile Menu Button ── */
.btn-mobile-menu {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
  border-radius: var(--radius-sm);
  transition: background 200ms;
}
.btn-mobile-menu:hover { background: var(--cream-200); }
.btn-mobile-menu span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: all 250ms;
}

/* ── Mobile Nav ── */
.nav-mobile {
  display: none;
  overflow: hidden;
  max-height: 0;
  transition: max-height 300ms ease;
  background: var(--surface-card);
  border-top: 1px solid var(--surface-border);
}
.nav-mobile.open {
  max-height: 600px;
}
.nav-mobile nav {
  padding: 1rem var(--container-pad) 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.mobile-nav-link {
  display: block;
  padding: 0.75rem 0.875rem;
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-primary);
  border-radius: var(--radius-md);
  transition: background 150ms;
}
.mobile-nav-link:hover { background: var(--cream-100); }

.mobile-dropdown summary { cursor: pointer; list-style: none; }
.mobile-dropdown summary::-webkit-details-marker { display: none; }
.mobile-submenu { padding-left: 1rem; margin-top: 0.25rem; }
.mobile-submenu-link {
  display: block;
  padding: 0.5rem 0.875rem;
  font-size: 0.9rem;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  transition: color 150ms;
}
.mobile-submenu-link:hover { color: var(--primary-dark); }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .nav-desktop { display: none; }
  .btn-phone { display: none; }
  .btn-mobile-menu { display: flex; }
  .nav-mobile { display: block; }
  .header-inner { gap: 1rem; }
}
@media (max-width: 640px) {
  .logo-tagline { display: none; }
  .header-inner { gap: 0.75rem; }
  .header-actions { gap: 0.5rem; }
  .header-actions .btn-sm { padding: 0.5rem 1rem; font-size: 0.8125rem; }
  .logo-name { font-size: 0.95rem; }
  .logo-icon { width: 34px; height: 34px; font-size: 1.125rem; }
}
@media (max-width: 380px) {
  .logo-name { display: none; }
}
</style>

<script>
// Header scroll effect
const header = document.getElementById('site-header');
window.addEventListener('scroll', () => {
  header?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

// Mobile menu
const btn = document.getElementById('mobile-menu-btn');
const nav = document.getElementById('mobile-nav');
btn?.addEventListener('click', () => {
  const isOpen = nav?.classList.toggle('open');
  btn.setAttribute('aria-expanded', String(isOpen));
  nav?.setAttribute('aria-hidden', String(!isOpen));
});
</script>
