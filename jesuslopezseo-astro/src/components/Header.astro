---
const currentPath = Astro.url.pathname;

const seoServices = [
  {
    label: 'Posicionamiento SEO',
    href: '/posicionamiento-web',
    desc: 'Estrategia SEO integral para Google',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    label: 'Posicionamiento GEO',
    href: '/servicios/posicionamiento-geo-salamanca',
    desc: 'Aparece en ChatGPT, Perplexity y Gemini',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 2v10l8 2"/><circle cx="12" cy="12" r="3"/></svg>`,
    badge: 'NUEVO',
  },
  {
    label: 'Posicionamiento ASO',
    href: '/servicios/posicionamiento-aso',
    desc: 'Más descargas para tu app móvil',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="2" width="14" height="20" rx="2.5"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
  },
  {
    label: 'Hosting SEO',
    href: '/servicios/hosting-seo',
    desc: 'Alojamiento optimizado para posicionar',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="4" width="20" height="7" rx="2"/><rect x="2" y="13" width="20" height="7" rx="2"/><line x1="6" y1="7.5" x2="6.01" y2="7.5"/><line x1="6" y1="16.5" x2="6.01" y2="16.5"/></svg>`,
  },
];

const designServices = [
  {
    label: 'Diseño Web',
    href: '/servicios/diseno-web',
    desc: 'Webs profesionales orientadas a conversión',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    label: 'Diseño Gráfico',
    href: '/servicios/diseno-grafico',
    desc: 'Identidad visual que te hace memorable',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="m8.5 8.5 7 7m-7 0 7-7"/></svg>`,
  },
  {
    label: 'Redacción de Contenido',
    href: '/servicios/redaccion-contenido',
    desc: 'Contenido SEO que posiciona y convierte',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>`,
  },
  {
    label: 'Community Manager',
    href: '/servicios/community-manager',
    desc: 'Gestión profesional de redes sociales',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<header class="header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="JesusLopezSEO — Inicio">
      <span class="logo-icon">J</span>
      <div class="logo-text">
        <span class="logo-name">JesusLopez<strong>SEO</strong></span>
        <span class="logo-tagline">Consultor SEO · Salamanca</span>
      </div>
    </a>

    <nav class="nav-desktop" aria-label="Navegación principal">
      <a href="/" class={`nav-link ${currentPath === '/' ? 'nav-link--active' : ''}`}>Inicio</a>

      <div class="nav-mega">
        <button class="nav-link nav-link--dropdown" aria-expanded="false" aria-haspopup="true">
          Servicios
          <svg class="dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="mega-panel" role="menu">
          <div class="mega-grid">
            <div class="mega-col">
              <div class="mega-label"><span class="mega-dot mega-dot--amber"></span>SEO & Visibilidad</div>
              {seoServices.map(s => (
                <a href={s.href} class="mega-item" role="menuitem">
                  <span class="mega-icon" set:html={s.icon} />
                  <div class="mega-body">
                    <div class="mega-title">
                      {s.label}
                      {s.badge && <span class="mega-badge">{s.badge}</span>}
                    </div>
                    <div class="mega-desc">{s.desc}</div>
                  </div>
                </a>
              ))}
            </div>

            <div class="mega-col">
              <div class="mega-label"><span class="mega-dot mega-dot--ink"></span>Diseño & Contenido</div>
              {designServices.map(s => (
                <a href={s.href} class="mega-item" role="menuitem">
                  <span class="mega-icon" set:html={s.icon} />
                  <div class="mega-body">
                    <div class="mega-title">{s.label}</div>
                    <div class="mega-desc">{s.desc}</div>
                  </div>
                </a>
              ))}
            </div>

            <div class="mega-col mega-col--featured">
              <div class="mega-promo">
                <div class="mega-promo-bg" aria-hidden="true"></div>
                <div class="mega-promo-eyebrow">
                  <span class="live-dot-mini"></span>
                  Nuestra herramienta
                </div>
                <div class="mega-promo-title">LLMFY<span class="mega-promo-tld">.ai</span></div>
                <p class="mega-promo-desc">
                  La primera plataforma española de LLMO. Mide si ChatGPT, Perplexity, Claude y Gemini te mencionan.
                </p>
                <ul class="mega-promo-list">
                  <li>LLM Tracking en 4 modelos</li>
                  <li>E-E-A-T Audit con IA</li>
                  <li>Brand Sentiment Analysis</li>
                </ul>
                <a href="https://llmfy.ai" target="_blank" rel="noopener" class="mega-promo-cta">
                  Descubre LLMFY
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M7 17L17 7M8 7h9v9"/></svg>
                </a>
              </div>
            </div>
          </div>

          <div class="mega-footer">
            <a href="/posicionamiento-web" class="mega-footer-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Ver página principal de SEO
            </a>
            <a href="/pedir-presupuesto" class="mega-footer-link mega-footer-link--primary">
              Pedir presupuesto
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <a href="/blog" class={`nav-link ${currentPath.startsWith('/blog') ? 'nav-link--active' : ''}`}>Blog</a>
      <a href="/contactar" class={`nav-link ${currentPath === '/contactar' ? 'nav-link--active' : ''}`}>Contacto</a>
    </nav>

    <div class="header-actions">
      <a href="tel:+34618015995" class="btn-phone" aria-label="Llamar">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="btn-phone-num">618 015 995</span>
      </a>
      <a href="/pedir-presupuesto" class="btn btn-primary btn-sm">Presupuesto</a>
      <button class="btn-mobile-menu" id="mobile-menu-btn" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="mobile-nav" aria-hidden="true">
    <nav>
      <a href="/" class="mobile-nav-link">Inicio</a>
      <details class="mobile-dropdown" open>
        <summary class="mobile-nav-link">SEO & Visibilidad</summary>
        <div class="mobile-submenu">
          {seoServices.map(s => (
            <a href={s.href} class="mobile-submenu-link">
              {s.label}
              {s.badge && <span class="mega-badge">{s.badge}</span>}
            </a>
          ))}
        </div>
      </details>
      <details class="mobile-dropdown">
        <summary class="mobile-nav-link">Diseño & Contenido</summary>
        <div class="mobile-submenu">
          {designServices.map(s => (
            <a href={s.href} class="mobile-submenu-link">{s.label}</a>
          ))}
        </div>
      </details>
      <a href="/blog" class="mobile-nav-link">Blog</a>
      <a href="/contactar" class="mobile-nav-link">Contacto</a>
      <a href="https://llmfy.ai" target="_blank" rel="noopener" class="mobile-llmfy-card">
        <strong>LLMFY<span>.ai</span></strong>
        <span class="mobile-llmfy-desc">Mide tu visibilidad en ChatGPT, Perplexity y Gemini</span>
      </a>
      <a href="/pedir-presupuesto" class="btn btn-primary" style="margin-top:1rem;width:100%;justify-content:center;">Pedir presupuesto</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(250,249,247,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color 250ms ease, box-shadow 250ms ease;
  }
  .header.scrolled {
    border-color: var(--surface-border);
    box-shadow: 0 2px 20px rgba(26,24,20,0.06);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 72px;
    min-width: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--text-primary);
    color: #faf9f7;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.5rem;
    border-radius: 10px;
  }
  .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
  .logo-name { font-size: 1rem; font-weight: 500; color: var(--text-primary); }
  .logo-name strong { font-weight: 700; color: var(--primary-dark); }
  .logo-tagline {
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }
  .nav-link {
    position: relative;
    padding: 0.5rem 0.875rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 200ms ease;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-link:hover { color: var(--text-primary); background: rgba(0,0,0,0.03); }
  .nav-link--active { color: var(--primary-dark); }
  .nav-link--active::after {
    content: '';
    position: absolute;
    left: 50%; bottom: -2px;
    transform: translateX(-50%);
    width: 20px; height: 2px;
    background: var(--primary);
    border-radius: 2px;
  }

  .nav-mega { position: relative; }
  .dropdown-icon { transition: transform 200ms ease; }
  .nav-mega:hover .dropdown-icon, .nav-mega:focus-within .dropdown-icon { transform: rotate(180deg); }
  .nav-mega::before {
    content: '';
    position: absolute;
    top: 100%; left: 0; right: 0;
    height: 16px;
  }
  .mega-panel {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    width: min(900px, 92vw);
    background: #ffffff;
    border: 1px solid var(--surface-border);
    border-radius: 16px;
    box-shadow:
      0 2px 4px rgba(15,14,12,0.04),
      0 24px 48px -16px rgba(15,14,12,0.18);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease, transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }
  .nav-mega:hover .mega-panel, .nav-mega:focus-within .mega-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.05fr;
    gap: 1.5rem;
    padding: 1.5rem;
  }
  .mega-col { display: flex; flex-direction: column; gap: 0.375rem; }
  .mega-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 0.625rem 0.5rem;
    margin-bottom: 0.125rem;
    border-bottom: 1px solid var(--surface-border);
  }
  .mega-dot { width: 8px; height: 8px; border-radius: 2px; }
  .mega-dot--amber { background: #f59e0b; }
  .mega-dot--ink { background: var(--text-primary); }

  .mega-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 150ms ease;
  }
  .mega-item:hover { background: #f7f3eb; }
  .mega-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    background: #f7f3eb;
    color: var(--primary-dark);
    border-radius: 8px;
    transition: all 150ms ease;
  }
  .mega-icon :global(svg) { width: 18px; height: 18px; }
  .mega-item:hover .mega-icon { background: var(--text-primary); color: #fff; }
  .mega-body { flex: 1; min-width: 0; }
  .mega-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .mega-desc { font-size: 0.8125rem; color: var(--text-muted); line-height: 1.4; }
  .mega-badge {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    background: #00d57b;
    color: #0f0e0c;
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .mega-col--featured { padding-left: 1.25rem; border-left: 1px solid var(--surface-border); }
  .mega-promo {
    position: relative;
    height: 100%;
    padding: 1.25rem;
    border-radius: 12px;
    background: #0f0e0c;
    color: #faf9f7;
    overflow: hidden;
  }
  .mega-promo-bg {
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(0,213,123,0.2), transparent 60%);
    filter: blur(25px);
  }
  .mega-promo-eyebrow {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .live-dot-mini {
    width: 6px; height: 6px;
    background: #00d57b;
    border-radius: 50%;
    box-shadow: 0 0 8px #00d57b;
    animation: mini-pulse 2s ease-in-out infinite;
  }
  @keyframes mini-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .mega-promo-title {
    position: relative;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 0.625rem;
  }
  .mega-promo-tld { color: #00d57b; font-style: italic; }
  .mega-promo-desc {
    position: relative;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.72);
    margin: 0 0 0.875rem;
  }
  .mega-promo-list {
    position: relative;
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mega-promo-list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.72);
  }
  .mega-promo-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #00d57b;
    font-weight: 700;
  }
  .mega-promo-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.875rem;
    background: #00d57b;
    color: #0f0e0c;
    border-radius: 7px;
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 200ms ease;
  }
  .mega-promo-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(0,213,123,0.35); }

  .mega-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.5rem;
    background: #f7f3eb;
    border-top: 1px solid var(--surface-border);
  }
  .mega-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: all 150ms ease;
  }
  .mega-footer-link:hover { color: var(--text-primary); background: rgba(0,0,0,0.04); }
  .mega-footer-link--primary { color: var(--primary-dark); font-weight: 600; }
  .mega-footer-link--primary:hover { background: rgba(245,158,11,0.1); }

  .header-actions { display: flex; align-items: center; gap: 0.625rem; flex-shrink: 0; }
  .btn-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    color: var(--text-secondary);
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .btn-phone:hover { color: var(--primary-dark); background: rgba(0,0,0,0.03); }
  .btn-phone svg { color: var(--primary); }

  .btn-mobile-menu {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
  }
  .btn-mobile-menu span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    margin: 0 auto;
    transition: transform 200ms, opacity 200ms;
  }
  .btn-mobile-menu[aria-expanded="true"] span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .btn-mobile-menu[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .btn-mobile-menu[aria-expanded="true"] span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  .nav-mobile {
    position: fixed;
    top: 72px;
    left: 0; right: 0; bottom: 0;
    background: #0f0e0c;
    transform: translateX(100%);
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    z-index: 99;
  }
  .nav-mobile.is-open { transform: translateX(0); }
  .nav-mobile nav { display: flex; flex-direction: column; padding: 1.25rem 1.5rem 2rem; gap: 0.25rem; }
  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0.25rem;
    font-size: 1rem;
    font-weight: 500;
    color: #faf9f7;
    text-decoration: none;
    border-bottom: 1px solid rgba(250,249,247,0.08);
    cursor: pointer;
  }
  .mobile-dropdown summary { list-style: none; }
  .mobile-dropdown summary::-webkit-details-marker { display: none; }
  .mobile-dropdown summary::after { content: '+'; font-size: 1.25rem; color: rgba(250,249,247,0.5); font-weight: 300; }
  .mobile-dropdown[open] summary::after { content: '−'; }
  .mobile-submenu { padding: 0.375rem 0.75rem 0.75rem; display: flex; flex-direction: column; }
  .mobile-submenu-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.25rem;
    font-size: 0.9375rem;
    color: rgba(250,249,247,0.75);
    text-decoration: none;
  }
  .mobile-submenu-link:hover { color: var(--primary); }

  .mobile-llmfy-card {
    display: block;
    margin: 1.25rem 0 0;
    padding: 1rem 1.25rem;
    background: #0f0e0c;
    color: #faf9f7;
    border-radius: 12px;
    text-decoration: none;
  }
  .mobile-llmfy-card strong {
    display: block;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .mobile-llmfy-card strong span { color: #00d57b; font-style: italic; }
  .mobile-llmfy-desc { font-size: 0.8125rem; color: rgba(255,255,255,0.7); }

  @media (max-width: 1024px) {
    .nav-desktop { display: none; }
    .btn-mobile-menu { display: flex; }
    .btn-phone-num { display: none; }
    .btn-phone { padding: 0.5rem; }
  }
  @media (max-width: 640px) {
    .logo-tagline { display: none; }
    .logo-icon { width: 36px; height: 36px; font-size: 1.25rem; }
  }
  @media (max-width: 380px) {
    .logo-name { display: none; }
    .header-inner { gap: 0.5rem; }
  }
</style>

<script>
const header = document.getElementById('site-header');
window.addEventListener('scroll', () => {
  header?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

const mobileBtn = document.getElementById('mobile-menu-btn');
const mobileNav = document.getElementById('mobile-nav');
mobileBtn?.addEventListener('click', () => {
  const isOpen = mobileNav?.classList.toggle('is-open') ?? false;
  mobileBtn.setAttribute('aria-expanded', String(isOpen));
  mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  document.body.style.overflow = isOpen ? 'hidden' : '';
});
mobileNav?.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    mobileNav.classList.remove('is-open');
    mobileBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  });
});
</script>
