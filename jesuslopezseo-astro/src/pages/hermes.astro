---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const canonical = 'https://www.jesuslopezseo.com/hermes/';
const pageTitle = 'Hermes Pro Setup — Tu agente IA personal instalado en 48h | Jesús López SEO';
const pageDescription = 'Instalación gestionada del agente IA Hermes en tu propio servidor. Conectado a Slack o Telegram, con tus herramientas (Notion, Gmail, Calendar...). 599€ + 59€/mes. Sin código, sin servidores que mantener.';

const faqs = [
  {
    q: '¿Qué es Hermes exactamente?',
    a: 'Hermes es un agente IA open source desarrollado por Nous Research. Convierte modelos de lenguaje (Claude, GPT, Llama, etc.) en un asistente que ejecuta tareas reales: leer emails, buscar archivos, programar eventos, redactar respuestas. Lo controlas en lenguaje natural desde Slack o Telegram.',
  },
  {
    q: '¿Cuánto cuesta el LLM aparte?',
    a: 'Tú pones tu API key de OpenRouter o Anthropic. Para uso normal (50-100 mensajes/día) suele costar entre 10-30€/mes en tokens. Si lo usas masivamente, puede subir. Te asesoro en el onboarding.',
  },
  {
    q: '¿De quién es el VPS?',
    a: 'Tuyo. Lo contratas tú a tu nombre (te paso instrucciones), yo lo configuro con permisos delegados. Si dejas de trabajar conmigo, mantienes acceso completo.',
  },
  {
    q: '¿Qué pasa si Hermes se rompe o sale una versión nueva?',
    a: 'Para eso está el mantenimiento mensual. Yo me ocupo de actualizaciones, parches de seguridad y arreglos. Si cancelas el mantenimiento, sigue funcionando pero tú decides cuándo actualizar.',
  },
  {
    q: '¿Puedo añadir MCPs después de la instalación?',
    a: 'Sí, 49€ por MCP nuevo. Si están en mi catálogo es plug-and-play. Si es uno custom, te hago presupuesto.',
  },
  {
    q: '¿Es legal/ético usar Hermes comercialmente?',
    a: 'Sí, su licencia Apache 2.0 lo permite explícitamente. Tu instalación es privada, solo para ti o tu equipo.',
  },
  {
    q: '¿Funciona en español?',
    a: 'Perfectamente. El idioma del agente depende del modelo LLM que uses (Claude, GPT-4, etc.). Todos manejan español nativo.',
  },
  {
    q: '¿Qué pasa si quiero cancelar?',
    a: 'Cancelas el mantenimiento cuando quieras desde el formulario o por email, sin permanencia. Tu Hermes sigue funcionando en tu VPS. Si quieres darlo de baja del VPS, te ayudo con el apagado limpio.',
  },
];

const mcps = [
  'Slack', 'Telegram', 'Notion', 'Gmail',
  'Google Calendar', 'Google Drive', 'GitHub', 'Linear',
  'Stripe', 'Supabase', 'Make', 'Semrush',
];

const schemaService = {
  '@type': 'Service',
  name: 'Hermes Pro Setup',
  description: pageDescription,
  provider: {
    '@type': 'Organization',
    name: 'Posicionamiento Web Systems SL',
    url: 'https://www.jesuslopezseo.com',
  },
  areaServed: ['España', 'Europa'],
  serviceType: 'AI Agent Installation',
  offers: [
    { '@type': 'Offer', name: 'Setup inicial', price: '599', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Mantenimiento mensual', price: '59', priceCurrency: 'EUR' },
  ],
};

const schemaFaq = {
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schemaBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.jesuslopezseo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: 'https://www.jesuslopezseo.com/servicios/' },
    { '@type': 'ListItem', position: 3, name: 'Hermes Pro Setup', item: canonical },
  ],
};

const schema = JSON.stringify({ '@context': 'https://schema.org', '@graph': [schemaService, schemaFaq, schemaBreadcrumb] });
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={schema}
>
  <Header />

  <main class="h-page">

    <!-- ═══ HERO ═══ -->
    <section class="h-hero">
      <div class="h-hero-grid" aria-hidden="true"></div>
      <div class="h-hero-glow" aria-hidden="true"></div>
      <div class="container h-hero-inner">
        <div class="h-hero-copy">
          <div class="h-eyebrow">
            <span class="h-dot"></span>
            Hermes Pro Setup · Agente IA gestionado
          </div>
          <h1 class="h-hero-title">
            Tu agente IA personal<br/>
            en <em>Slack o Telegram.</em><br/>
            Instalado en <em>48 horas.</em>
          </h1>
          <p class="h-hero-desc">
            Te montamos Hermes (Nous Research) en tu propio servidor, conectado a tus herramientas. Tú hablas con él como con un asistente humano. Sin código, sin servidores que mantener, sin curva de aprendizaje.
          </p>
          <div class="h-hero-actions">
            <a href="#contacto" class="h-btn h-btn--amber">
              Reservar mi instalación
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#incluye" class="h-btn h-btn--ghost">
              Ver qué incluye
            </a>
          </div>
        </div>

        <!-- Slack mockup -->
        <div class="h-hero-aside" aria-hidden="true">
          <div class="h-mock">
            <div class="h-mock-head">
              <span class="h-slack-icon">#</span>
              <span class="h-mock-channel">general</span>
            </div>
            <div class="h-mock-msgs">
              <div class="h-msg">
                <div class="h-avatar h-avatar--user">T</div>
                <div>
                  <div class="h-msg-meta"><span>Tú</span><span class="h-ts">10:32</span></div>
                  <p>@hermes dame un resumen de los emails sin responder</p>
                </div>
              </div>
              <div class="h-msg">
                <div class="h-avatar h-avatar--bot">H</div>
                <div>
                  <div class="h-msg-meta">
                    <span>Hermes</span>
                    <span class="h-app-badge">App</span>
                    <span class="h-ts">10:32</span>
                  </div>
                  <p>Tienes <strong>3 emails importantes</strong> sin responder:</p>
                  <ul class="h-mock-list">
                    <li><span>→</span>Propuesta de Acme Corp (hace 2 días)</li>
                    <li><span>→</span>Revisión contrato proveedor</li>
                    <li><span>→</span>Factura #2847 pendiente</li>
                  </ul>
                  <p class="h-bot-cta">¿Quieres que redacte respuesta para alguno?</p>
                </div>
              </div>
              <div class="h-msg">
                <div class="h-avatar h-avatar--user">T</div>
                <div>
                  <div class="h-msg-meta"><span>Tú</span><span class="h-ts">10:33</span></div>
                  <p>sí, el primero</p>
                </div>
              </div>
            </div>
            <div class="h-mock-typing">
              <div class="h-avatar h-avatar--bot">H</div>
              <div class="h-dots">
                <span style="animation-delay:0ms"></span>
                <span style="animation-delay:150ms"></span>
                <span style="animation-delay:300ms"></span>
              </div>
            </div>
          </div>
          <div class="h-mock-badge">
            <span class="h-badge-icon">48h</span>
            <div>
              <div class="h-badge-num">Listo</div>
              <div class="h-badge-cap">para usar</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROBLEM ═══ -->
    <section class="h-section h-section--cream">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill">El problema</div>
          <h2 class="h-h2">¿Por qué no funciona<br/><em>lo de siempre?</em></h2>
        </div>
        <div class="h-cards-3">
          <div class="h-card">
            <div class="h-card-icon h-card-icon--red">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <h3>Tu privacidad no es su prioridad</h3>
            <p>Los agentes IA comerciales son cajas negras. Tus datos viven en su nube, sus servidores, sus modelos. Tú no controlas nada.</p>
          </div>
          <div class="h-card">
            <div class="h-card-icon h-card-icon--amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            </div>
            <h3>Montarlo tú es una pesadilla</h3>
            <p>VPS, Linux, Python, YAMLs, claves API, proxies... y horas de fricción antes de que funcione algo. No es tu trabajo.</p>
          </div>
          <div class="h-card">
            <div class="h-card-icon h-card-icon--blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3>SaaS que escala (tu factura)</h3>
            <p>Las suscripciones SaaS escalan con cada usuario. Tú quieres pagar una vez y olvidarte. No 30€/mes por asiento.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section class="h-section">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill">El proceso</div>
          <h2 class="h-h2">Cómo funciona.<br/><em>Tres pasos.</em></h2>
        </div>
        <div class="h-steps">
          <div class="h-step">
            <div class="h-step-num">01</div>
            <h3>Reservas tu instalación</h3>
            <p>Rellenas el formulario con tu caso de uso. Te llamo en 24h para confirmar requisitos y arrancar.</p>
          </div>
          <div class="h-step-arrow" aria-hidden="true">→</div>
          <div class="h-step">
            <div class="h-step-num">02</div>
            <h3>Provisionamos tu Hermes</h3>
            <p>Configuro un VPS a tu nombre, instalo Hermes, conecto Slack o Telegram, integro tus MCPs. Todo en menos de 48h.</p>
          </div>
          <div class="h-step-arrow" aria-hidden="true">→</div>
          <div class="h-step">
            <div class="h-step-num">03</div>
            <h3>Lo usas desde el día uno</h3>
            <p>Le hablas en lenguaje natural desde tu móvil o escritorio. Lee tu calendario, busca en Notion, redacta emails, ejecuta automatizaciones.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PRICING ═══ -->
    <section id="incluye" class="h-section h-section--cream">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill">Precios</div>
          <h2 class="h-h2">Sin letra pequeña.<br/><em>Sin sorpresas.</em></h2>
        </div>
        <div class="h-pricing">
          <div class="h-price-card h-price-card--featured">
            <div class="h-price-top">
              <div>
                <div class="h-price-label">Setup inicial</div>
                <div class="h-price-badge">Pago único</div>
              </div>
              <div class="h-price-amount">
                <span class="h-price-num">599€</span>
              </div>
            </div>
            <ul class="h-price-list">
              {[
                'VPS provisionado a tu nombre (Hetzner o Contabo — 5-8€/mes que pagas tú directo)',
                'Hermes Agent instalado, securizado y con backups automáticos',
                'Conexión a Slack o Telegram (a elegir)',
                'Hasta 5 MCPs preconfigurados del catálogo',
                'API key del LLM (OpenRouter o Anthropic) configurada con tu cuenta',
                'Onboarding 1h en videollamada',
                'Documentación PDF personalizada',
              ].map(item => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href="#contacto" class="h-btn h-btn--amber" style="width:100%;justify-content:center;margin-top:auto">
              Reservar ahora
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="h-price-card">
            <div class="h-price-top">
              <div>
                <div class="h-price-label">Mantenimiento</div>
                <div class="h-price-badge h-price-badge--muted">Opcional · sin permanencia</div>
              </div>
              <div class="h-price-amount">
                <span class="h-price-num">59€</span>
                <span class="h-price-period">/mes</span>
              </div>
            </div>
            <ul class="h-price-list">
              {[
                'Actualizaciones de Hermes cuando hay versión nueva',
                'Monitorización 24/7 del VPS con alertas',
                '1 cambio de configuración al mes (añadir MCP, cambiar modelo, etc.)',
                'Soporte por email con respuesta en 48h',
                'Backup semanal automático con retención de 30 días',
              ].map(item => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <p class="h-price-note">Sin permanencia. Cancelas cuando quieras y tu Hermes sigue funcionando.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ MCP CATALOG ═══ -->
    <section class="h-section">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill">Integraciones</div>
          <h2 class="h-h2">MCPs disponibles<br/><em>en tu instalación.</em></h2>
          <p class="h-section-desc">Hasta 5 incluidos en el setup. Elige los que mejor encajen con tu flujo de trabajo.</p>
        </div>
        <div class="h-mcps">
          {mcps.map(mcp => (
            <div class="h-mcp">{mcp}</div>
          ))}
        </div>
        <p class="h-mcps-note">
          ¿Necesitas otro MCP? Lo añadimos por <strong>49€ extra</strong>. Pídelo en el formulario.
        </p>
      </div>
    </section>

    <!-- ═══ USE CASES ═══ -->
    <section class="h-section h-section--cream">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill">Casos de uso</div>
          <h2 class="h-h2">¿Qué le puedo<br/><em>pedir a mi Hermes?</em></h2>
        </div>
        <div class="h-cards-3">
          <div class="h-card h-card--use">
            <div class="h-use-label">Agencias de marketing y SEO</div>
            <p>Pídele a tu Hermes en Slack que extraiga las keywords con peor CTR del último mes en Search Console y te las mande priorizadas. Sin abrir GSC, sin filtros, sin exportar a Excel.</p>
          </div>
          <div class="h-card h-card--use">
            <div class="h-use-label">Founders y consultores</div>
            <p>Reenvíale un email a Hermes y dile "agéndame esto la próxima semana". Lee el contexto, busca hueco en tu Calendar, te propone tres opciones y crea el evento cuando confirmas.</p>
          </div>
          <div class="h-card h-card--use">
            <div class="h-use-label">Equipos pequeños</div>
            <p>Tu equipo le pregunta a Hermes en Slack "¿cuándo vence la factura de Acme?" y él busca en Notion, Stripe o Drive sin que nadie tenga que abrir nada. Un solo punto de entrada para el conocimiento de la empresa.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ WHY ═══ -->
    <section class="h-section h-section--dark">
      <div class="container">
        <div class="h-section-header">
          <div class="h-pill h-pill--light">Diferenciación</div>
          <h2 class="h-h2 h-h2--light">¿Por qué este servicio<br/><em>y no otro?</em></h2>
        </div>
        <div class="h-why-grid">
          {[
            { title: 'Tu agente, tu servidor, tus datos', desc: 'No son nuestros. Tu instalación es privada, en hardware que controlas tú directamente.' },
            { title: 'Pago único + mantenimiento opcional', desc: 'No SaaS con cuota por usuario. Pagas el setup y decides si quieres mantenimiento.' },
            { title: 'Open source (Apache 2.0)', desc: 'Hermes es libre. Si dejas de pagarme, sigue tuyo y funcionando. Para siempre.' },
            { title: '18+ años en infraestructura web', desc: 'No es mi primer rodeo. He montado servidores para sitios con millones de visitas.' },
          ].map(p => (
            <div class="h-why-item">
              <div class="h-why-check">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section class="h-section">
      <div class="container" style="max-width:820px">
        <div class="h-section-header">
          <div class="h-pill">FAQ</div>
          <h2 class="h-h2">Todo lo que nos preguntan<br/><em>antes de empezar.</em></h2>
        </div>
        <div class="h-faq">
          {faqs.map(item => (
            <details class="h-faq-item">
              <summary>
                <span>{item.q}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="h-faq-ans"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTACT FORM ═══ -->
    <section id="contacto" class="h-section h-section--dark">
      <div class="container" style="max-width:700px">
        <div class="h-section-header">
          <div class="h-pill h-pill--light">Contacto</div>
          <h2 class="h-h2 h-h2--light">Reserva tu<br/><em>instalación.</em></h2>
          <p class="h-section-desc" style="color:rgba(250,249,247,0.65)">Cuéntame tu caso. Te respondo en menos de 24h.</p>
        </div>

        <form
          id="hermes-form"
          action="/api/hermes-lead"
          method="POST"
          novalidate
          class="h-form"
        >
          <div class="h-form-row">
            <div class="h-field">
              <label for="nombre">Nombre completo <span aria-hidden="true">*</span></label>
              <input type="text" id="nombre" name="nombre" required autocomplete="name" placeholder="María García" />
              <span class="h-err">Por favor, introduce tu nombre.</span>
            </div>
            <div class="h-field">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="maria@empresa.com" />
              <span class="h-err">Email obligatorio o inválido.</span>
            </div>
          </div>

          <div class="h-field">
            <label for="empresa">Empresa / proyecto <span class="h-opt">(opcional)</span></label>
            <input type="text" id="empresa" name="empresa" autocomplete="organization" placeholder="Agencia SEO Madrid" />
          </div>

          <fieldset class="h-fieldset">
            <legend>Plataforma preferida <span aria-hidden="true">*</span></legend>
            <div class="h-radios">
              <label class="h-radio">
                <input type="radio" name="plataforma" value="Slack" required />
                <span>Slack</span>
              </label>
              <label class="h-radio">
                <input type="radio" name="plataforma" value="Telegram" />
                <span>Telegram</span>
              </label>
            </div>
          </fieldset>

          <fieldset class="h-fieldset">
            <legend>MCPs de interés <span class="h-opt">(selecciona todos los que te interesen)</span></legend>
            <div class="h-checks">
              {mcps.map(mcp => (
                <label class="h-check">
                  <input type="checkbox" name="mcps" value={mcp} />
                  <span>{mcp}</span>
                </label>
              ))}
            </div>
            <input type="text" name="mcps_otros" placeholder="Otros MCPs (separados por coma)" class="h-input-otros" />
          </fieldset>

          <div class="h-field">
            <label for="caso_uso">Cuéntame tu caso de uso principal <span aria-hidden="true">*</span></label>
            <textarea
              id="caso_uso"
              name="caso_uso"
              required
              maxlength="500"
              rows="4"
              placeholder="Ej: Soy consultor SEO y quiero que Hermes me ayude a automatizar reportes de clientes, gestionar mi bandeja de entrada y agendar reuniones desde Slack..."
            ></textarea>
            <div class="h-field-foot">
              <span class="h-err">Cuéntame en qué puedo ayudarte.</span>
              <span class="h-chars">máx. 500 caracteres</span>
            </div>
          </div>

          <div class="h-field">
            <label for="fuente">¿Cómo me has conocido?</label>
            <select id="fuente" name="fuente">
              <option value="">Selecciona una opción</option>
              <option value="Google">Google</option>
              <option value="LinkedIn">LinkedIn</option>
              <option value="Twitter/X">Twitter / X</option>
              <option value="Recomendación">Recomendación</option>
              <option value="Otro">Otro</option>
            </select>
          </div>

          <div class="h-form-submit">
            <button id="hermes-submit" type="submit" class="h-btn h-btn--amber" style="width:100%;justify-content:center;font-size:1.0625rem;padding:1rem 2rem">
              Reservar mi instalación de Hermes
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <p class="h-form-note">Te respondo en menos de 24h. Sin compromiso, sin venta agresiva.</p>
            <div id="hermes-result" class="h-result" hidden></div>
          </div>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Page tokens ── */
  .h-page {
    --h-ink:      #0f0e0c;
    --h-ink-soft: #2a2622;
    --h-mid:      #5a524a;
    --h-mute:     #8a8078;
    --h-paper:    #faf9f7;
    --h-cream:    #f3efe7;
    --h-border:   rgba(15,14,12,0.08);
