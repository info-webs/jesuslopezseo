<script is:inline>
  (function () {
    var form = document.getElementById('hermes-form');
    var btn  = document.getElementById('hermes-submit');
    var res  = document.getElementById('hermes-result');

    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      form.classList.add('validated');

      if (!form.checkValidity()) {
        var first = form.querySelector(':invalid');
        if (first) first.focus();
        // Show inline error spans for required fields
        form.querySelectorAll('[required]').forEach(function(el) {
          var parent = el.closest('.h-field') || el.closest('fieldset');
          if (parent) {
            var errSpan = parent.querySelector('.h-err');
            if (errSpan) errSpan.style.display = el.validity.valid ? 'none' : 'block';
          }
        });
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Enviando…';

      var data = new FormData(form);

      fetch('/api/hermes-lead', { method: 'POST', body: data })
        .then(function (r) { return r.json(); })
        .then(function (json) {
          res.removeAttribute('hidden');
          if (json.ok) {
            res.className = 'h-result ok';
            res.textContent = '¡Recibido! Te contesto en menos de 24h.';
            form.reset();
            form.classList.remove('validated');
          } else {
            res.className = 'h-result err';
            res.textContent = 'Algo fue mal. Escríbeme a jesus@jesuslopezseo.com';
          }
        })
        .catch(function () {
          res.removeAttribute('hidden');
          res.className = 'h-result err';
          res.textContent = 'Error de conexión. Escríbeme a jesus@jesuslopezseo.com';
        })
        .finally(function () {
          btn.disabled = false;
          btn.textContent = 'Reservar mi instalación de Hermes';
          res.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    });
  })();
</script>
