  .h-faq-ans { padding: 0 0 1.5rem; color: var(--h-mid); font-size: 0.9375rem; line-height: 1.7; max-width: 680px; }
  .h-faq-ans p { margin: 0; }

  /* ── Form ── */
  .h-form {
