    background: rgba(255,255,255,0.06); color: var(--amp-paper);
    border-color: rgba(255,255,255,0.18); backdrop-filter: blur(8px);
  }
  .amp-btn--ghost-light:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.35); }
  .amp-btn--outline {
    background: var(--amp-paper); color: var(--amp-ink);
    border-color: var(--amp-border-s);
  }
  .amp-btn--outline:hover { border-color: var(--amp-ink); transform: translateY(-2px); }

  /* ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ */
  .amp-hero {
    position: relative;
    padding: 5rem 0 4rem;
    background:
      radial-gradient(1100px 600px at 90% -10%, rgba(109,76,255,0.10), transparent 60%),
      radial-gradient(900px 600px at -10% 30%, rgba(245,158,11,0.08), transparent 65%),
      var(--amp-paper);
    overflow: hidden;
  }
  .amp-hero-grid {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(var(--amp-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--amp-border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 50% 30%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 10%, transparent 70%);
    opacity: 0.55;
  }
  .amp-hero-glow-a, .amp-hero-glow-b {
    position: absolute; pointer-events: none; z-index: 0;
    border-radius: 50%; filter: blur(60px);
  }
  .amp-hero-glow-a {
    top: -160px; right: -160px; width: 540px; height: 540px;
    background: radial-gradient(circle, rgba(245,158,11,0.18), transparent 60%);
    animation: amp-glow 14s ease-in-out infinite;
  }
  .amp-hero-glow-b {
    bottom: -200px; left: -120px; width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(109,76,255,0.16), transparent 60%);
    animation: amp-glow 16s ease-in-out infinite reverse;
  }
  @keyframes amp-glow {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%      { transform: translate(40px,-30px) scale(1.08); }
  }

  .amp-orbit { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .amp-orb {
    position: absolute; border-radius: 50%;
    background: linear-gradient(135deg, var(--amp-amber), var(--amp-violet));
    box-shadow: 0 16px 40px -10px rgba(109,76,255,0.45);
    opacity: 0.75;
  }
  .amp-orb--1 { top: 14%; left: 6%;   width: 14px; height: 14px; animation: amp-float 7s ease-in-out infinite; }
  .amp-orb--2 { top: 60%; left: 3%;   width: 8px;  height: 8px;  animation: amp-float 9s ease-in-out 1s infinite; opacity: 0.6; }
  .amp-orb--3 { top: 30%; right: 10%; width: 10px; height: 10px; animation: amp-float 11s ease-in-out 0.5s infinite; opacity: 0.7; }
  @keyframes amp-float {
    0%, 100% { transform: translate(0,0); }
    50%      { transform: translate(0,-22px); }
  }

  .amp-hero-inner {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    gap: 4rem; align-items: center;
    padding-top: 1rem; padding-bottom: 3.5rem;
  }
  .amp-hero-copy { max-width: 640px; animation: amp-fade-up 700ms ease-out both; }

  .amp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.4rem 0.9rem; border-radius: 999px;
    border: 1px solid var(--amp-border-s);
    background: rgba(255,255,255,0.7); backdrop-filter: blur(8px);
    font-family: var(--amp-mono); font-size: 0.7rem;
    color: var(--amp-ink-soft);
    letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .amp-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: var(--amp-amber);
    box-shadow: 0 0 0 3px rgba(245,158,11,0.22);
    animation: amp-pulse 2s ease-in-out infinite;
  }
  @keyframes amp-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(245,158,11,0.22); }
    50%      { box-shadow: 0 0 0 7px rgba(245,158,11,0); }
  }

  .amp-hero-title {
    font-family: var(--amp-serif);
    font-size: clamp(2.45rem, 5.2vw, 4.3rem);
    font-weight: 400; line-height: 1.02; letter-spacing: -0.025em;
    margin: 0 0 1.4rem; color: var(--amp-ink);
  }
  .amp-hero-title em {
    font-style: italic;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .amp-hero-desc {
    font-size: 1.0625rem; color: var(--amp-mid);
    line-height: 1.65; margin: 0 0 2rem; max-width: 580px;
  }
  .amp-hero-desc strong { color: var(--amp-ink); font-weight: 600; }

  .amp-hero-actions {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .amp-hero-free {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.85rem; margin-bottom: 1.5rem;
    border: 1px dashed var(--amp-border-s);
    border-radius: 999px;
    font-size: 0.8125rem; color: var(--amp-mid);
    text-decoration: none;
    transition: all 200ms cubic-bezier(0.16,1,0.3,1);
    background: rgba(255,255,255,0.4);
  }
  .amp-hero-free:hover {
    border-color: var(--amp-amber);
    color: var(--amp-amber-d);
    background: rgba(245,158,11,0.06);
    transform: translateY(-1px);
  }
  .amp-hero-free strong { color: var(--amp-ink); font-weight: 600; }
  .amp-hero-free:hover strong { color: var(--amp-amber-d); }
  .amp-hero-free svg:first-child { color: var(--amp-amber-d); flex-shrink: 0; }
  .amp-hero-free svg:last-child  { opacity: 0.6; flex-shrink: 0; }

  .amp-hero-badges {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 2.25rem;
  }
  .amp-hero-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    background: rgba(255,255,255,0.65);
    border: 1px solid var(--amp-border-s);
    border-radius: 999px;
    font-family: var(--amp-mono);
    font-size: 0.7rem; color: var(--amp-ink-soft);
    letter-spacing: 0.02em;
    backdrop-filter: blur(6px);
  }
  .amp-hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--amp-amber);
  }
  .amp-hero-badge-dot--mint   { background: var(--amp-mint); }
  .amp-hero-badge-dot--violet { background: var(--amp-violet); }
  .amp-hero-badge-dot--blue   { background: var(--amp-blue); }

  .amp-hero-meta {
    display: flex; gap: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--amp-border-s);
  }
  .amp-stat-num {
    font-family: var(--amp-serif); font-size: 1.85rem;
    line-height: 1; letter-spacing: -0.02em; color: var(--amp-ink);
  }
  .amp-stat-cap { font-size: 0.78rem; color: var(--amp-mute); margin-top: 4px; }

  /* ── Hero mockup ── */
  .amp-hero-aside {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    min-height: 480px;
    animation: amp-fade-up 800ms ease-out 80ms both;
  }
  @keyframes amp-fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .amp-mock {
    width: 100%; max-width: 460px;
    background: var(--amp-card);
    border: 1px solid var(--amp-border-s);
    border-radius: 18px; overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.7) inset,
      0 30px 70px -20px rgba(15,15,30,0.30),
      0 12px 30px -10px rgba(109,76,255,0.18);
    transform: rotate(-1deg);
    transition: transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-mock:hover { transform: rotate(-0.2deg) translateY(-4px); }

  .amp-mock-bar {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    background: linear-gradient(180deg, #f5f3ee, #ece8de);
    border-bottom: 1px solid var(--amp-border);
  }
  .amp-mock-dot { width: 11px; height: 11px; border-radius: 50%; }
  .amp-mock-dot--r { background: #fb6566; }
  .amp-mock-dot--y { background: #fdc04c; }
  .amp-mock-dot--g { background: #4cd685; }
  .amp-mock-tab {
    margin-left: 0.5rem; padding: 0.2rem 0.65rem;
    background: var(--amp-card); border: 1px solid var(--amp-border);
    border-radius: 6px; font-family: var(--amp-mono);
    font-size: 0.7rem; color: var(--amp-mute);
  }

  .amp-mock-body { padding: 1.25rem; }

  .amp-mock-head {
    display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.1rem;
  }
  .amp-mock-thumb {
    width: 44px; height: 44px; border-radius: 10px;
    background: linear-gradient(135deg, #fef3c7, #ddd6fe);
    color: var(--amp-ink-soft);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .amp-mock-thumb svg { width: 22px; height: 22px; }
  .amp-mock-prod { font-weight: 600; font-size: 0.95rem; color: var(--amp-ink); }
  .amp-mock-sku  { font-family: var(--amp-mono); font-size: 0.7rem; color: var(--amp-mute); margin-top: 2px; }
  .amp-mock-pill {
    margin-left: auto;
    background: rgba(16,185,129,0.12); color: var(--amp-mint);
    font-size: 0.65rem; font-weight: 600; text-transform: uppercase;
    padding: 0.2rem 0.55rem; border-radius: 6px; letter-spacing: 0.05em;
    display: inline-flex; align-items: center; gap: 0.35rem;
  }
  .amp-mock-pill--live::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--amp-mint);
    box-shadow: 0 0 0 2px rgba(16,185,129,0.25);
    animation: amp-pulse-mint 1.6s ease-in-out infinite;
  }
  @keyframes amp-pulse-mint {
    0%, 100% { box-shadow: 0 0 0 2px rgba(16,185,129,0.25); }
    50%      { box-shadow: 0 0 0 5px rgba(16,185,129,0); }
  }

  .amp-mock-feeds {
    display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem;
  }
  .amp-mock-feed {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.7rem 0.85rem;
    background: linear-gradient(180deg, rgba(245,158,11,0.04), rgba(245,158,11,0));
    border: 1px solid var(--amp-border);
    border-radius: 11px;
  }
  .amp-mock-feed-icon {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .amp-mock-feed-icon svg { width: 16px; height: 16px; color: #fff; }
  .amp-mock-feed-icon--mint   { background: var(--amp-mint); }
  .amp-mock-feed-icon--amber  { background: var(--amp-amber); }
  .amp-mock-feed-icon--violet { background: var(--amp-violet); }
  .amp-mock-feed-body { flex: 1; min-width: 0; }
  .amp-mock-feed-name {
    font-size: 0.82rem; font-weight: 600; color: var(--amp-ink);
    line-height: 1.1;
  }
  .amp-mock-feed-tag {
    font-family: var(--amp-mono); font-size: 0.66rem;
    color: var(--amp-mute); margin-top: 3px;
  }
  .amp-mock-feed-status {
    font-family: var(--amp-mono); font-size: 0.78rem;
    font-weight: 600; color: var(--amp-ink);
    padding: 0.2rem 0.55rem; border-radius: 6px;
    background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.25);
  }
  .amp-mock-feed-status--ok { color: var(--amp-mint); }

  .amp-mock-foot {
    margin-top: 0.5rem; padding-top: 0.85rem;
    border-top: 1px solid var(--amp-border);
    display: flex; align-items: center; gap: 0.85rem;
  }
  .amp-progress {
    flex: 1; height: 6px; background: rgba(15,15,30,0.06);
    border-radius: 99px; overflow: hidden;
  }
  .amp-progress-bar {
    display: block; height: 100%; width: 0;
    background: linear-gradient(90deg, var(--amp-amber), var(--amp-violet));
    border-radius: 99px;
    animation: amp-fill 4s cubic-bezier(0.4,0,0.2,1) 200ms infinite;
  }
  @keyframes amp-fill {
    0%   { width: 0;   transform: translateX(0); }
    70%  { width: 92%; }
    100% { width: 100%; opacity: 0.4; }
  }
  .amp-mock-status {
    font-family: var(--amp-mono); font-size: 0.7rem;
    color: var(--amp-mute); white-space: nowrap;
  }

  /* Floating badges */
  .amp-mock-badge {
    position: absolute; display: flex; align-items: center; gap: 0.7rem;
    padding: 0.7rem 0.95rem; border-radius: 14px;
    background: var(--amp-ink); color: var(--amp-paper);
    box-shadow: 0 16px 36px -8px rgba(15,15,30,0.35);
    z-index: 3;
  }
  .amp-mock-badge--top {
    top: -16px; left: -22px;
    animation: amp-float 4s ease-in-out infinite;
  }
  .amp-mock-badge--top svg {
    width: 20px; height: 20px;
    padding: 6px; border-radius: 8px;
    background: var(--amp-mint); color: #fff; box-sizing: content-box;
  }
  .amp-mock-badge--bot {
    bottom: -16px; right: -18px;
    animation: amp-float 5.5s ease-in-out 0.5s infinite;
  }
  .amp-badge-icon {
    font-family: var(--amp-mono); font-weight: 700;
    background: linear-gradient(135deg, var(--amp-amber), var(--amp-violet));
    color: var(--amp-ink);
    width: 38px; height: 38px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; letter-spacing: 0.04em;
  }
  .amp-badge-num {
    font-family: var(--amp-serif);
    font-size: 1.05rem; line-height: 1; letter-spacing: -0.02em;
  }
  .amp-badge-cap {
    font-size: 0.66rem; color: rgba(251,250,246,0.65);
    margin-top: 3px; letter-spacing: 0.02em;
  }

  /* Trust strip */
  .amp-trust {
    position: relative; z-index: 2;
    margin-top: 1rem; padding: 1.5rem 0 0.5rem;
    border-top: 1px solid var(--amp-border);
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .amp-trust-label {
    font-family: var(--amp-mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--amp-mute);
  }
  .amp-trust-grid {
    display: flex; flex-wrap: wrap; gap: 0.5rem 2.5rem;
    justify-content: center;
  }
  .amp-trust-item {
    font-size: 0.85rem; font-weight: 500; color: var(--amp-ink-soft);
    opacity: 0.85;
  }

  /* ═══════════════════════════════════════════════════════════
     COMPARE
     ═══════════════════════════════════════════════════════════ */
  .amp-compare {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 1.25rem; align-items: stretch; max-width: 1080px; margin: 0 auto;
  }
  .amp-compare-card {
    border-radius: 16px; padding: 1.75rem;
    border: 1px solid var(--amp-border-s);
  }
  .amp-compare-card--before { background: rgba(239,68,68,0.04); border-color: rgba(239,68,68,0.18); }
  .amp-compare-card--after  {
    background: linear-gradient(160deg, rgba(245,158,11,0.10), rgba(109,76,255,0.08));
    border-color: rgba(245,158,11,0.28);
  }
  .amp-compare-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }
  .amp-compare-tag {
    font-family: var(--amp-mono);
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.25rem 0.6rem;
    border-radius: 6px;
  }
  .amp-compare-tag--bad  { background: rgba(239,68,68,0.16);  color: #b91c1c; }
  .amp-compare-tag--good { background: rgba(245,158,11,0.20); color: var(--amp-amber-d); }
  .amp-compare-meta { font-family: var(--amp-mono); font-size: 0.72rem; color: var(--amp-mute); }
  .amp-compare-prod {
    font-family: var(--amp-serif); font-size: 1.5rem;
    font-weight: 400; color: var(--amp-ink); margin-bottom: 0.7rem;
    line-height: 1.2;
  }
  .amp-compare-text {
    font-size: 0.9375rem; line-height: 1.65;
    color: var(--amp-mid); margin: 0 0 1.1rem;
  }
  .amp-compare-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
    border-top: 1px solid var(--amp-border); padding-top: 1rem;
  }
  .amp-compare-list li {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: 0.875rem; color: var(--amp-ink-soft);
  }
  .amp-compare-list li span {
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700;
    flex-shrink: 0;
  }
  .amp-compare-list--bad  li span { background: rgba(239,68,68,0.14); color: #b91c1c; }
  .amp-compare-list--good li span { background: rgba(16,185,129,0.16); color: var(--amp-mint); }
  .amp-compare-arrow {
    display: flex; align-items: center; justify-content: center;
    color: var(--amp-amber);
    background: rgba(245,158,11,0.10);
    border-radius: 50%; width: 56px; height: 56px;
    align-self: center; margin: 0 auto;
    box-shadow: 0 0 0 8px rgba(245,158,11,0.06);
  }
  .amp-compare-arrow svg { width: 24px; height: 24px; }

  /* ═══════════════════════════════════════════════════════════
     BIG STATS (SEO → LLMO)
     ═══════════════════════════════════════════════════════════ */
  .amp-bigstats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem;
  }
  .amp-bigstat {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 16px; padding: 1.75rem;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-bigstat:hover {
    border-color: var(--amp-amber);
    transform: translateY(-4px);
    box-shadow: 0 22px 50px -16px rgba(15,15,30,0.18);
  }
  .amp-bigstat-num {
    font-family: var(--amp-serif);
    font-size: 3rem; line-height: 1; letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .amp-bigstat p {
    font-size: 0.9375rem; color: var(--amp-mid);
    line-height: 1.55; margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     FEED CARDS
     ═══════════════════════════════════════════════════════════ */
  .amp-feeds {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .amp-feed-card {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 18px; padding: 2rem;
    display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-feed-card:hover {
    border-color: var(--amp-ink);
    transform: translateY(-4px);
    box-shadow: 0 22px 50px -16px rgba(15,15,30,0.18);
  }
  .amp-feed-card-icon {
    width: 52px; height: 52px; border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .amp-feed-card-icon svg { width: 26px; height: 26px; color: #fff; }
  .amp-feed-card-icon--mint   { background: linear-gradient(135deg, var(--amp-mint), var(--amp-green)); }
  .amp-feed-card-icon--amber  { background: linear-gradient(135deg, var(--amp-amber), var(--amp-amber-d)); }
  .amp-feed-card-icon--violet { background: linear-gradient(135deg, var(--amp-violet), var(--amp-violet-d)); }

  .amp-feed-card-code {
    position: absolute; top: 1.5rem; right: 1.5rem;
    font-family: var(--amp-mono); font-size: 0.68rem;
    font-weight: 700; letter-spacing: 0.06em;
    background: rgba(15,15,30,0.06); color: var(--amp-ink-soft);
    padding: 0.25rem 0.55rem; border-radius: 6px;
  }
  .amp-feed-card h3 {
    font-family: var(--amp-serif); font-size: 1.5rem; font-weight: 400;
    line-height: 1.2; margin: 0 0 0.5rem; color: var(--amp-ink);
  }
  .amp-feed-card-target {
    display: flex; flex-direction: column; gap: 0.1rem;
    margin-bottom: 1rem;
  }
  .amp-feed-card-target > span:first-child {
    font-weight: 600; font-size: 0.95rem; color: var(--amp-amber-d);
  }
  .amp-feed-card-audience {
    font-family: var(--amp-mono); font-size: 0.75rem;
    color: var(--amp-mute);
  }
  .amp-feed-card p {
    font-size: 0.9375rem; color: var(--amp-mid);
    line-height: 1.6; margin: 0 0 1.25rem;
  }
  .amp-feed-card-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.55rem;
    padding-top: 1rem; border-top: 1px solid var(--amp-border);
    margin-top: auto;
  }
  .amp-feed-card-list li {
    display: flex; gap: 0.55rem; align-items: flex-start;
