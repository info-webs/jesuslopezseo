    --amp-violet:   #6d4cff;
    --amp-violet-d: #4f33cc;
    --amp-pink:     #ff5d8f;
    --amp-mint:     #10b981;
    --amp-blue:     #3b82f6;
    --amp-cyan:     #06b6d4;
