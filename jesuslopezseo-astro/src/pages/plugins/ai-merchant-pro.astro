---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const canonical = 'https://www.jesuslopezseo.com/plugins/ai-merchant-pro/';
const pageTitle = 'AI Merchant Pro — Plugin WordPress y módulo PrestaShop con IA | Jesús López';
const pageDescription = 'Genera fichas de producto, SEO, traducciones y categorías con IA en WooCommerce y PrestaShop. Ahorra cientos de horas y multiplica tu catálogo. Compatible con OpenAI, Claude y Gemini. Prueba gratis.';

const platforms = [
  {
    key: 'wp',
    name: 'WordPress + WooCommerce',
    sub: 'Plugin oficial · WP 6.0+ · WooCommerce 7+',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M2.5 12h19M12 2.5c2.7 3 4.2 6.2 4.2 9.5s-1.5 6.5-4.2 9.5C9.3 18.5 7.8 15.3 7.8 12s1.5-6.5 4.2-9.5z"/></svg>`,
  },
  {
    key: 'ps',
    name: 'PrestaShop',
    sub: 'Módulo oficial · PrestaShop 1.7+ y 8.x',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 12l9 4 9-4"/><path d="M3 17l9 4 9-4"/></svg>`,
  },
];

const features = [
  {
    iconColor: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>`,
    title: 'Fichas de producto en segundos',
    desc: 'Genera descripciones únicas, persuasivas y orientadas a conversión a partir del nombre, atributos o una simple imagen. Reescribe miles de fichas en lote con un clic.',
  },
  {
    iconColor: 'blue',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 7v4l2.5 2.5"/></svg>`,
    title: 'SEO on-page automatizado',
    desc: 'Title tags, meta descriptions, H1 y datos estructurados Product/Offer optimizados para tus keywords objetivo. Sin canibalizar, sin duplicados, listo para Google.',
  },
  {
    iconColor: 'green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M5 8h14M5 12h14M5 16h9"/><path d="M3 4h18v16H3z"/></svg>`,
    title: 'Traducciones nativas multi-idioma',
    desc: 'Traduce todo tu catálogo a 40+ idiomas conservando tono, terminología técnica y SEO. Compatible con WPML, Polylang y la multi-tienda nativa de PrestaShop.',
  },
  {
    iconColor: 'pink',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: 'Categorización inteligente',
    desc: 'Asigna categorías, subcategorías, etiquetas y atributos analizando el producto. Limpia jerarquías heredadas y elimina duplicados sin romper tu navegación.',
  },
  {
    iconColor: 'violet',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.5-3.5a2 2 0 0 0-2.8 0L4 22"/></svg>`,
    title: 'ALT-text y reescritura de imágenes',
    desc: 'Genera ALT descriptivo para cada imagen, optimiza el peso, renombra ficheros con slug-keyword y mejora la accesibilidad WCAG. Mejora tu SEO de imágenes en automático.',
  },
  {
    iconColor: 'cyan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>`,
    title: 'Asistente de soporte en tu tienda',
    desc: 'Chatbot embebido entrenado con tu catálogo y tus FAQs. Responde dudas de talla, envío o disponibilidad y deriva al humano cuando hace falta. 24/7.',
  },
  {
    iconColor: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 20V10M18 20V4M6 20v-6"/></svg>`,
    title: 'Insights y oportunidades',
    desc: 'La IA detecta productos con baja conversión, fichas pobres, categorías vacías y oportunidades de cross-selling. Te entrega un plan accionable cada semana.',
  },
  {
    iconColor: 'red',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>`,
    title: 'Procesamiento masivo en lote',
    desc: 'Procesa 10.000 productos sin bloquear tu tienda. Cola en segundo plano, control de tokens, reintentos automáticos y exportación CSV antes de aplicar cambios.',
  },
  {
    iconColor: 'green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Privacidad y control total',
    desc: 'Tu API key, tu modelo, tus datos. Sin enviar tu catálogo a terceros, sin scraping, sin telemetría oculta. RGPD-friendly y registro de todas las acciones.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Instala el plugin o módulo',
    desc: 'Sube el ZIP a WordPress o PrestaShop, activa con tu licencia y conecta tu API key de OpenAI, Anthropic o Google. Listo en 3 minutos.',
  },
  {
    num: '02',
    title: 'Elige qué quieres mejorar',
    desc: 'Selecciona productos por categoría, marca, stock o filtro custom. Define tono de voz, idiomas, estructura SEO y plantillas reutilizables.',
  },
  {
    num: '03',
    title: 'Revisa y publica con un clic',
    desc: 'Previsualiza los cambios en una pantalla diff, edita lo que quieras y publica. Todo queda versionado: vuelves al original cuando quieras.',
  },
];

const integrations = [
  'OpenAI',
  'Anthropic Claude',
  'Google Gemini',
  'Mistral',
  'WooCommerce',
  'PrestaShop',
  'WPML',
  'Polylang',
  'Yoast SEO',
  'Rank Math',
  'Google Merchant',
  'Meta Catalog',
];

const useCases = [
  {
    label: 'Tiendas de moda',
    title: 'Catálogos masivos sin pereza',
    desc: '5.000 referencias con ficha vacía heredadas del proveedor. AI Merchant Pro las reescribe respetando tu tono de marca y genera variantes SEO por talla y color en menos de una tarde.',
  },
  {
    label: 'Marketplaces y dropshippers',
    title: 'Diferenciación frente al feed',
    desc: 'Si vendes lo mismo que otros 200 vendedores, copiar la descripción del proveedor te hunde en Google. Genera fichas únicas y optimizadas en cada importación automática.',
  },
  {
    label: 'Tiendas multi-idioma',
    title: 'Traducir 40 idiomas sin agencia',
    desc: 'Localización profesional con terminología y fichas adaptadas a cada mercado. Olvídate de presupuestos de traducción y plazos de 6 semanas por cada nueva campaña.',
  },
];

const plans = [
  {
    name: 'Starter',
    badge: 'Para tiendas pequeñas',
    price: '49€',
    period: '/año',
    cta: 'Empezar con Starter',
    featured: false,
    items: [
      '1 dominio · WordPress o PrestaShop',
      'Hasta 500 productos procesados/mes',
      'SEO on-page + traducciones (5 idiomas)',
      'Modelos OpenAI / Claude / Gemini',
      'Soporte por email · 48h',
      'Actualizaciones durante 1 año',
    ],
  },
  {
    name: 'Pro',
    badge: 'El más vendido',
    price: '129€',
    period: '/año',
    cta: 'Probar Pro 14 días gratis',
    featured: true,
    items: [
      '3 dominios · WP + PrestaShop',
      'Hasta 10.000 productos/mes',
      'Idiomas ilimitados + WPML/Polylang',
      'Asistente de soporte embebido',
      'Insights semanales accionables',
      'Soporte prioritario · 12h',
      'Actualizaciones de por vida',
    ],
  },
  {
    name: 'Agency',
    badge: 'Para agencias y marketplaces',
    price: '349€',
    period: '/año',
    cta: 'Hablar con ventas',
    featured: false,
    items: [
      'Hasta 25 dominios cliente',
      'Productos ilimitados · API directa',
      'White-label opcional (logo y dominio)',
      'Workflows automatizados (n8n / Make)',
      'Gestor de cuenta dedicado',
      'SLA 4h · onboarding 1:1',
    ],
  },
];

const faqs = [
  {
    q: '¿Necesito saber programar para usarlo?',
    a: 'No. AI Merchant Pro es plug-and-play: subes el ZIP, activas la licencia y trabajas desde un panel visual integrado en tu admin de WordPress o PrestaShop. Si sabes editar un producto, sabes usarlo.',
  },
  {
    q: '¿Quién paga el coste de los modelos de IA?',
    a: 'Tú, con tu propia API key (OpenAI, Anthropic o Google). Esto te da control total: usas el modelo que prefieras, ves el coste exacto y no hay margen oculto. Para una tienda media, el coste suele ser de 5-20€/mes en tokens.',
  },
  {
    q: '¿Funciona con mi versión de WooCommerce o PrestaShop?',
    a: 'Sí: WordPress 6.0+ con WooCommerce 7+, y PrestaShop 1.7.6+ y toda la rama 8.x. Si tienes una versión más antigua, te ayudamos a actualizar antes de instalar.',
  },
  {
    q: '¿Puede romper mi tienda en producción?',
    a: 'No. Todo cambio se previsualiza primero en una pantalla diff, queda versionado y se puede revertir con un clic. Para procesos masivos exportamos un CSV antes para que revises offline si lo necesitas.',
  },
  {
    q: '¿Es compatible con Yoast, Rank Math o el SEO nativo de PrestaShop?',
    a: 'Totalmente. Detectamos el plugin SEO instalado y rellenamos los campos correctos (focus keyword, meta description, schema). En PrestaShop usamos los campos nativos de meta título, meta descripción y URL amigable.',
  },
  {
    q: '¿Mis datos viajan a OpenAI/Anthropic/Google?',
    a: 'Solo el contenido estrictamente necesario para generar la respuesta (nombre, atributos, descripción origen). Nunca enviamos clientes, pedidos ni precios sensibles. Tienes una whitelist clara y un log de todo lo enviado.',
  },
  {
    q: '¿Puedo reescribir todo mi catálogo de golpe?',
    a: 'Sí. El motor de procesamiento masivo soporta hasta 10.000 productos por job en Pro y catálogo ilimitado en Agency. Funciona en cola en segundo plano, así que tu tienda no se ralentiza durante el proceso.',
  },
  {
    q: '¿Qué pasa cuando se acaba la licencia anual?',
    a: 'El plugin sigue funcionando con la última versión. Solo dejas de recibir actualizaciones y soporte. Puedes renovar con un 30% de descuento durante los 30 días posteriores al vencimiento.',
  },
  {
    q: '¿Tenéis política de devolución?',
    a: 'Sí. 14 días de garantía de devolución sin preguntas. Si en dos semanas no notas un antes y un después en tu catálogo, te devolvemos el dinero íntegro.',
  },
];

const schemaProduct = {
  '@type': 'SoftwareApplication',
  name: 'AI Merchant Pro',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'WordPress, WooCommerce, PrestaShop',
  description: pageDescription,
  url: 'https://aimerchantpro.com',
  offers: [
    { '@type': 'Offer', name: 'Starter',  price: '49',  priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Pro',      price: '129', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Agency',   price: '349', priceCurrency: 'EUR' },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127',
  },
};

const schemaFaq = {
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schemaBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',   item: 'https://www.jesuslopezseo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Plugins',  item: 'https://www.jesuslopezseo.com/plugins/' },
    { '@type': 'ListItem', position: 3, name: 'AI Merchant Pro', item: canonical },
  ],
};

const schema = JSON.stringify({ '@context': 'https://schema.org', '@graph': [schemaProduct, schemaFaq, schemaBreadcrumb] });
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={schema}
>
  <Header />

  <main class="amp-page">

    <!-- ═══════════════════════════════════════════════════════
         HERO — premium · NO above-the-fold (sigue scrolleando)
         ═══════════════════════════════════════════════════════ -->
    <section class="amp-hero">
      <div class="amp-hero-grid"   aria-hidden="true"></div>
      <div class="amp-hero-glow-a" aria-hidden="true"></div>
      <div class="amp-hero-glow-b" aria-hidden="true"></div>
      <div class="amp-orbit"       aria-hidden="true">
        <span class="amp-orb amp-orb--1"></span>
        <span class="amp-orb amp-orb--2"></span>
        <span class="amp-orb amp-orb--3"></span>
      </div>

      <div class="container amp-hero-inner">
        <div class="amp-hero-copy">
          <div class="amp-eyebrow">
            <span class="amp-dot"></span>
            AI Merchant Pro · v3.4 disponible
          </div>

          <h1 class="amp-hero-title">
            La IA que escribe<br/>
            <em>tu catálogo entero</em><br/>
            mientras tú duermes.
          </h1>

          <p class="amp-hero-desc">
            Plugin para <strong>WordPress / WooCommerce</strong> y módulo para
            <strong>PrestaShop</strong> que genera fichas de producto, SEO,
            traducciones y categorías con IA generativa. Multiplica tu catálogo
            sin contratar redactores y sin que tus posiciones se desplomen.
          </p>

          <div class="amp-hero-actions">
            <a href="#planes" class="amp-btn amp-btn--primary">
              Probar 14 días gratis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#demo" class="amp-btn amp-btn--ghost">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
              Ver demo en vivo
            </a>
          </div>

          <div class="amp-hero-meta">
            <div class="amp-stat">
              <div class="amp-stat-num">12k+</div>
              <div class="amp-stat-cap">tiendas usándolo</div>
            </div>
            <div class="amp-stat">
              <div class="amp-stat-num">4.9 ★</div>
              <div class="amp-stat-cap">127 reviews</div>
            </div>
            <div class="amp-stat">
              <div class="amp-stat-num">3 min</div>
              <div class="amp-stat-cap">para empezar</div>
            </div>
          </div>
        </div>

        <!-- Visual mockup: panel admin generando ficha en vivo -->
        <div class="amp-hero-aside" aria-hidden="true">
          <div class="amp-mock">
            <div class="amp-mock-bar">
              <span class="amp-mock-dot amp-mock-dot--r"></span>
              <span class="amp-mock-dot amp-mock-dot--y"></span>
              <span class="amp-mock-dot amp-mock-dot--g"></span>
              <span class="amp-mock-tab">/wp-admin/post.php?post=2847</span>
            </div>

            <div class="amp-mock-body">
              <div class="amp-mock-head">
                <div class="amp-mock-thumb">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-3.5-3.5a2 2 0 0 0-2.8 0L4 22"/></svg>
                </div>
                <div>
                  <div class="amp-mock-prod">Botines Chelsea piel napa</div>
                  <div class="amp-mock-sku">SKU FW-CH-2847 · Sin descripción</div>
                </div>
                <span class="amp-mock-pill">draft</span>
              </div>

              <div class="amp-mock-section">
                <div class="amp-mock-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                  Generando descripción con IA
                </div>
                <div class="amp-typewriter">
                  Botines Chelsea de piel napa premium con elásticos laterales
                  cosidos y suela de caucho antideslizante. Diseño atemporal
                  hecho en España, listos para combinar con vaquero o traje.
                  <span class="amp-caret"></span>
                </div>
              </div>

              <div class="amp-mock-meta">
                <div class="amp-mock-meta-row">
                  <span class="amp-mock-key">Title SEO</span>
                  <span class="amp-mock-val">Botines Chelsea piel napa hechos en España | Marca</span>
                </div>
                <div class="amp-mock-meta-row">
                  <span class="amp-mock-key">Meta description</span>
                  <span class="amp-mock-val">Chelsea de napa con suela de caucho. Hechos en España, envío 24h y devolución gratis…</span>
                </div>
                <div class="amp-mock-meta-row">
                  <span class="amp-mock-key">ALT imagen</span>
                  <span class="amp-mock-val">Botín Chelsea negro de piel napa con elástico lateral</span>
                </div>
                <div class="amp-mock-meta-row">
                  <span class="amp-mock-key">Categorías</span>
                  <span class="amp-mock-val">
                    <span class="amp-tag">Hombre</span>
                    <span class="amp-tag">Botines</span>
                    <span class="amp-tag">Piel</span>
                  </span>
                </div>
              </div>

              <div class="amp-mock-foot">
                <div class="amp-progress">
                  <span class="amp-progress-bar"></span>
                </div>
                <span class="amp-mock-status">Generando 3 idiomas · 2 de 12 fichas</span>
              </div>
            </div>
          </div>

          <div class="amp-mock-badge amp-mock-badge--top">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <div>
              <div class="amp-badge-num">12 fichas</div>
              <div class="amp-badge-cap">en 38 segundos</div>
            </div>
          </div>

          <div class="amp-mock-badge amp-mock-badge--bot">
            <span class="amp-badge-icon">SEO</span>
            <div>
              <div class="amp-badge-num">+187%</div>
              <div class="amp-badge-cap">tráfico orgánico</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Trust strip dentro del hero (ayuda a romper la fold) -->
      <div class="container">
        <div class="amp-trust">
          <span class="amp-trust-label">Compatible con</span>
          <div class="amp-trust-grid">
            <div class="amp-trust-item">WordPress · WooCommerce</div>
            <div class="amp-trust-item">PrestaShop 1.7 / 8.x</div>
            <div class="amp-trust-item">OpenAI · Claude · Gemini</div>
            <div class="amp-trust-item">WPML · Polylang</div>
            <div class="amp-trust-item">Yoast · Rank Math</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ BENEFITS / VALUE PROP ═══ -->
    <section class="amp-section">
      <div class="container">
        <div class="amp-section-header">
          <div class="amp-pill">El cambio</div>
          <h2 class="amp-h2">Tu equipo deja de copiar fichas<br/><em>y empieza a vender.</em></h2>
          <p class="amp-section-desc">
            Tres horas escribiendo una ficha que va a leer un crawler. Multiplícalo por 5.000 productos.
            Nadie en tu negocio merece eso. La IA no viene a reemplazar a tu equipo: viene a quitarles el trabajo plano.
          </p>
        </div>

        <div class="amp-bigstats">
          <div class="amp-bigstat">
            <div class="amp-bigstat-num">94%</div>
            <p>menos tiempo para publicar un nuevo producto en tu catálogo principal y secundarios.</p>
          </div>
          <div class="amp-bigstat">
            <div class="amp-bigstat-num">187%</div>
            <p>de incremento medio en tráfico orgánico en los primeros 90 días tras reescribir el catálogo.</p>
          </div>
          <div class="amp-bigstat">
            <div class="amp-bigstat-num">40+</div>
            <p>idiomas listos sin traductores externos: lanzas mercado nuevo en una tarde, no en seis semanas.</p>
          </div>
          <div class="amp-bigstat">
            <div class="amp-bigstat-num">3 min</div>
            <p>desde que descargas el ZIP hasta que generas tu primera ficha. Sin developer, sin agencia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PLATFORMS ═══ -->
    <section class="amp-section amp-section--cream">
      <div class="container">
        <div class="amp-section-header">
          <div class="amp-pill">Plataformas</div>
          <h2 class="amp-h2">Un único producto.<br/><em>Dos motores nativos.</em></h2>
        </div>
        <div class="amp-platforms">
          {platforms.map(p => (
            <div class={`amp-platform amp-platform--${p.key}`}>
              <div class="amp-platform-icon" set:html={p.icon} />
              <div>
                <h3>{p.name}</h3>
                <p>{p.sub}</p>
              </div>
              <div class="amp-platform-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          ))}
        </div>
        <p class="amp-platforms-note">Una licencia te incluye los dos. Sin sobrecoste por plataforma.</p>
      </div>
    </section>

    <!-- ═══ FEATURES GRID ═══ -->
    <section id="features" class="amp-section">
      <div class="container">
        <div class="amp-section-header">
          <div class="amp-pill">Funcionalidades</div>
          <h2 class="amp-h2">Todo lo que tu tienda necesita,<br/><em>sin diez plugins encadenados.</em></h2>
          <p class="amp-section-desc">Un solo plugin sustituye al generador de descripciones, al traductor, al optimizador SEO, al gestor de imágenes y al chatbot. Menos plugins = más velocidad, menos conflictos, menos coste.</p>
        </div>

