    width: 44px; height: 44px; border-radius: 10px;
    background: linear-gradient(135deg, #fef3c7, #ddd6fe);
    color: var(--amp-ink-soft);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .amp-mock-thumb svg { width: 22px; height: 22px; }
  .amp-mock-prod { font-weight: 600; font-size: 0.95rem; color: var(--amp-ink); }
  .amp-mock-sku  { font-family: var(--amp-mono); font-size: 0.7rem; color: var(--amp-mute); margin-top: 2px; }
  .amp-mock-pill {
    margin-left: auto;
    background: rgba(239,68,68,0.10); color: var(--amp-red);
    font-size: 0.65rem; font-weight: 600; text-transform: uppercase;
    padding: 0.2rem 0.55rem; border-radius: 6px; letter-spacing: 0.05em;
  }

  .amp-mock-section {
    background: linear-gradient(180deg, rgba(245,158,11,0.06), rgba(245,158,11,0.02));
    border: 1px solid rgba(245,158,11,0.20);
    border-radius: 12px; padding: 0.9rem 1rem; margin-bottom: 1rem;
  }
  .amp-mock-label {
    display: flex; align-items: center; gap: 0.4rem;
    font-family: var(--amp-mono); font-size: 0.68rem;
    color: var(--amp-amber-d); text-transform: uppercase;
    letter-spacing: 0.06em; margin-bottom: 0.55rem;
  }
  .amp-mock-label svg { width: 13px; height: 13px; animation: amp-spin 3s linear infinite; }
  @keyframes amp-spin { to { transform: rotate(360deg); } }

  .amp-typewriter {
    font-size: 0.85rem; line-height: 1.55; color: var(--amp-ink-soft);
    overflow: hidden; white-space: normal;
    animation: amp-type 4s steps(60, end) 400ms both;
  }
  @keyframes amp-type {
    from { max-height: 0; }
    to   { max-height: 200px; }
  }
  .amp-caret {
    display: inline-block; width: 7px; height: 1em;
    margin-left: 2px; vertical-align: -3px;
    background: var(--amp-amber);
    animation: amp-blink 1s step-end infinite;
  }
  @keyframes amp-blink { 50% { opacity: 0; } }

  .amp-mock-meta {
    display: flex; flex-direction: column; gap: 0.55rem;
    font-size: 0.78rem; padding-top: 0.5rem;
    border-top: 1px dashed var(--amp-border);
  }
  .amp-mock-meta-row {
    display: grid; grid-template-columns: 105px 1fr; gap: 0.7rem; align-items: start;
  }
  .amp-mock-key { font-family: var(--amp-mono); color: var(--amp-mute); font-size: 0.68rem; text-transform: uppercase; padding-top: 2px; }
  .amp-mock-val { color: var(--amp-ink-soft); line-height: 1.45; display: flex; flex-wrap: wrap; gap: 0.3rem; }

  .amp-tag {
    background: rgba(109,76,255,0.10); color: var(--amp-violet-d);
    border: 1px solid rgba(109,76,255,0.18);
    padding: 0.1rem 0.5rem; border-radius: 6px;
    font-size: 0.7rem; font-weight: 500;
  }

  .amp-mock-foot {
    margin-top: 1rem; padding-top: 0.85rem;
    border-top: 1px solid var(--amp-border);
    display: flex; align-items: center; gap: 0.85rem;
  }
  .amp-progress {
    flex: 1; height: 6px; background: rgba(15,15,30,0.06);
    border-radius: 99px; overflow: hidden;
  }
  .amp-progress-bar {
    display: block; height: 100%; width: 0;
    background: linear-gradient(90deg, var(--amp-amber), var(--amp-violet));
    border-radius: 99px;
    animation: amp-fill 4s cubic-bezier(0.4,0,0.2,1) 200ms infinite;
  }
  @keyframes amp-fill {
    0%   { width: 0;   transform: translateX(0); }
    70%  { width: 92%; }
    100% { width: 100%; opacity: 0.4; }
  }
  .amp-mock-status {
    font-family: var(--amp-mono); font-size: 0.7rem;
    color: var(--amp-mute); white-space: nowrap;
  }

  /* Floating badges */
  .amp-mock-badge {
    position: absolute; display: flex; align-items: center; gap: 0.7rem;
    padding: 0.7rem 0.95rem; border-radius: 14px;
    background: var(--amp-ink); color: var(--amp-paper);
    box-shadow: 0 16px 36px -8px rgba(15,15,30,0.35);
    z-index: 3;
  }
  .amp-mock-badge--top {
    top: -16px; left: -22px;
    animation: amp-float 4s ease-in-out infinite;
  }
  .amp-mock-badge--top svg {
    width: 20px; height: 20px;
    padding: 6px; border-radius: 8px;
    background: var(--amp-mint); color: #fff; box-sizing: content-box;
  }
  .amp-mock-badge--bot {
    bottom: -16px; right: -18px;
    animation: amp-float 5.5s ease-in-out 0.5s infinite;
  }
  .amp-badge-icon {
    font-family: var(--amp-mono); font-weight: 700;
    background: linear-gradient(135deg, var(--amp-amber), var(--amp-violet));
    color: var(--amp-ink);
    width: 38px; height: 38px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; letter-spacing: 0.04em;
  }
  .amp-badge-num {
    font-family: var(--amp-serif);
    font-size: 1.05rem; line-height: 1; letter-spacing: -0.02em;
  }
  .amp-badge-cap {
    font-size: 0.66rem; color: rgba(251,250,246,0.65);
    margin-top: 3px; letter-spacing: 0.02em;
  }

  /* Trust strip */
  .amp-trust {
    position: relative; z-index: 2;
    margin-top: 1rem; padding: 1.5rem 0 0.5rem;
    border-top: 1px solid var(--amp-border);
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .amp-trust-label {
    font-family: var(--amp-mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--amp-mute);
  }
  .amp-trust-grid {
    display: flex; flex-wrap: wrap; gap: 0.5rem 2.5rem;
    justify-content: center;
  }
  .amp-trust-item {
    font-size: 0.85rem; font-weight: 500; color: var(--amp-ink-soft);
    opacity: 0.8;
  }

  /* ═══════════════════════════════════════════════════════════
     BIG STATS
     ═══════════════════════════════════════════════════════════ */
  .amp-bigstats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem;
  }
  .amp-bigstat {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 16px; padding: 1.75rem;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-bigstat:hover {
    border-color: var(--amp-amber);
    transform: translateY(-4px);
    box-shadow: 0 22px 50px -16px rgba(15,15,30,0.18);
  }
  .amp-bigstat-num {
    font-family: var(--amp-serif);
    font-size: 3rem; line-height: 1; letter-spacing: -0.03em;
    color: var(--amp-ink); margin-bottom: 0.6rem;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .amp-bigstat p {
    font-size: 0.9375rem; color: var(--amp-mid);
    line-height: 1.55; margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     PLATFORMS
     ═══════════════════════════════════════════════════════════ */
  .amp-platforms {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
    max-width: 880px; margin: 0 auto;
  }
  .amp-platform {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 16px; padding: 1.75rem;
    display: flex; align-items: center; gap: 1.15rem;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
    position: relative; overflow: hidden;
  }
  .amp-platform::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(245,158,11,0.08), transparent 60%);
    opacity: 0; transition: opacity 300ms;
  }
  .amp-platform:hover { border-color: var(--amp-ink); transform: translateY(-3px); }
  .amp-platform:hover::before { opacity: 1; }
  .amp-platform-icon {
    width: 52px; height: 52px; border-radius: 12px;
    background: linear-gradient(135deg, #fef3c7, #ddd6fe);
    color: var(--amp-ink-soft); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .amp-platform-icon svg { width: 26px; height: 26px; }
  .amp-platform h3 {
    font-family: var(--amp-serif); font-size: 1.4rem; font-weight: 400;
    line-height: 1.2; margin: 0 0 0.25rem; color: var(--amp-ink);
  }
  .amp-platform p {
    font-family: var(--amp-mono);
    font-size: 0.78rem; color: var(--amp-mute); margin: 0;
  }
  .amp-platform-arrow {
    margin-left: auto; color: var(--amp-mute);
    transition: all 250ms;
  }
  .amp-platform-arrow svg { width: 18px; height: 18px; }
  .amp-platform:hover .amp-platform-arrow { color: var(--amp-amber-d); transform: translateX(4px); }
  .amp-platforms-note {
    text-align: center; color: var(--amp-mute);
    font-size: 0.9rem; margin-top: 1.75rem;
  }

  /* ═══════════════════════════════════════════════════════════
     FEATURES
     ═══════════════════════════════════════════════════════════ */
  .amp-features {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  .amp-feature {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 16px; padding: 1.85rem;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-feature:hover {
    border-color: var(--amp-ink);
    transform: translateY(-4px);
    box-shadow: 0 22px 50px -16px rgba(15,15,30,0.15);
  }
  .amp-feature h3 {
    font-family: var(--amp-serif); font-size: 1.35rem; font-weight: 400;
    line-height: 1.25; margin: 0 0 0.55rem; color: var(--amp-ink);
  }
  .amp-feature p {
    font-size: 0.9375rem; color: var(--amp-mid);
    line-height: 1.65; margin: 0;
  }
  .amp-feature-icon {
    width: 46px; height: 46px; border-radius: 11px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.1rem;
  }
  .amp-feature-icon svg { width: 22px; height: 22px; }
  .amp-feature-icon--amber  { background: rgba(245,158,11,0.12); color: var(--amp-amber-d); }
  .amp-feature-icon--blue   { background: rgba(59,130,246,0.10); color: var(--amp-blue); }
  .amp-feature-icon--green  { background: rgba(16,185,129,0.10); color: var(--amp-mint); }
  .amp-feature-icon--pink   { background: rgba(255,93,143,0.12); color: var(--amp-pink); }
  .amp-feature-icon--violet { background: rgba(109,76,255,0.10); color: var(--amp-violet); }
  .amp-feature-icon--cyan   { background: rgba(6,182,212,0.10);  color: var(--amp-cyan); }
  .amp-feature-icon--red    { background: rgba(239,68,68,0.10);  color: var(--amp-red); }

  /* ═══════════════════════════════════════════════════════════
     COMPARE (before / after)
     ═══════════════════════════════════════════════════════════ */
  .amp-compare {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 1.25rem; align-items: stretch; max-width: 1080px; margin: 0 auto;
  }
  .amp-compare-card {
    border-radius: 16px; padding: 1.75rem;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(8px);
  }
  .amp-compare-card--before { background: rgba(239,68,68,0.04); border-color: rgba(239,68,68,0.18); }
  .amp-compare-card--after  {
    background: linear-gradient(160deg, rgba(245,158,11,0.10), rgba(109,76,255,0.08));
    border-color: rgba(245,158,11,0.28);
  }
  .amp-compare-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }
  .amp-compare-tag {
    font-family: var(--amp-mono);
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.25rem 0.6rem;
    border-radius: 6px;
  }
  .amp-compare-tag--bad  { background: rgba(239,68,68,0.16);  color: #fca5a5; }
  .amp-compare-tag--good { background: rgba(245,158,11,0.20); color: #fbbf24; }
  .amp-compare-meta { font-family: var(--amp-mono); font-size: 0.72rem; color: rgba(251,250,246,0.5); }
  .amp-compare-prod {
    font-family: var(--amp-serif); font-size: 1.5rem;
    font-weight: 400; color: var(--amp-paper); margin-bottom: 0.7rem;
    line-height: 1.2;
  }
  .amp-compare-text {
    font-size: 0.9375rem; line-height: 1.65;
    color: rgba(251,250,246,0.72); margin: 0 0 1.1rem;
  }
  .amp-compare-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.08); padding-top: 1rem;
  }
  .amp-compare-list li {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: 0.875rem; color: rgba(251,250,246,0.78);
  }
  .amp-compare-list li span {
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700;
  }
  .amp-compare-list--bad  li span { background: rgba(239,68,68,0.18); color: #fca5a5; }
  .amp-compare-list--good li span { background: rgba(16,185,129,0.18); color: var(--amp-mint); }
  .amp-compare-arrow {
    display: flex; align-items: center; justify-content: center;
    color: var(--amp-amber);
    background: rgba(245,158,11,0.10);
    border-radius: 50%; width: 56px; height: 56px;
    align-self: center; margin: 0 auto;
    box-shadow: 0 0 0 8px rgba(245,158,11,0.06);
  }
  .amp-compare-arrow svg { width: 24px; height: 24px; }

  /* ═══════════════════════════════════════════════════════════
     STEPS
     ═══════════════════════════════════════════════════════════ */
  .amp-steps {
    display: grid; grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 1.25rem; align-items: stretch;
  }
  .amp-step {
    background: var(--amp-card); border: 1px solid var(--amp-border);
    border-radius: 16px; padding: 2rem;
    display: flex; flex-direction: column;
  }
  .amp-step-num {
    font-family: var(--amp-serif); font-size: 3rem;
    line-height: 1; opacity: 0.85;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
    margin-bottom: 1rem;
  }
  .amp-step h3 {
    font-family: var(--amp-serif); font-size: 1.35rem; font-weight: 400;
    margin: 0 0 0.5rem; color: var(--amp-ink); line-height: 1.25;
  }
  .amp-step p {
    font-size: 0.9375rem; color: var(--amp-mid);
    line-height: 1.65; margin: 0;
  }
  .amp-step-arrow {
    color: var(--amp-amber); display: flex; align-items: center;
  }
  .amp-step-arrow svg { width: 24px; height: 24px; }

  /* ═══════════════════════════════════════════════════════════
     USE CASES
     ═══════════════════════════════════════════════════════════ */
  .amp-uses {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  .amp-use {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 16px; padding: 2rem;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-use:hover { border-color: var(--amp-ink); transform: translateY(-4px); }
  .amp-use-tag {
    display: inline-block;
    font-family: var(--amp-mono); font-size: 0.68rem;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--amp-amber-d); margin-bottom: 0.85rem;
  }
  .amp-use h3 {
    font-family: var(--amp-serif); font-size: 1.45rem; font-weight: 400;
    line-height: 1.2; margin: 0 0 0.7rem; color: var(--amp-ink);
  }
  .amp-use p {
    font-size: 0.95rem; color: var(--amp-mid);
    line-height: 1.65; margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     INTEGRATIONS
     ═══════════════════════════════════════════════════════════ */
  .amp-integrations {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem; max-width: 880px; margin: 0 auto;
  }
  .amp-integration {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 12px; padding: 0.95rem 1rem;
    text-align: center; font-size: 0.875rem; font-weight: 500;
    color: var(--amp-ink-soft);
    transition: all 200ms ease;
  }
  .amp-integration:hover {
    border-color: var(--amp-amber);
    color: var(--amp-amber-d);
    transform: translateY(-2px);
    background: rgba(245,158,11,0.04);
  }

  /* ═══════════════════════════════════════════════════════════
     PRICING
     ═══════════════════════════════════════════════════════════ */
  .amp-plans {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; max-width: 1100px; margin: 0 auto;
    align-items: stretch;
  }
  .amp-plan {
    background: var(--amp-card);
    border: 1px solid var(--amp-border-s);
    border-radius: 18px; padding: 2rem;
    display: flex; flex-direction: column; gap: 1.25rem;
    position: relative;
    transition: all 250ms cubic-bezier(0.16,1,0.3,1);
  }
  .amp-plan:hover { transform: translateY(-4px); }
  .amp-plan--featured {
    border: 2px solid transparent;
    background:
      linear-gradient(var(--amp-card), var(--amp-card)) padding-box,
      linear-gradient(135deg, var(--amp-amber), var(--amp-violet)) border-box;
    box-shadow: 0 30px 60px -20px rgba(109,76,255,0.25);
    transform: translateY(-8px);
  }
  .amp-plan--featured:hover { transform: translateY(-12px); }
  .amp-plan-banner {
    position: absolute; top: -14px; left: 50%;
    transform: translateX(-50%);
    padding: 0.35rem 0.85rem; border-radius: 999px;
    background: linear-gradient(135deg, var(--amp-amber), var(--amp-violet));
    color: #fff;
    font-family: var(--amp-mono); font-size: 0.68rem;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;
    box-shadow: 0 8px 18px -4px rgba(109,76,255,0.4);
  }
  .amp-plan-head { display: flex; flex-direction: column; gap: 0.35rem; }
  .amp-plan-name {
    font-family: var(--amp-serif); font-size: 1.65rem;
    color: var(--amp-ink); line-height: 1;
  }
  .amp-plan-badge {
    font-family: var(--amp-mono); font-size: 0.68rem;
    color: var(--amp-mute); text-transform: uppercase; letter-spacing: 0.06em;
  }
  .amp-plan-price {
    display: flex; align-items: baseline; gap: 0.35rem;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--amp-border-s);
  }
  .amp-plan-num {
    font-family: var(--amp-serif);
    font-size: 3rem; line-height: 1;
    letter-spacing: -0.03em; color: var(--amp-ink);
  }
  .amp-plan-period { color: var(--amp-mute); font-size: 1rem; }
  .amp-plan-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.7rem; flex: 1;
  }
  .amp-plan-list li {
    display: flex; gap: 0.7rem; align-items: flex-start;
    font-size: 0.9rem; color: var(--amp-ink-soft); line-height: 1.5;
  }
  .amp-plan-list svg { width: 14px; height: 14px; color: var(--amp-amber); flex-shrink: 0; margin-top: 4px; }
  .amp-plans-note {
    text-align: center; color: var(--amp-mute);
    font-size: 0.9rem; margin-top: 2rem;
  }
  .amp-plans-note a { color: var(--amp-amber-d); text-decoration: underline; font-weight: 500; }

  /* ═══════════════════════════════════════════════════════════
     QUOTE
     ═══════════════════════════════════════════════════════════ */
  .amp-quote {
    background: var(--amp-card); border: 1px solid var(--amp-border-s);
    border-radius: 20px; padding: 3rem 3.25rem;
    position: relative; overflow: hidden;
  }
  .amp-quote::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 6px; height: 100%;
    background: linear-gradient(180deg, var(--amp-amber), var(--amp-violet));
  }
  .amp-quote-mark {
    position: absolute; top: 1.5rem; right: 1.75rem;
    width: 56px; height: 56px;
    color: rgba(245,158,11,0.18);
  }
  .amp-quote blockquote {
    font-family: var(--amp-serif); font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    line-height: 1.4; color: var(--amp-ink);
    margin: 0 0 1.5rem; font-weight: 400; letter-spacing: -0.01em;
    position: relative;
  }
  .amp-quote figcaption {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding-top: 1rem; border-top: 1px solid var(--amp-border);
  }
  .amp-quote figcaption strong { font-weight: 700; color: var(--amp-ink); font-size: 0.95rem; }
  .amp-quote figcaption span { font-size: 0.85rem; color: var(--amp-mute); }

  /* ═══════════════════════════════════════════════════════════
     FAQ
     ═══════════════════════════════════════════════════════════ */
  .amp-faq { border-top: 1px solid var(--amp-border-s); margin-top: 2.5rem; }
  .amp-faq-item { border-bottom: 1px solid var(--amp-border-s); }
  .amp-faq-item summary {
    list-style: none;
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem; padding: 1.4rem 0; cursor: pointer;
