    color: var(--amp-mid); font-size: 1.0625rem;
    margin: 1rem auto 0; max-width: 620px; line-height: 1.6;
  }
  .amp-section-desc--light { color: rgba(251,250,246,0.7); }

  .amp-pill {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 0.85rem; border-radius: 999px;
    font-family: var(--amp-mono);
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
    background: linear-gradient(135deg, rgba(245,158,11,0.12), rgba(109,76,255,0.10));
    color: var(--amp-amber-d);
    border: 1px solid rgba(245,158,11,0.22);
  }
  .amp-pill--light {
    background: rgba(245,158,11,0.18);
    color: #fbbf24;
    border-color: rgba(245,158,11,0.35);
  }

  .amp-h2 {
    font-family: var(--amp-serif);
    font-size: clamp(2.1rem, 4.4vw, 3.4rem);
    font-weight: 400; line-height: 1.05; letter-spacing: -0.02em;
    margin: 1rem 0 0; color: var(--amp-ink);
  }
  .amp-h2 em {
    font-style: italic;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .amp-h2--light { color: var(--amp-paper); }
  .amp-h2--light em {
    background: linear-gradient(95deg, #fbbf24, #a78bfa);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }

  /* ── Buttons ── */
  .amp-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 10px;
    font-weight: 600; font-size: 0.9375rem; text-decoration: none;
    border: 1px solid transparent;
    transition: all 220ms cubic-bezier(0.16,1,0.3,1);
    white-space: nowrap;
  }
  .amp-btn--lg { padding: 1.05rem 1.85rem; font-size: 1rem; border-radius: 12px; }
  .amp-btn--primary {
    background: linear-gradient(180deg, var(--amp-amber) 0%, var(--amp-amber-d) 100%);
    color: #fff;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.4) inset,
      0 8px 22px -6px rgba(245,158,11,0.55);
  }
  .amp-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.4) inset,
      0 14px 30px -6px rgba(245,158,11,0.65);
  }
  .amp-btn--ghost {
    background: rgba(15,15,30,0.04); color: var(--amp-ink);
    border-color: var(--amp-border-s);
  }
  .amp-btn--ghost:hover { background: rgba(15,15,30,0.07); border-color: var(--amp-ink); }
  .amp-btn--ghost-light {
    background: rgba(255,255,255,0.06); color: var(--amp-paper);
    border-color: rgba(255,255,255,0.18); backdrop-filter: blur(8px);
  }
  .amp-btn--ghost-light:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.35); }
  .amp-btn--outline {
    background: var(--amp-paper); color: var(--amp-ink);
    border-color: var(--amp-border-s);
  }
  .amp-btn--outline:hover { border-color: var(--amp-ink); transform: translateY(-2px); }

  /* ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ */
  .amp-hero {
    position: relative;
    padding: 5rem 0 4rem;
    background:
      radial-gradient(1100px 600px at 90% -10%, rgba(109,76,255,0.10), transparent 60%),
      radial-gradient(900px 600px at -10% 30%, rgba(245,158,11,0.08), transparent 65%),
      var(--amp-paper);
    overflow: hidden;
  }
  .amp-hero-grid {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(var(--amp-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--amp-border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 50% 30%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 10%, transparent 70%);
    opacity: 0.55;
  }
  .amp-hero-glow-a, .amp-hero-glow-b {
    position: absolute; pointer-events: none; z-index: 0;
    border-radius: 50%; filter: blur(60px);
  }
  .amp-hero-glow-a {
    top: -160px; right: -160px; width: 540px; height: 540px;
    background: radial-gradient(circle, rgba(245,158,11,0.18), transparent 60%);
    animation: amp-glow 14s ease-in-out infinite;
  }
  .amp-hero-glow-b {
    bottom: -200px; left: -120px; width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(109,76,255,0.16), transparent 60%);
    animation: amp-glow 16s ease-in-out infinite reverse;
  }
  @keyframes amp-glow {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%      { transform: translate(40px,-30px) scale(1.08); }
  }

  /* Floating orbs */
  .amp-orbit { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .amp-orb {
    position: absolute; border-radius: 50%;
    background: linear-gradient(135deg, var(--amp-amber), var(--amp-violet));
    box-shadow: 0 16px 40px -10px rgba(109,76,255,0.45);
    opacity: 0.75;
  }
  .amp-orb--1 { top: 14%;  left: 6%;  width: 14px; height: 14px; animation: amp-float 7s ease-in-out infinite; }
  .amp-orb--2 { top: 60%;  left: 3%;  width: 8px;  height: 8px;  animation: amp-float 9s ease-in-out 1s infinite; opacity: 0.6; }
  .amp-orb--3 { top: 30%;  right: 10%; width: 10px; height: 10px; animation: amp-float 11s ease-in-out 0.5s infinite; opacity: 0.7; }
  @keyframes amp-float {
    0%, 100% { transform: translate(0,0); }
    50%      { transform: translate(0,-22px); }
  }

  .amp-hero-inner {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    gap: 4rem; align-items: center;
    padding-top: 1rem; padding-bottom: 3.5rem;
  }
  .amp-hero-copy { max-width: 620px; animation: amp-fade-up 700ms ease-out both; }

  .amp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.4rem 0.9rem; border-radius: 999px;
    border: 1px solid var(--amp-border-s);
    background: rgba(255,255,255,0.7); backdrop-filter: blur(8px);
    font-family: var(--amp-mono); font-size: 0.7rem;
    color: var(--amp-ink-soft);
    letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .amp-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: var(--amp-amber);
    box-shadow: 0 0 0 3px rgba(245,158,11,0.22);
    animation: amp-pulse 2s ease-in-out infinite;
  }
  @keyframes amp-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(245,158,11,0.22); }
    50%      { box-shadow: 0 0 0 7px rgba(245,158,11,0); }
  }

  .amp-hero-title {
    font-family: var(--amp-serif);
    font-size: clamp(2.55rem, 5.4vw, 4.5rem);
    font-weight: 400; line-height: 1.02; letter-spacing: -0.025em;
    margin: 0 0 1.4rem; color: var(--amp-ink);
  }
  .amp-hero-title em {
    font-style: italic;
    background: linear-gradient(95deg, var(--amp-amber-d), var(--amp-violet));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .amp-hero-desc {
    font-size: 1.0625rem; color: var(--amp-mid);
