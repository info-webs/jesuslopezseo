---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const canonical = 'https://www.jesuslopezseo.com/plugins/ai-merchant-pro/';
const pageTitle = 'AI Merchant Pro — Plugin WordPress con UCP v7.0 para ChatGPT Shopping y Google AI Mode | Jesús López';
const pageDescription = 'El primer plugin de WordPress con protocolo UCP v7.0. Lleva tu catálogo de WooCommerce a ChatGPT Shopping, Google AI Mode y Google Merchant Center con feeds JSON ACP 1.0 y XML validados. Desde 79€/año.';

// ── Tres feeds que genera el plugin ──
const feeds = [
  {
    code: 'ACP 1.0',
    name: 'Feed JSON ACP 1.0',
    target: 'ChatGPT Shopping',
    audience: '300M+ usuarios',
    desc: 'Cumple el Agentic Commerce Protocol de OpenAI. Tu catálogo aparece dentro de las conversaciones de ChatGPT cuando el usuario pregunta por productos como los tuyos.',
    iconColor: 'mint',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2v20M2 12h20M5 5l14 14M19 5 5 19"/></svg>`,
    bullets: [
      'Formato JSON validado contra el spec de OpenAI',
      'Initial push de 100 productos para aprobación inicial',
      'Soporte para productos variables y atributos',
    ],
  },
  {
    code: 'XML',
    name: 'Feed XML Google Merchant',
    target: 'Google Shopping',
    audience: 'Ads · Free Listings · Buy on Google',
    desc: 'Genera un feed XML de Google Merchant Center listo para enviar. Validación previa para evitar rechazos por campos obligatorios o formato incorrecto.',
    iconColor: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m9 18 6-6-6-6"/><path d="M3 6h.01M3 12h.01M3 18h.01"/></svg>`,
    bullets: [
      'Mapeo automático a la taxonomía Google Product',
      'Reglas de envío por país, región, peso y precio',
      'Validador integrado antes de exportar',
    ],
  },
  {
    code: 'UCP 7',
    name: 'Feed UCP v7.0',
    target: 'Google AI Mode',
    audience: 'AI Overviews · AI Agent Checkout',
    desc: 'Universal Commerce Protocol v7.0, el estándar de Google para comercio con IA. Listo para que un agente complete la compra sin salir de la conversación.',
    iconColor: 'violet',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M12 6a6 6 0 0 0 0 12M12 6a6 6 0 0 1 0 12"/></svg>`,
    bullets: [
      'Primer plugin de WordPress que implementa UCP v7.0',
      'Preparado para AI Agent Checkout (compra automática)',
      'Spec oficial de Google · documentado y mantenido',
    ],
  },
];

// ── Funcionalidades reales ──
const features = [
  {
    iconColor: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/></svg>`,
    title: 'Generación dual JSON + XML',
    desc: 'Un único catálogo de WooCommerce o PrestaShop alimenta los tres feeds. Sin duplicar trabajo, sin instalar tres exportadores distintos.',
  },
  {
    iconColor: 'mint',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><polyline points="20 6 9 17 4 12"/></svg>`,
    title: 'Validador ACP / Google Spec',
    desc: 'Verifica el feed contra el spec oficial antes de enviar. Cero rechazos por GTIN ausente, formato incorrecto o campos obligatorios vacíos.',
  },
  {
    iconColor: 'blue',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M2 10h20"/><path d="M9 18v3M15 18v3"/></svg>`,
    title: 'Reglas de envío avanzadas',
    desc: 'Configura tarifas por país, región, peso y umbrales de precio. Los costes de envío entran ya calculados en el feed que ven los agentes de IA.',
  },
  {
    iconColor: 'violet',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>`,
    title: 'Dashboard con analítica',
    desc: 'Estadísticas de productos sincronizados, errores de validación, evolución del catálogo y exportación a PDF para reporte interno o de cliente.',
  },
  {
    iconColor: 'pink',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Streaming + caché para 50K productos',
    desc: 'Arquitectura por streaming y caché diseñada para catálogos grandes. Probado con más de 50.000 productos sin timeouts ni errores de memoria.',
  },
  {
    iconColor: 'cyan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
    title: 'Initial push a ChatGPT Merchant',
    desc: 'Envío inicial de 100 productos representativos para acelerar la aprobación de catálogos grandes en el programa de ChatGPT Merchant.',
  },
  {
    iconColor: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
    title: 'Vídeo y vídeo 3D nativo',
    desc: 'Campos de vídeo y vídeo 3D directamente en el editor de producto de WooCommerce. Esos formatos viajan en el feed UCP v7.0 hasta los canales de IA.',
  },
  {
    iconColor: 'green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 3v18"/></svg>`,
    title: 'Mapeo a Google Product Taxonomy',
    desc: 'Asigna cada categoría de tu tienda a la taxonomía oficial de Google de forma asistida. Imprescindible para que el feed sea aceptado y bien clasificado.',
  },
  {
    iconColor: 'red',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'Productos variables al 100%',
    desc: 'Cada variación de WooCommerce viaja con sus atributos, precios, stock y GTIN propios. Sin perder información en el camino al feed.',
  },
];

// ── Problemas que resuelve ──
const problems = [
  {
    color: 'red',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/></svg>`,
    title: 'Invisible para 300M+ usuarios de ChatGPT',
    desc: 'La búsqueda con IA crece más rápido que la búsqueda en Google y tu catálogo no aparece. Cada día que pasas fuera, vendes menos en el canal que más rápido crece.',
  },
  {
    color: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Pierdes la ventaja del primer en llegar',
    desc: 'Los canales de IA están en fase de aprobación de catálogos. Quien entre ahora gana posicionamiento y data en los modelos antes de que se sature el espacio.',
  },
  {
    color: 'blue',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: 'Rechazos en Google Merchant Center',
    desc: 'Feeds mal formados, GTINs faltantes, taxonomía incorrecta. AI Merchant Pro valida contra el spec oficial antes de enviar y te dice exactamente qué corregir.',
  },
  {
    color: 'violet',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>`,
    title: 'Timeouts y errores de memoria',
    desc: 'Los exportadores genéricos no aguantan catálogos grandes. La arquitectura streaming + caché de AI Merchant Pro está probada con más de 50.000 productos.',
  },
];

// ── Cómo funciona ──
const steps = [
  {
    num: '01',
    title: 'Instala y activa',
    desc: 'Subes el ZIP a WordPress o PrestaShop, activas con tu licencia y conectas tu cuenta de ChatGPT Merchant y Google Merchant Center. Listo en minutos.',
  },
  {
    num: '02',
    title: 'Configura los feeds',
    desc: 'Mapea categorías a Google Product Taxonomy, define reglas de envío y elige qué productos entran en cada canal. Validador en tiempo real conforme guardas.',
  },
  {
    num: '03',
    title: 'Envía y monitoriza',
    desc: 'Generas los tres feeds con un clic. Ves estadísticas, errores resueltos y crecimiento del catálogo en el dashboard. Exporta a PDF cuando lo necesites.',
  },
];

// ── FAQ ──
const faqs = [
  {
    q: '¿Qué es UCP v7.0 y por qué importa?',
    a: 'Universal Commerce Protocol v7.0 es el estándar abierto que Google ha publicado para que los agentes de IA puedan entender un catálogo y completar la compra dentro de la conversación. Sin un feed UCP, tu tienda no aparece en Google AI Mode ni en AI Overviews con intención de compra. AI Merchant Pro es el primer plugin de WordPress que lo implementa.',
  },
  {
    q: '¿Qué es LLMO y en qué se diferencia del SEO?',
    a: 'LLMO (Large Language Model Optimization) es la disciplina equivalente al SEO pero aplicada a los modelos de lenguaje: ChatGPT, Perplexity, Claude y Google AI Mode. El SEO te posiciona en la SERP de Google. El LLMO te posiciona en las respuestas de los asistentes de IA. AI Merchant Pro es la pieza de LLMO específica para e-commerce: convierte tu catálogo en datos legibles por agentes.',
  },
  {
    q: '¿AI Merchant Pro genera contenido o descripciones de producto?',
    a: 'No. AI Merchant Pro no usa modelos de IA para crear texto. Lo que hace es tomar tu catálogo de WooCommerce o PrestaShop y generar tres feeds (JSON ACP 1.0, XML Google Merchant, UCP v7.0) que los canales de IA entienden. Es un puente entre tu tienda y los nuevos canales de descubrimiento.',
  },
  {
    q: '¿Qué diferencia hay entre la versión Free y la versión de pago?',
    a: 'La Free es gratis, productos ilimitados, pero solo genera el feed JSON ACP 1.0 para ChatGPT Shopping. La versión de pago añade el feed XML de Google Merchant Center, el feed UCP v7.0, el validador completo, las reglas de envío avanzadas, el dashboard con analítica y soporte por email.',
  },
  {
    q: '¿Qué pasa cuando expira mi licencia anual de WooCommerce?',
    a: 'En WooCommerce la licencia es de 79€/año: el plugin sigue funcionando con la última versión instalada, pero dejas de recibir actualizaciones y soporte. Puedes renovar cuando quieras. En PrestaShop la licencia es lifetime (99€ pago único): el plugin es tuyo para siempre y solo el primer año incluye actualizaciones; después puedes contratar updates por 49€/año si quieres seguir recibiéndolas.',
  },
  {
    q: '¿Con qué versiones de WordPress y PrestaShop es compatible?',
    a: 'WordPress con WooCommerce instalado. En PrestaShop es compatible con las ramas 1.7, 8.x y 9.x. Si tienes una versión más antigua, es momento de actualizar antes de instalar.',
  },
  {
    q: '¿Cuántos productos soporta?',
    a: 'Productos ilimitados. La arquitectura por streaming y caché está probada con más de 50.000 productos sin timeouts ni errores de memoria. Para catálogos grandes, el "initial push" de 100 productos representativos acelera la aprobación en ChatGPT Merchant.',
  },
  {
    q: '¿Hay garantía de devolución?',
    a: 'Sí, 30 días desde la compra. Si en un mes no encajamos con tu negocio, te devolvemos el dinero íntegro sin preguntas.',
  },
  {
    q: '¿Puedo probarlo antes de comprar?',
    a: 'Sí. Hay una demo en vivo de la versión WooCommerce en woogptmerchant.com/demo y la versión Free disponible en aimerchantpro.com/free. Te la puedes instalar hoy y ver el feed JSON funcionando antes de plantearte el pago.',
  },
];

// ── Schema.org ──
const schemaProduct = {
  '@type': 'SoftwareApplication',
  name: 'AI Merchant Pro',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'WordPress, WooCommerce, PrestaShop',
  description: pageDescription,
  url: 'https://aimerchantpro.com',
  offers: [
    { '@type': 'Offer', name: 'WooCommerce',  price: '79', priceCurrency: 'EUR', priceSpecification: { '@type': 'UnitPriceSpecification', price: '79', priceCurrency: 'EUR', unitCode: 'ANN' } },
    { '@type': 'Offer', name: 'PrestaShop',   price: '99', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Free',         price: '0',  priceCurrency: 'EUR' },
  ],
};

const schemaFaq = {
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schemaBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',           item: 'https://www.jesuslopezseo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Plugins',          item: 'https://www.jesuslopezseo.com/plugins/' },
    { '@type': 'ListItem', position: 3, name: 'AI Merchant Pro',  item: canonical },
  ],
};

const schema = JSON.stringify({ '@context': 'https://schema.org', '@graph': [schemaProduct, schemaFaq, schemaBreadcrumb] });
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  schema={schema}
>
  <Header />

  <main class="amp-page">

    <!-- ════════════════════════════════════════════════════════
         HERO
         ════════════════════════════════════════════════════════ -->
    <section class="amp-hero">
      <div class="amp-hero-grid"   aria-hidden="true"></div>
      <div class="amp-hero-glow-a" aria-hidden="true"></div>
      <div class="amp-hero-glow-b" aria-hidden="true"></div>
      <div class="amp-orbit"       aria-hidden="true">
        <span class="amp-orb amp-orb--1"></span>
        <span class="amp-orb amp-orb--2"></span>
        <span class="amp-orb amp-orb--3"></span>
      </div>

      <div class="container amp-hero-inner">
        <div class="amp-hero-copy">
          <div class="amp-eyebrow">
            <span class="amp-dot"></span>
            Primer plugin de WordPress con UCP v7.0
          </div>

          <h1 class="amp-hero-title">
            Tu tienda lista para<br/>
            <em>ChatGPT Shopping</em><br/>
            y <em>Google AI Mode.</em>
          </h1>

          <p class="amp-hero-desc">
            <strong>AI Merchant Pro</strong> es el plugin de <strong>WordPress / WooCommerce</strong>
            y módulo de <strong>PrestaShop</strong> que genera los tres feeds que necesitan los
            nuevos canales de comercio con IA — sin escribir una línea de código y desde un único catálogo.
          </p>

          <div class="amp-hero-actions">
            <a href="https://shop.aimerchantpro.com" target="_blank" rel="noopener" class="amp-btn amp-btn--primary">
              Comprar WooCommerce · 79€/año
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="https://shop.aimerchantpro.com/prestashop" target="_blank" rel="noopener" class="amp-btn amp-btn--ghost">
              PrestaShop · 99€ pago único
            </a>
          </div>

          <a href="https://wordpress.org/plugins/jesuslopez-gpt-merchant-feed/" target="_blank" rel="noopener" class="amp-hero-free">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            ¿Solo quieres probarlo? Versión <strong>gratuita oficial en WordPress.org</strong>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M7 17 17 7M8 7h9v9"/></svg>
          </a>

          <div class="amp-hero-badges">
            <span class="amp-hero-badge"><span class="amp-hero-badge-dot"></span>UCP v7.0 Ready</span>
            <span class="amp-hero-badge"><span class="amp-hero-badge-dot amp-hero-badge-dot--mint"></span>ChatGPT Shopping</span>
            <span class="amp-hero-badge"><span class="amp-hero-badge-dot amp-hero-badge-dot--violet"></span>Google AI Mode</span>
            <span class="amp-hero-badge"><span class="amp-hero-badge-dot amp-hero-badge-dot--blue"></span>ACP 1.0</span>
          </div>

          <div class="amp-hero-meta">
            <div class="amp-stat">
              <div class="amp-stat-num">500+</div>
              <div class="amp-stat-cap">tiendas activas</div>
            </div>
            <div class="amp-stat">
              <div class="amp-stat-num">300M+</div>
              <div class="amp-stat-cap">usuarios ChatGPT</div>
            </div>
            <div class="amp-stat">
              <div class="amp-stat-num">50K+</div>
              <div class="amp-stat-cap">productos probados</div>
            </div>
          </div>
        </div>

        <!-- Mockup: feed JSON generándose en vivo -->
        <div class="amp-hero-aside" aria-hidden="true">
          <div class="amp-mock">
            <div class="amp-mock-bar">
              <span class="amp-mock-dot amp-mock-dot--r"></span>
              <span class="amp-mock-dot amp-mock-dot--y"></span>
              <span class="amp-mock-dot amp-mock-dot--g"></span>
              <span class="amp-mock-tab">/wp-admin/ai-merchant-pro/feeds</span>
            </div>

            <div class="amp-mock-body">
              <div class="amp-mock-head">
                <div class="amp-mock-thumb">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/></svg>
                </div>
                <div>
                  <div class="amp-mock-prod">Generando feeds del catálogo</div>
                  <div class="amp-mock-sku">12.847 productos · 3 canales activos</div>
                </div>
                <span class="amp-mock-pill amp-mock-pill--live">live</span>
              </div>

              <div class="amp-mock-feeds">
                <div class="amp-mock-feed">
                  <div class="amp-mock-feed-icon amp-mock-feed-icon--mint">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="amp-mock-feed-body">
                    <div class="amp-mock-feed-name">JSON · ACP 1.0</div>
                    <div class="amp-mock-feed-tag">ChatGPT Shopping</div>
                  </div>
                  <div class="amp-mock-feed-status amp-mock-feed-status--ok">12.847</div>
                </div>
                <div class="amp-mock-feed">
                  <div class="amp-mock-feed-icon amp-mock-feed-icon--amber">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="amp-mock-feed-body">
                    <div class="amp-mock-feed-name">XML · Google Merchant</div>
                    <div class="amp-mock-feed-tag">Shopping Ads · Buy on Google</div>
                  </div>
                  <div class="amp-mock-feed-status amp-mock-feed-status--ok">12.847</div>
                </div>
                <div class="amp-mock-feed">
                  <div class="amp-mock-feed-icon amp-mock-feed-icon--violet">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="amp-mock-feed-body">
                    <div class="amp-mock-feed-name">UCP v7.0</div>
                    <div class="amp-mock-feed-tag">Google AI Mode · AI Overviews</div>
                  </div>
                  <div class="amp-mock-feed-status amp-mock-feed-status--ok">12.847</div>
                </div>
              </div>

              <div class="amp-mock-foot">
                <div class="amp-progress">
                  <span class="amp-progress-bar"></span>
                </div>
                <span class="amp-mock-status">Validando spec · 0 errores</span>
              </div>
            </div>
          </div>

          <div class="amp-mock-badge amp-mock-badge--top">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <div>
              <div class="amp-badge-num">3 feeds</div>
              <div class="amp-badge-cap">listos para enviar</div>
            </div>
          </div>

          <div class="amp-mock-badge amp-mock-badge--bot">
            <span class="amp-badge-icon">UCP</span>
            <div>
              <div class="amp-badge-num">v7.0</div>
              <div class="amp-badge-cap">spec oficial Google</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Compatibilidad real -->
      <div class="container">
        <div class="amp-trust">
          <span class="amp-trust-label">Compatible con</span>
          <div class="amp-trust-grid">
            <div class="amp-trust-item">WordPress + WooCommerce</div>
            <div class="amp-trust-item">PrestaShop 1.7 / 8.x / 9.x</div>
            <div class="amp-trust-item">ChatGPT Merchant</div>
            <div class="amp-trust-item">Google Merchant Center</div>
            <div class="amp-trust-item">Google AI Mode</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         WHAT IS UCP v7.0
         ════════════════════════════════════════════════════════ -->
    <section class="amp-section">
      <div class="container">
        <div class="amp-section-header">
          <div class="amp-pill">El protocolo</div>
          <h2 class="amp-h2">¿Qué es <em>UCP v7.0</em><br/>y por qué te importa?</h2>
          <p class="amp-section-desc">
            Universal Commerce Protocol es el estándar abierto que Google publicó para que los
            agentes de IA puedan leer un catálogo y completar la compra dentro de la conversación,
            sin redirigir al usuario a tu web. Es a la IA lo que el sitemap.xml fue al SEO en 2005.
          </p>
        </div>

        <div class="amp-compare">
          <div class="amp-compare-card amp-compare-card--before">
            <div class="amp-compare-head">
              <span class="amp-compare-tag amp-compare-tag--bad">Sin UCP</span>
              <span class="amp-compare-meta">visibilidad parcial</span>
            </div>
            <div class="amp-compare-prod">Tu tienda hoy</div>
            <p class="amp-compare-text">
              Tu catálogo solo existe en Google clásico. Cuando un usuario pregunta a ChatGPT o a
