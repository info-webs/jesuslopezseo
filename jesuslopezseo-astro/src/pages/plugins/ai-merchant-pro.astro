    --amp-ink-soft: #1f2230;
    --amp-mid:      #4f5466;
    --amp-mute:     #7d8398;
    --amp-paper:    #fbfaf6;
    --amp-cream:    #f3efe7;
    --amp-card:     #ffffff;
    --amp-border:   rgba(15,15,30,0.08);
