---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPostBySlug, getPageContent, getPosts } from '../../lib/notion';
import type { NotionPost } from '../../lib/notion';
import featuredImages from '../../lib/featured-images.json';

const featuredImagesMap: Record<string, string> = featuredImages as Record<string, string>;

const { slug } = Astro.params;

// Fetch the post
let post: NotionPost | null = null;
let content = '';
let relatedPosts: NotionPost[] = [];

try {
  post = await getPostBySlug(slug!);

  if (post) {
    // Fetch content blocks
    content = await getPageContent(post.id, post.slug, post.originalUrl);

    // Fetch related posts (same category, exclude current)
    const related = await getPosts({ category: post.category, limit: 4 });
    relatedPosts = related.posts.filter(p => p.slug !== slug).slice(0, 3);
  }
} catch (e) {
  console.error('Error fetching post:', e);
}

if (!post) {
  return Astro.redirect('/noticias');
}

// Format date helper
function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  } catch {
    return dateStr;
  }
}

// Reading time from actual HTML content (accurate)
function readingTime(html: string): string {
  const text = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  const words = text.split(' ').filter(w => w.length > 0).length;
  const mins = Math.max(1, Math.round(words / 200));
  return `${mins} min de lectura`;
}

// Extract first image from HTML for og:image
function extractFirstImage(html: string): string | null {
  const m = html.match(/src="(https?:\/\/[^"\s]+\.(jpg|jpeg|png|webp|gif)[^"\s]*)"/i);
  return m ? m[1] : null;
}

// Build Schema.org Article JSON-LD
function buildSchema(p: NonNullable<typeof post>, html: string, url: string): string {
  const text = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  const words = text.split(' ').filter(w => w.length > 0).length;
  const img = extractFirstImage(html) || defaultOgImage;
  return JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": p.title,
    "description": p.excerpt || p.title,
    "image": img,
    "author": { "@type": "Person", "name": p.author || "Jesús López", "url": "https://www.jesuslopezseo.com" },
    "publisher": { "@type": "Organization", "name": "JesusLopezSEO", "logo": { "@type": "ImageObject", "url": "https://www.jesuslopezseo.com/favicon.svg" } },
    "datePublished": p.publishedDate,
    "dateModified": p.publishedDate,
    "url": url,
    "wordCount": words,
    "articleSection": p.category,
    "inLanguage": "es-ES"
  });
}

const defaultOgImage = 'https://www.jesuslopezseo.com/og-default.jpg';
const postUrl = `https://www.jesuslopezseo.com/noticias/${post.slug}/`;
// Priority: 1) local downloaded image, 2) Notion cover (only if not WP), 3) first image in content, 4) default
const localImage = featuredImagesMap[post.slug] || null;
const notionCover = (post.coverImage && !post.coverImage.includes('wp-content')) ? post.coverImage : null;
const featuredImage = localImage || notionCover || extractFirstImage(content);
const ogImage = featuredImage
  ? (featuredImage.startsWith('/') ? `https://www.jesuslopezseo.com${featuredImage}` : featuredImage)
  : defaultOgImage;
const schema = buildSchema(post, content, postUrl);

const catColors: Record<string, string> = {
  'SEO': 'badge-seo',
  'Diseño Web': 'badge-diseno',
  'Marketing Digital': 'badge-marketing',
  'Redes Sociales': 'badge-redes',
  'Noticias': 'badge-noticias',
  'Google': 'badge-google',
};

const breadcrumb = [
  { label: 'Inicio', href: '/' },
  { label: 'Blog', href: '/noticias' },
  { label: post.category, href: `/noticias?categoria=${encodeURIComponent(post.category)}` },
];
---

<Layout
  title={`${post.title} — JesusLopezSEO`}
  description={post.excerpt || post.title}
  canonical={postUrl}
  ogImage={ogImage}
  ogType="article"
  publishedDate={post.publishedDate || undefined}
  author={post.author || 'Jesús López'}
  schema={schema}
>
  <Header />

  <!-- Reading progress bar (fixed at top) -->
  <div id="progress-bar" class="reading-progress" style="width: 0%;"></div>

  <main>
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <div class="container">
        <nav aria-label="Breadcrumb" class="breadcrumb">
          {breadcrumb.map((item, i) => (
            <>
              {i > 0 && <span class="breadcrumb-sep">/</span>}
              <a href={item.href} class="breadcrumb-link">{item.label}</a>
            </>
          ))}
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-current">{post.title}</span>
        </nav>
      </div>
    </div>

    <!-- Article -->
    <article class="post-wrap">
      <div class="container post-layout">

        <!-- Main content -->
        <div class="post-main">

          <!-- Header -->
          <header class="post-header">
            <div class="post-header-meta">
              <a
                href={`/noticias?categoria=${encodeURIComponent(post.category)}`}
                class={`post-badge ${catColors[post.category] || 'badge-default'}`}
              >
                {post.category}
              </a>
              <span class="post-reading-time">{readingTime(content)}</span>
            </div>

            <h1 class="post-title">{post.title}</h1>

            {post.excerpt && (
              <p class="post-excerpt">{post.excerpt}</p>
            )}

            <div class="post-byline">
              <div class="byline-author">
                <div class="author-avatar">{post.author.charAt(0).toUpperCase()}</div>
                <div>
                  <span class="author-name">{post.author}</span>
                  {post.publishedDate && (
                    <time datetime={post.publishedDate} class="post-date">
                      {formatDate(post.publishedDate)}
                    </time>
                  )}
                </div>
              </div>
              {post.tags?.length > 0 && (
                <div class="post-tags">
                  {post.tags.map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </header>

          <!-- Featured image -->
          {featuredImage && (
            <div class="post-featured-image">
              <img
                src={featuredImage}
                alt={post.title}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="post-featured-img"
                onerror="this.closest('.post-featured-image').style.display='none'"
              />
            </div>
          )}

          <!-- Divider -->
          <hr class="post-divider"/>

          <!-- Body -->
          {content ? (
            <div class="post-body" set:html={content} />
          ) : (
            <div class="post-body post-body--empty">
              <p>
                Este artículo fue publicado originalmente en:
                <a href={post.originalUrl} target="_blank" rel="noopener">{post.originalUrl}</a>
              </p>
              <p>El contenido completo está disponible en nuestro blog. Estamos migrando todos los artículos a nuestra nueva plataforma.</p>
            </div>
          )}

          <!-- Inline related posts: data + template (consumed by inline-related script) -->
          {relatedPosts.length > 0 && (
            <script
              id="inline-related-data"
              type="application/json"
              set:html={JSON.stringify(
                relatedPosts.map(rp => ({
                  slug: rp.slug,
                  title: rp.title,
                  category: rp.category,
                }))
              )}
            />
          )}
          <template id="inline-related-template">
            <aside class="inline-related" role="complementary">
              <span class="inline-related__label">Leer también</span>
              <a class="inline-related__link" href="">
                <span class="inline-related__title"></span>
                <span class="inline-related__arrow" aria-hidden="true">→</span>
              </a>
            </aside>
          </template>

          <!-- Tags footer -->
          {post.tags?.length > 0 && (
            <div class="post-tags-footer">
              <span class="tags-label">Etiquetas:</span>
              {post.tags.map(tag => (
                <span class="tag tag--lg">#{tag}</span>
              ))}
            </div>
          )}

          <!-- Share -->
          <div class="post-share">
            <span class="share-label">Compartir:</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=https://www.jesuslopezseo.com/noticias/${post.slug}/`}
              target="_blank"
              rel="noopener"
              class="share-btn"
              aria-label="Compartir en X (Twitter)"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter/X
            </a>
            <a
              href={`https://www.linkedin.com/shareArticle?mini=true&url=https://www.jesuslopezseo.com/noticias/${post.slug}&title=${encodeURIComponent(post.title)}`}
              target="_blank"
              rel="noopener"
              class="share-btn"
              aria-label="Compartir en LinkedIn"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>

          <!-- Author box -->
          <div class="author-box">
            <div class="author-box-avatar">JL</div>
            <div class="author-box-content">
              <strong>Jesús López</strong>
              <span>CEO & Consultor SEO en JesusLopezSEO</span>
              <p>
                Apasionado del posicionamiento web con más de 18 años de experiencia
                ayudando a empresas a crecer en Google. Si tienes dudas sobre SEO,
                <a href="/contactar">contáctame directamente</a>.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar (TOC only) -->
        <aside class="post-sidebar">
          <div id="toc-sidebar" class="toc-box">
            <div class="toc-header">
              <button id="toc-toggle" class="toc-toggle" aria-expanded="true" aria-controls="toc-list">
                <span class="toc-title">En este artículo</span>
                <svg id="toc-toggle-icon" class="toc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                </svg>
              </button>
            </div>
            <div class="toc-progress">
              <div class="toc-progress-row">
                <span class="toc-progress-label">Progreso</span>
                <span id="toc-progress-text" class="toc-progress-pct">0%</span>
              </div>
              <div class="toc-progress-track">
                <div id="toc-progress-bar" class="toc-progress-fill" style="width: 0%;"></div>
              </div>
            </div>
            <nav id="toc-list" class="toc-list" aria-label="Tabla de contenidos"></nav>
            <div class="toc-empty" id="toc-empty" hidden>Este artículo no tiene secciones.</div>
          </div>
        </aside>

      </div>
    </article>

    <!-- Mobile TOC floating button -->
    <button id="mobile-toc-btn" class="mobile-toc-btn" aria-label="Abrir tabla de contenidos" aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
      </svg>
      <span>Contenido</span>
      <span id="mobile-toc-pct" class="mobile-toc-pct">0%</span>
    </button>

    <!-- Mobile TOC drawer -->
    <div id="mobile-toc-overlay" class="mobile-toc-overlay" aria-hidden="true">
      <div class="mobile-toc-backdrop" id="mobile-toc-backdrop"></div>
      <div class="mobile-toc-drawer" id="mobile-toc-drawer" role="dialog" aria-label="Tabla de contenidos">
        <div class="mobile-toc-handle"></div>
        <div class="mobile-toc-head">
          <span class="toc-title">En este artículo</span>
          <button id="mobile-toc-close" class="mobile-toc-close" aria-label="Cerrar tabla de contenidos">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <nav id="mobile-toc-list" class="mobile-toc-list" aria-label="Tabla de contenidos móvil"></nav>
      </div>
    </div>

    <!-- Related posts full section -->
    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="container">
          <div class="section-label">Sigue leyendo</div>
          <h2>Más artículos de <span class="serif">{post.category}</span></h2>
          <div class="related-grid">
            {relatedPosts.map(rp => (
              <a href={`/noticias/${rp.slug}`} class="related-card">
                <span class={`post-badge ${catColors[rp.category] || 'badge-default'}`}>{rp.category}</span>
                <h3>{rp.title}</h3>
                {rp.excerpt && <p>{rp.excerpt}</p>}
                <span class="read-more">Leer artículo →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
/* Breadcrumb */
.breadcrumb-bar {
  border-bottom: 1px solid var(--surface-border);
  background: var(--surface-card);
  padding: 0.75rem 0;
}
.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.25rem;
  font-size: 0.8125rem;
}
.breadcrumb-link { color: var(--text-muted); text-decoration: none; }
.breadcrumb-link:hover { color: var(--primary-dark); }
.breadcrumb-sep { color: var(--text-light); }
.breadcrumb-current {
  color: var(--text-secondary);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240px;
}

/* Layout */
.post-wrap { padding: 4rem 0 6rem; }
.post-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 4rem;
  align-items: start;
}
.post-main { min-width: 0; }

/* Header */
.post-header { margin-bottom: 2rem; }
.post-featured-image { margin: 1.5rem 0 0; border-radius: var(--radius-lg, 0.75rem); overflow: hidden; }
.post-featured-img { width: 100%; height: auto; max-height: 480px; object-fit: cover; display: block; border-radius: var(--radius-lg, 0.75rem); }
.post-header-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.post-title {
  font-size: clamp(1.625rem, 3vw, 2.25rem);
  line-height: 1.3;
  margin-bottom: 1rem;
  color: var(--text-primary);
}
.post-excerpt {
  font-size: 1.0625rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}
.post-byline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
}
.byline-author { display: flex; align-items: center; gap: 0.75rem; }
.author-avatar {
  width: 40px; height: 40px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.author-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }
.post-date { display: block; font-size: 0.8125rem; color: var(--text-light); }
.post-reading-time { font-size: 0.8125rem; color: var(--text-light); }

.post-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.tag {
  display: inline-block;
  padding: 0.2rem 0.5rem;
  background: var(--cream-100);
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  color: var(--text-muted);
}
.tag--lg {
  padding: 0.3rem 0.625rem;
  font-size: 0.8125rem;
}

/* Badges */
.post-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  font-weight: 600;
  text-decoration: none;
}
.badge-seo { background: #fef3c7; color: #92400e; }
.badge-diseno { background: #ede9fe; color: #5b21b6; }
.badge-marketing { background: #dcfce7; color: #166534; }
.badge-redes { background: #dbeafe; color: #1e40af; }
.badge-noticias { background: #fce7f3; color: #9d174d; }
.badge-google { background: #fee2e2; color: #991b1b; }
.badge-default { background: var(--cream-100); color: var(--text-muted); }

/* Divider */
.post-divider { border: none; border-top: 1px solid var(--surface-border); margin: 2rem 0; }

/* Body */
.post-body {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--text-secondary);
}
.post-body h2 {
  font-size: 1.5rem;
  color: var(--text-primary);
  margin: 2.5rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--amber-100);
}
.post-body h3 { font-size: 1.25rem; color: var(--text-primary); margin: 2rem 0 0.75rem; }
.post-body h4 { font-size: 1.0625rem; color: var(--text-primary); margin: 1.5rem 0 0.5rem; }
.post-body p { margin-bottom: 1.25rem; }
.post-body ul, .post-body ol { margin: 1rem 0 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.375rem; }
.post-body li { line-height: 1.7; }
.post-body a { color: var(--primary-dark); text-decoration: underline; }
.post-body a:hover { color: var(--primary); }
.post-body blockquote {
  border-left: 3px solid var(--primary);
  padding: 0.75rem 1.25rem;
  margin: 1.5rem 0;
  background: var(--amber-50);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  color: var(--text-secondary);
  font-style: italic;
}
.post-body pre {
  background: #1a1814;
  border-radius: var(--radius-md);
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.post-body code {
  font-family: 'Courier New', monospace;
  font-size: 0.875rem;
  color: #f59e0b;
}
.post-body figure { margin: 1.75rem 0; }
.post-body img { width: 100%; border-radius: var(--radius-md); }
.post-body figcaption { font-size: 0.8125rem; color: var(--text-light); text-align: center; margin-top: 0.5rem; }
.post-body hr { border: none; border-top: 1px solid var(--surface-border); margin: 2rem 0; }

.post-body--empty {
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-lg);
  padding: 2rem;
}
.post-body--empty a { color: var(--primary-dark); }

/* Tags footer */
.post-tags-footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--surface-border);
}
.tags-label { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }

/* Share */
.post-share {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 1.5rem;
}
.share-label { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 150ms;
}
.share-btn:hover { border-color: var(--amber-200); color: var(--primary-dark); background: var(--amber-50); }

/* Author box */
.author-box {
  display: flex;
  gap: 1.25rem;
  padding: 1.75rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-xl);
  margin-top: 2rem;
}
.author-box-avatar {
  flex-shrink: 0;
  width: 56px; height: 56px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800;
  font-size: 1.125rem;
  color: #fff;
}
.author-box-content strong { display: block; font-size: 1rem; color: var(--text-primary); margin-bottom: 0.1rem; }
.author-box-content span { display: block; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 0.5rem; }
.author-box-content p { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }
.author-box-content a { color: var(--primary-dark); text-decoration: underline; }

/* Reading progress bar (top of viewport) */
.reading-progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  z-index: 60;
  transition: width 100ms linear;
  pointer-events: none;
}

/* Sidebar — TOC only */
.post-sidebar { position: sticky; top: 6rem; align-self: start; }
.toc-box {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  padding: 1.25rem;
  box-shadow: var(--shadow-xs);
  max-height: calc(100vh - 8rem);
  display: flex;
  flex-direction: column;
}
.toc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}
.toc-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  width: 100%;
  padding: 0;
  border: 0;
  background: transparent;
  cursor: pointer;
  color: var(--text-primary);
}
.toc-title { font-size: 0.9375rem; font-weight: 700; color: var(--text-primary); }
.toc-chevron { color: var(--text-muted); transition: transform 200ms ease; flex-shrink: 0; }
.toc-toggle[aria-expanded="false"] .toc-chevron { transform: rotate(-90deg); }

.toc-list {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
  overflow-y: auto;
  padding-right: 0.25rem;
  scrollbar-width: thin;
}
.toc-list::-webkit-scrollbar { width: 4px; }
.toc-list::-webkit-scrollbar-track { background: transparent; }
.toc-list::-webkit-scrollbar-thumb { background: var(--surface-border); border-radius: 2px; }

.toc-link {
  display: block;
  padding: 0.45rem 0.625rem;
  border-left: 2px solid transparent;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 0.8125rem;
  line-height: 1.4;
  color: var(--text-muted);
  text-decoration: none;
  transition: all 150ms ease;
}
.toc-link:hover { color: var(--text-primary); background: var(--cream-50); }
.toc-link--h3 { padding-left: 1.25rem; font-size: 0.78125rem; }
.toc-link--h4 { padding-left: 1.75rem; font-size: 0.75rem; }
.toc-link--active {
  color: var(--primary-dark);
  font-weight: 600;
  border-left-color: var(--primary);
  background: var(--amber-50);
}

.toc-empty { font-size: 0.8125rem; color: var(--text-muted); padding: 0.5rem 0; }

.toc-progress {
  margin-bottom: 1rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--surface-border);
}
.toc-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.5rem;
}
.toc-progress-label { font-size: 0.75rem; color: var(--text-muted); }
.toc-progress-pct { font-size: 0.75rem; font-weight: 600; color: var(--primary-dark); }
.toc-progress-track {
  height: 4px;
  background: var(--cream-100);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.toc-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: var(--radius-full);
  transition: width 150ms linear;
  width: 0%;
}

/* Mobile TOC button */
.mobile-toc-btn {
  display: none;
  position: fixed;
  bottom: 1.25rem;
  right: 1.25rem;
  z-index: 45;
  align-items: center;
  gap: 0.5rem;
  padding: 0.625rem 1rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-lg);
  color: var(--text-primary);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 150ms ease;
}
.mobile-toc-btn:hover { border-color: var(--amber-200); }
.mobile-toc-btn svg { color: var(--primary); }
.mobile-toc-pct {
  padding: 0.125rem 0.4rem;
  border-radius: var(--radius-full);
  background: var(--amber-50);
  color: var(--primary-dark);
  font-size: 0.6875rem;
  font-weight: 700;
}

/* Mobile TOC drawer */
.mobile-toc-overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: none;
  opacity: 0;
  transition: opacity 250ms ease;
}
.mobile-toc-overlay.is-open { opacity: 1; pointer-events: auto; }
.mobile-toc-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(26, 24, 20, 0.55);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
}
.mobile-toc-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background: var(--surface-card);
  border-top: 1px solid var(--surface-border);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  box-shadow: var(--shadow-xl);
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
}
@media (max-height: 600px) {
  .mobile-toc-drawer { max-height: 60vh; }
}
.mobile-toc-overlay.is-open .mobile-toc-drawer { transform: translateY(0); }
.mobile-toc-handle {
  width: 40px;
  height: 4px;
  background: var(--surface-border);
  border-radius: var(--radius-full);
  margin: 0.5rem auto 0;
}
.mobile-toc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid var(--surface-border);
}
.mobile-toc-close {
  background: transparent;
  border: 0;
  color: var(--text-muted);
  cursor: pointer;
  padding: 0.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  transition: all 150ms ease;
}
.mobile-toc-close:hover { color: var(--text-primary); background: var(--cream-50); }
.mobile-toc-list {
  overflow-y: auto;
  padding: 0.75rem 1rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}
.mobile-toc-list .toc-link { border-left: 0; border-radius: var(--radius-sm); }
.mobile-toc-list .toc-link--active {
  background: var(--amber-50);
  color: var(--primary-dark);
  border-left: 0;
}

/* Related section */
.related-section {
  padding: 5rem 0 6rem;
  background: var(--surface-subtle);
}
.related-section h2 { margin: 0.5rem 0 2.5rem; }
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.related-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.5rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  text-decoration: none;
  transition: all var(--transition-base);
}
.related-card:hover {
  border-color: var(--amber-200);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.related-card h3 { font-size: 1rem; color: var(--text-primary); line-height: 1.45; margin: 0; }
.related-card p {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.read-more { font-size: 0.875rem; font-weight: 600; color: var(--primary-dark); margin-top: auto; }

/* Full-width variant when the article has no TOC to show */
.post-layout.post-layout--no-toc { grid-template-columns: 1fr; max-width: 780px; margin-left: auto; margin-right: auto; }
.post-layout.post-layout--no-toc .post-sidebar { display: none; }

/* Responsive */
@media (max-width: 1024px) {
  .post-layout { grid-template-columns: 1fr; }
  .post-sidebar { display: none; }
  .mobile-toc-btn { display: inline-flex; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .post-wrap { padding: 2rem 0 5rem; }
  .related-grid { grid-template-columns: 1fr; }
  .post-byline { flex-direction: column; align-items: flex-start; }
  .mobile-toc-btn { bottom: 1rem; right: 1rem; padding: 0.5rem 0.875rem; font-size: 0.75rem; }
  /* Prevent any child element from overflowing horizontally */
  .post-main { overflow-x: hidden; }
  .post-body { overflow-x: hidden; }
  .post-body * { max-width: 100%; }
  .post-body pre { overflow-x: auto; white-space: pre-wrap; word-break: break-word; }
  .post-body table { display: block; overflow-x: auto; }
  .post-body img { height: auto; }
}

/* Scroll offset so anchor jumps don't hide under sticky header */
.post-body :where(h2, h3, h4)[id] { scroll-margin-top: 6rem; }

/* Inline related posts (WP "Inline Related Posts" plugin style) */
.inline-related {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin: 2rem 0;
  padding: 1.1rem 1.25rem 1.1rem 1.4rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-left: 4px solid var(--primary);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  box-shadow: var(--shadow-xs);
  transition: all 200ms ease;
}
.inline-related:hover {
  background: var(--cream-50);
  border-left-color: var(--primary-dark);
  box-shadow: var(--shadow-sm);
  transform: translateX(2px);
}
.inline-related__label {
  font-size: 0.6875rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--primary-dark);
}
.inline-related__link {
  display: inline-flex;
  align-items: baseline;
  gap: 0.4rem;
  color: var(--text-primary);
  font-size: 1.0625rem;
  font-weight: 600;
  line-height: 1.4;
  text-decoration: none !important;
}
.inline-related__link:hover { color: var(--primary-dark); }
.inline-related__arrow {
  display: inline-block;
  transition: transform 200ms ease;
  color: var(--primary);
}
.inline-related__link:hover .inline-related__arrow { transform: translateX(3px); }
@media (max-width: 640px) {
  .inline-related { margin: 1.5rem 0; padding: 0.9rem 1rem 0.9rem 1.1rem; }
  .inline-related__link { font-size: 0.9375rem; }
}
