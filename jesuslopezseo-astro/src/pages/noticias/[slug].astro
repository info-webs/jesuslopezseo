<script is:inline>
  (function () {
    function slugify(text) {
      return String(text || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-');
    }

    function init() {
      var articleBody = document.querySelector('.post-body');
      var progressBar = document.getElementById('progress-bar');
      var tocSidebar = document.getElementById('toc-sidebar');
      var tocList = document.getElementById('toc-list');
      var tocEmpty = document.getElementById('toc-empty');
      var tocToggle = document.getElementById('toc-toggle');
      var tocProgressBar = document.getElementById('toc-progress-bar');
      var tocProgressText = document.getElementById('toc-progress-text');
      var mobileTocBtn = document.getElementById('mobile-toc-btn');
      var mobileTocPct = document.getElementById('mobile-toc-pct');
      var mobileTocOverlay = document.getElementById('mobile-toc-overlay');
      var mobileTocList = document.getElementById('mobile-toc-list');
      var mobileTocClose = document.getElementById('mobile-toc-close');
      var mobileTocBackdrop = document.getElementById('mobile-toc-backdrop');

      if (!articleBody) return;

      // Inject inline related posts (WP "Inline Related Posts" plugin style).
      // Inserts a small "Leer también" card after specific paragraphs to
      // surface related content mid-article without breaking reading flow.
      (function injectInlineRelated() {
        var dataEl = document.getElementById('inline-related-data');
        var tpl = document.getElementById('inline-related-template');
        if (!dataEl || !tpl || !articleBody) return;
        var related;
        try { related = JSON.parse(dataEl.textContent || '[]'); } catch (e) { return; }
        if (!Array.isArray(related) || related.length === 0) return;

        var paragraphs = Array.prototype.filter.call(
          articleBody.children,
          function (el) {
            if (el.tagName !== 'P') return false;
            var text = (el.textContent || '').trim();
            return text.length > 40;
          }
        );
        if (paragraphs.length < 4) return;

        var total = paragraphs.length;
        var slots = [];
        slots.push(Math.min(2, total - 1));
        if (total >= 9 && related.length >= 2) {
          slots.push(Math.min(Math.floor(total / 2) + 1, total - 1));
        }
        if (total >= 16 && related.length >= 3) {
          slots.push(Math.min(total - 3, total - 1));
        }

        var seen = {};
        var insertions = [];
        var ri = 0;
        for (var s = 0; s < slots.length; s++) {
          var idx = slots[s];
          if (seen[idx] || ri >= related.length) continue;
          seen[idx] = true;
          insertions.push({ index: idx, rel: related[ri] });
          ri++;
        }

        // Insert from last to first so earlier indexes stay valid.
        for (var i = insertions.length - 1; i >= 0; i--) {
          var ins = insertions[i];
          var node = tpl.content.cloneNode(true);
          var link = node.querySelector('.inline-related__link');
          var titleEl = node.querySelector('.inline-related__title');
          if (!link || !titleEl) continue;
          link.setAttribute('href', '/noticias/' + ins.rel.slug);
          titleEl.textContent = ins.rel.title;
          var anchor = paragraphs[ins.index];
          if (anchor && anchor.parentNode) {
            anchor.parentNode.insertBefore(node, anchor.nextSibling);
          }
        }
      })();

      // Promote WP-style pseudo-headings to real <h3> so legacy imported
      // posts (where section titles were saved as <p><strong>Title</strong></p>)
      // still produce a TOC.
      Array.prototype.forEach.call(articleBody.querySelectorAll('p'), function (p) {
        var strong = p.querySelector('strong');
        if (!strong) return;
        // Only promote if the paragraph's entire visible content is one <strong>.
        var onlyStrong = p.children.length === 1 && p.children[0] === strong;
        var rest = (p.textContent || '').replace(strong.textContent || '', '').trim();
        var text = (strong.textContent || '').trim();
        if (!onlyStrong || rest.length > 0) return;
        if (text.length < 3 || text.length > 160) return;
        var h = document.createElement('h3');
        h.textContent = text;
        h.className = 'post-body__h-promoted';
        p.replaceWith(h);
      });

      var headings = Array.from(articleBody.querySelectorAll('h2, h3, h4'));
      var usedIds = {};
      headings.forEach(function (h, i) {
        if (!h.id) {
          var base = slugify(h.textContent) || 'seccion-' + (i + 1);
          var id = base;
          var n = 2;
          while (usedIds[id] || document.getElementById(id)) {
            id = base + '-' + n++;
          }
          h.id = id;
        }
        usedIds[h.id] = true;
      });

      var postLayout = document.querySelector('.post-layout');
      if (headings.length === 0) {
        if (tocList) tocList.hidden = true;
        if (tocEmpty) tocEmpty.hidden = false;
        if (mobileTocBtn) mobileTocBtn.style.display = 'none';
        if (postLayout) postLayout.classList.add('post-layout--no-toc');
        // Still keep progress bar functional
      }

      function buildLink(h, i, isMobile) {
        var level = h.tagName.toLowerCase();
        var a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent || '';
        a.className = 'toc-link toc-link--' + level;
        a.dataset.index = String(i);
        a.addEventListener('click', function (e) {
          e.preventDefault();
          var target = document.getElementById(h.id);
          if (!target) return;
          var top = target.getBoundingClientRect().top + window.scrollY - 96;
          window.scrollTo({ top: top, behavior: 'smooth' });
          history.replaceState(null, '', '#' + h.id);
          if (isMobile) closeDrawer();
        });
        return a;
      }

      headings.forEach(function (h, i) {
        if (tocList) tocList.appendChild(buildLink(h, i, false));
        if (mobileTocList) mobileTocList.appendChild(buildLink(h, i, true));
      });

      // Toggle collapse
      var expanded = true;
      if (tocToggle && tocList) {
        tocToggle.addEventListener('click', function () {
          expanded = !expanded;
          tocList.style.display = expanded ? '' : 'none';
          tocToggle.setAttribute('aria-expanded', String(expanded));
        });
      }

      // Active heading via IntersectionObserver
      var activeIndex = -1;
      function setActive(idx) {
        if (idx === activeIndex) return;
        activeIndex = idx;
        [tocList, mobileTocList].forEach(function (list) {
          if (!list) return;
          var items = list.querySelectorAll('.toc-link');
          items.forEach(function (item, i) {
            item.classList.toggle('toc-link--active', i === idx);
          });
          // Scroll the active item into view within the TOC list
          var activeItem = items[idx];
          if (activeItem && list.scrollHeight > list.clientHeight) {
            var itemTop = activeItem.offsetTop;
            var itemBottom = itemTop + activeItem.offsetHeight;
            var listTop = list.scrollTop;
            var listBottom = listTop + list.clientHeight;
            if (itemTop < listTop + 40) {
              list.scrollTop = Math.max(0, itemTop - 40);
            } else if (itemBottom > listBottom - 40) {
              list.scrollTop = itemBottom - list.clientHeight + 40;
            }
          }
        });
      }

      if (headings.length > 0 && 'IntersectionObserver' in window) {
        var visible = new Set();
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) visible.add(entry.target);
            else visible.delete(entry.target);
          });
          if (visible.size > 0) {
            var topmost = -1;
            var topY = Infinity;
            headings.forEach(function (h, i) {
              if (visible.has(h)) {
                var y = h.getBoundingClientRect().top;
                if (y < topY) { topY = y; topmost = i; }
              }
            });
            if (topmost !== -1) setActive(topmost);
          } else {
            // Fall back: highlight nearest heading above viewport top
            var best = -1;
            for (var i = 0; i < headings.length; i++) {
              if (headings[i].getBoundingClientRect().top - 120 <= 0) best = i;
              else break;
            }
            if (best !== -1) setActive(best);
          }
        }, { rootMargin: '-96px 0px -60% 0px', threshold: [0, 1] });
        headings.forEach(function (h) { io.observe(h); });
      }

      // Reading progress
      function onScroll() {
        var rect = articleBody.getBoundingClientRect();
        var articleTop = rect.top + window.scrollY;
        var articleHeight = articleBody.offsetHeight;
        var vh = window.innerHeight;
        var scrollY = window.scrollY;
        var raw = (scrollY - articleTop + vh * 0.35) / Math.max(articleHeight - vh * 0.35, 1);
        var progress = Math.min(Math.max(raw, 0), 1);
        var pct = Math.round(progress * 100);
        if (progressBar) progressBar.style.width = pct + '%';
        if (tocProgressBar) tocProgressBar.style.width = pct + '%';
        if (tocProgressText) tocProgressText.textContent = pct + '%';
        if (mobileTocPct) mobileTocPct.textContent = pct + '%';
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      onScroll();

      // Mobile drawer
      function openDrawer() {
        if (!mobileTocOverlay) return;
        mobileTocOverlay.classList.add('is-open');
        mobileTocOverlay.setAttribute('aria-hidden', 'false');
        if (mobileTocBtn) mobileTocBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        if (!mobileTocOverlay) return;
        mobileTocOverlay.classList.remove('is-open');
        mobileTocOverlay.setAttribute('aria-hidden', 'true');
        if (mobileTocBtn) mobileTocBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      if (mobileTocBtn) mobileTocBtn.addEventListener('click', openDrawer);
      if (mobileTocClose) mobileTocClose.addEventListener('click', closeDrawer);
      if (mobileTocBackdrop) mobileTocBackdrop.addEventListener('click', closeDrawer);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDrawer();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
