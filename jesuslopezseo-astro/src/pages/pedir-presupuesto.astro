---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Pedir Presupuesto SEO — JesusLopezSEO"
  description="Solicita tu presupuesto SEO gratuito y sin compromiso. Analizamos tu web y te presentamos un plan personalizado para mejorar tu posicionamiento en Google."
  canonical="https://www.jesuslopezseo.com/pedir-presupuesto"
>
  <Header />
  <main>
    <section class="budget-hero">
      <div class="budget-hero-bg" aria-hidden="true"></div>
      <div class="container budget-hero-inner">
        <div class="budget-hero-text animate-fade-up">
          <div class="section-label">Presupuesto gratuito</div>
          <h1>Solicita tu auditoría<br/><span style="color:var(--primary-dark)">SEO gratuita</span></h1>
          <p>
            Sin coste y sin compromiso. Analizamos tu web, la competencia y te presentamos
            un plan personalizado con lo que necesitas para crecer en Google.
          </p>
          <ul class="budget-perks">
            {['Análisis de posiciones actuales', 'Revisión técnica básica', 'Análisis de competencia', 'Oportunidades de mejora identificadas', 'Propuesta de plan con precios'].map(p => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {p}
              </li>
            ))}
          </ul>
        </div>

        <div class="budget-form-wrap animate-fade-up delay-200">
          <iframe
            id="JotFormIFrame-261082646575059"
            title="Pedir presupuesto - JesusLopezSEO"
            onload="window.parent.scrollTo(0,0)"
            allowtransparency="true"
            allow="geolocation; microphone; camera; fullscreen; payment"
            src="https://form.jotform.com/261082646575059"
            frameborder="0"
            class="jotform-iframe"
            scrolling="no"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
.budget-hero {
  position: relative;
  padding: 5rem 0 6rem;
  overflow: hidden;
}
.budget-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 60% at 100% 0%, rgba(245,158,11,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.budget-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 4rem;
  align-items: start;
}
.budget-hero-text h1 { margin: 0.75rem 0 1rem; }
.budget-hero-text p { font-size: 1.0625rem; color: var(--text-muted); line-height: 1.75; margin-bottom: 2rem; }
.budget-perks { display: flex; flex-direction: column; gap: 0.75rem; }
.budget-perks li { display: flex; align-items: center; gap: 0.625rem; font-size: 0.9375rem; color: var(--text-secondary); }

.budget-form-wrap {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-xl);
  overflow: hidden;
}
.jotform-iframe {
  width: 1px;
  min-width: 100%;
  max-width: 100%;
  height: 820px;
  border: none;
  display: block;
}

@media (max-width: 1024px) {
  .budget-hero-inner { grid-template-columns: 1fr; }
  .budget-hero { padding: 4rem 0 4rem; }
}
@media (max-width: 640px) {
  .jotform-iframe { height: 900px; }
}
</style>

<script is:inline src="https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js"></script>
<script is:inline>
  window.jotformEmbedHandler &&
    window.jotformEmbedHandler("iframe[id='JotFormIFrame-261082646575059']", "https://form.jotform.com/");
</script>
