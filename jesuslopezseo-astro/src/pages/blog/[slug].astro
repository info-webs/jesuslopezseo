---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPostBySlug, getPageContent, getPosts } from '../../lib/notion';
import type { NotionPost } from '../../lib/notion';

const { slug } = Astro.params;

// Fetch the post
let post: NotionPost | null = null;
let content = '';
let relatedPosts: NotionPost[] = [];

try {
  post = await getPostBySlug(slug!);

  if (post) {
    // Fetch content blocks
    content = await getPageContent(post.id, post.slug);

    // Fetch related posts (same category, exclude current)
    const related = await getPosts({ category: post.category, limit: 4 });
    relatedPosts = related.posts.filter(p => p.slug !== slug).slice(0, 3);
  }
} catch (e) {
  console.error('Error fetching post:', e);
}

if (!post) {
  return Astro.redirect('/blog');
}

// Format date helper
function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  } catch {
    return dateStr;
  }
}

function readingTime(wordCount: number): string {
  const mins = Math.max(1, Math.round(wordCount / 200));
  return `${mins} min de lectura`;
}

const catColors: Record<string, string> = {
  'SEO': 'badge-seo',
  'Diseño Web': 'badge-diseno',
  'Marketing Digital': 'badge-marketing',
  'Redes Sociales': 'badge-redes',
  'Noticias': 'badge-noticias',
  'Google': 'badge-google',
};

const breadcrumb = [
  { label: 'Inicio', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: post.category, href: `/blog?categoria=${encodeURIComponent(post.category)}` },
];
---

<Layout
  title={`${post.title} — JesusLopezSEO`}
  description={post.excerpt || post.title}
  canonical={`https://www.jesuslopezseo.com/blog/${post.slug}`}
>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <div class="container">
        <nav aria-label="Breadcrumb" class="breadcrumb">
          {breadcrumb.map((item, i) => (
            <>
              {i > 0 && <span class="breadcrumb-sep">/</span>}
              <a href={item.href} class="breadcrumb-link">{item.label}</a>
            </>
          ))}
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-current">{post.title}</span>
        </nav>
      </div>
    </div>

    <!-- Article -->
    <article class="post-wrap">
      <div class="container post-layout">

        <!-- Main content -->
        <div class="post-main">

          <!-- Header -->
          <header class="post-header">
            <div class="post-header-meta">
              <a
                href={`/blog?categoria=${encodeURIComponent(post.category)}`}
                class={`post-badge ${catColors[post.category] || 'badge-default'}`}
              >
                {post.category}
              </a>
              <span class="post-reading-time">{readingTime(post.wordCount)}</span>
            </div>

            <h1 class="post-title">{post.title}</h1>

            {post.excerpt && (
              <p class="post-excerpt">{post.excerpt}</p>
            )}

            <div class="post-byline">
              <div class="byline-author">
                <div class="author-avatar">{post.author.charAt(0).toUpperCase()}</div>
                <div>
                  <span class="author-name">{post.author}</span>
                  {post.publishedDate && (
                    <time datetime={post.publishedDate} class="post-date">
                      {formatDate(post.publishedDate)}
                    </time>
                  )}
                </div>
              </div>
              {post.tags?.length > 0 && (
                <div class="post-tags">
                  {post.tags.map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </header>

          <!-- Divider -->
          <hr class="post-divider"/>

          <!-- Body -->
          {content ? (
            <div class="post-body" set:html={content} />
          ) : (
            <div class="post-body post-body--empty">
              <p>
                Este artículo fue publicado originalmente en:
                <a href={post.originalUrl} target="_blank" rel="noopener">{post.originalUrl}</a>
              </p>
              <p>El contenido completo está disponible en nuestro blog. Estamos migrando todos los artículos a nuestra nueva plataforma.</p>
            </div>
          )}

          <!-- Tags footer -->
          {post.tags?.length > 0 && (
            <div class="post-tags-footer">
              <span class="tags-label">Etiquetas:</span>
              {post.tags.map(tag => (
                <span class="tag tag--lg">#{tag}</span>
              ))}
            </div>
          )}

          <!-- Share -->
          <div class="post-share">
            <span class="share-label">Compartir:</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=https://www.jesuslopezseo.com/blog/${post.slug}`}
              target="_blank"
              rel="noopener"
              class="share-btn"
              aria-label="Compartir en X (Twitter)"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter/X
            </a>
            <a
              href={`https://www.linkedin.com/shareArticle?mini=true&url=https://www.jesuslopezseo.com/blog/${post.slug}&title=${encodeURIComponent(post.title)}`}
              target="_blank"
              rel="noopener"
              class="share-btn"
              aria-label="Compartir en LinkedIn"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>

          <!-- Author box -->
          <div class="author-box">
            <div class="author-box-avatar">JL</div>
            <div class="author-box-content">
              <strong>Jesús López</strong>
              <span>CEO & Consultor SEO en JesusLopezSEO</span>
              <p>
                Apasionado del posicionamiento web con más de 10 años de experiencia
                ayudando a empresas a crecer en Google. Si tienes dudas sobre SEO,
                <a href="/contactar">contáctame directamente</a>.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="post-sidebar">
          <!-- CTA box -->
          <div class="sidebar-box sidebar-cta">
            <div class="sidebar-cta-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </div>
            <h3>¿Necesitas una auditoría SEO?</h3>
            <p>Analizamos tu web y te presentamos un plan personalizado. Sin coste y sin compromiso.</p>
            <a href="/pedir-presupuesto" class="btn btn-primary" style="width:100%;justify-content:center;">Solicitar gratis</a>
          </div>

          <!-- Related posts -->
          {relatedPosts.length > 0 && (
            <div class="sidebar-box">
              <h4 class="sidebar-title">Artículos relacionados</h4>
              <div class="related-list">
                {relatedPosts.map(rp => (
                  <a href={`/blog/${rp.slug}`} class="related-item">
                    <span class="related-cat">{rp.category}</span>
                    <span class="related-title">{rp.title}</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Contact box -->
          <div class="sidebar-box sidebar-contact">
            <h4 class="sidebar-title">Contacta con nosotros</h4>
            <a href="tel:+34618015995" class="contact-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              618 015 995
            </a>
            <a href="mailto:jesus@jesuslopezseo.com" class="contact-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              jesus@jesuslopezseo.com
            </a>
          </div>
        </aside>

      </div>
    </article>

    <!-- Related posts full section -->
    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="container">
          <div class="section-label">Sigue leyendo</div>
          <h2>Más artículos de <span class="serif">{post.category}</span></h2>
          <div class="related-grid">
            {relatedPosts.map(rp => (
              <a href={`/blog/${rp.slug}`} class="related-card">
                <span class={`post-badge ${catColors[rp.category] || 'badge-default'}`}>{rp.category}</span>
                <h3>{rp.title}</h3>
                {rp.excerpt && <p>{rp.excerpt}</p>}
                <span class="read-more">Leer artículo →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
/* Breadcrumb */
.breadcrumb-bar {
  border-bottom: 1px solid var(--surface-border);
  background: var(--surface-card);
  padding: 0.75rem 0;
}
.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.25rem;
  font-size: 0.8125rem;
}
.breadcrumb-link { color: var(--text-muted); text-decoration: none; }
.breadcrumb-link:hover { color: var(--primary-dark); }
.breadcrumb-sep { color: var(--text-light); }
.breadcrumb-current {
  color: var(--text-secondary);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240px;
}

/* Layout */
.post-wrap { padding: 4rem 0 6rem; }
.post-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 4rem;
  align-items: start;
}
.post-main { min-width: 0; }

/* Header */
.post-header { margin-bottom: 2rem; }
.post-header-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.post-title {
  font-size: clamp(1.625rem, 3vw, 2.25rem);
  line-height: 1.3;
  margin-bottom: 1rem;
  color: var(--text-primary);
}
.post-excerpt {
  font-size: 1.0625rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}
.post-byline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
}
.byline-author { display: flex; align-items: center; gap: 0.75rem; }
.author-avatar {
  width: 40px; height: 40px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.author-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }
.post-date { display: block; font-size: 0.8125rem; color: var(--text-light); }
.post-reading-time { font-size: 0.8125rem; color: var(--text-light); }

.post-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.tag {
  display: inline-block;
  padding: 0.2rem 0.5rem;
  background: var(--cream-100);
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  color: var(--text-muted);
}
.tag--lg {
  padding: 0.3rem 0.625rem;
  font-size: 0.8125rem;
}

/* Badges */
.post-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  font-weight: 600;
  text-decoration: none;
}
.badge-seo { background: #fef3c7; color: #92400e; }
.badge-diseno { background: #ede9fe; color: #5b21b6; }
.badge-marketing { background: #dcfce7; color: #166534; }
.badge-redes { background: #dbeafe; color: #1e40af; }
.badge-noticias { background: #fce7f3; color: #9d174d; }
.badge-google { background: #fee2e2; color: #991b1b; }
.badge-default { background: var(--cream-100); color: var(--text-muted); }

/* Divider */
.post-divider { border: none; border-top: 1px solid var(--surface-border); margin: 2rem 0; }

/* Body */
.post-body {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--text-secondary);
}
.post-body h2 {
  font-size: 1.5rem;
  color: var(--text-primary);
  margin: 2.5rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--amber-100);
}
.post-body h3 { font-size: 1.25rem; color: var(--text-primary); margin: 2rem 0 0.75rem; }
.post-body h4 { font-size: 1.0625rem; color: var(--text-primary); margin: 1.5rem 0 0.5rem; }
.post-body p { margin-bottom: 1.25rem; }
.post-body ul, .post-body ol { margin: 1rem 0 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.375rem; }
.post-body li { line-height: 1.7; }
.post-body a { color: var(--primary-dark); text-decoration: underline; }
.post-body a:hover { color: var(--primary); }
.post-body blockquote {
  border-left: 3px solid var(--primary);
  padding: 0.75rem 1.25rem;
  margin: 1.5rem 0;
  background: var(--amber-50);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  color: var(--text-secondary);
  font-style: italic;
}
.post-body pre {
  background: #1a1814;
  border-radius: var(--radius-md);
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.post-body code {
  font-family: 'Courier New', monospace;
  font-size: 0.875rem;
  color: #f59e0b;
}
.post-body figure { margin: 1.75rem 0; }
.post-body img { width: 100%; border-radius: var(--radius-md); }
.post-body figcaption { font-size: 0.8125rem; color: var(--text-light); text-align: center; margin-top: 0.5rem; }
.post-body hr { border: none; border-top: 1px solid var(--surface-border); margin: 2rem 0; }

.post-body--empty {
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-lg);
  padding: 2rem;
}
.post-body--empty a { color: var(--primary-dark); }

/* Tags footer */
.post-tags-footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--surface-border);
}
.tags-label { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }

/* Share */
.post-share {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 1.5rem;
}
.share-label { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 150ms;
}
.share-btn:hover { border-color: var(--amber-200); color: var(--primary-dark); background: var(--amber-50); }

/* Author box */
.author-box {
  display: flex;
  gap: 1.25rem;
  padding: 1.75rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-xl);
  margin-top: 2rem;
}
.author-box-avatar {
  flex-shrink: 0;
  width: 56px; height: 56px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800;
  font-size: 1.125rem;
  color: #fff;
}
.author-box-content strong { display: block; font-size: 1rem; color: var(--text-primary); margin-bottom: 0.1rem; }
.author-box-content span { display: block; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 0.5rem; }
.author-box-content p { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }
.author-box-content a { color: var(--primary-dark); text-decoration: underline; }

/* Sidebar */
.post-sidebar { position: sticky; top: 6rem; display: flex; flex-direction: column; gap: 1.25rem; }
.sidebar-box {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  padding: 1.5rem;
}
.sidebar-title { font-size: 0.9375rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary); }

.sidebar-cta { background: linear-gradient(135deg, var(--amber-50), #fff); border-color: var(--amber-200); }
.sidebar-cta-icon {
  width: 44px; height: 44px;
  background: var(--primary);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  margin-bottom: 0.875rem;
}
.sidebar-cta h3 { font-size: 1rem; margin-bottom: 0.5rem; }
.sidebar-cta p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }

.related-list { display: flex; flex-direction: column; gap: 0.75rem; }
.related-item {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  text-decoration: none;
  padding: 0.75rem;
  border-radius: var(--radius-md);
  background: var(--cream-50);
  border: 1px solid var(--surface-border);
  transition: all 150ms;
}
.related-item:hover { border-color: var(--amber-200); background: var(--amber-50); }
.related-cat { font-size: 0.6875rem; font-weight: 700; color: var(--primary-dark); text-transform: uppercase; letter-spacing: 0.05em; }
.related-title { font-size: 0.875rem; font-weight: 600; color: var(--text-primary); line-height: 1.4; }

.sidebar-contact { display: flex; flex-direction: column; gap: 0.625rem; }
.contact-item {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.625rem 0.875rem;
  background: var(--cream-50);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  font-size: 0.8125rem;
  color: var(--text-secondary);
  text-decoration: none;
  font-weight: 500;
  transition: all 150ms;
}
.contact-item:hover { border-color: var(--amber-200); color: var(--primary-dark); background: var(--amber-50); }

/* Related section */
.related-section {
  padding: 5rem 0 6rem;
  background: var(--surface-subtle);
}
.related-section h2 { margin: 0.5rem 0 2.5rem; }
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.related-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.5rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  text-decoration: none;
  transition: all var(--transition-base);
}
.related-card:hover {
  border-color: var(--amber-200);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.related-card h3 { font-size: 1rem; color: var(--text-primary); line-height: 1.45; margin: 0; }
.related-card p {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.read-more { font-size: 0.875rem; font-weight: 600; color: var(--primary-dark); margin-top: auto; }

/* Responsive */
@media (max-width: 1024px) {
  .post-layout { grid-template-columns: 1fr; }
  .post-sidebar { position: static; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .post-wrap { padding: 2rem 0 4rem; }
  .related-grid { grid-template-columns: 1fr; }
  .post-byline { flex-direction: column; align-items: flex-start; }
}
</style>
