---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const canonical = 'https://www.jesuslopezseo.com/servicios/posicionamiento-geo-salamanca';
const title = 'Posicionamiento GEO en Salamanca — Aparece en ChatGPT, Perplexity y Google AI';
const description = 'Consultor GEO en Salamanca especializado en que ChatGPT, Perplexity, Gemini y Google AI citen tu negocio. Estrategia, medición real con LLMFY y autoridad semántica. 18 años de SEO + la primera plataforma española de optimización para IA.';

// Schema.org - Service + FAQ
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Posicionamiento GEO · Generative Engine Optimization",
      "provider": {
        "@type": "LocalBusiness",
        "name": "JesusLopezSEO",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Calle Cortinas 14",
          "addressLocality": "Salamanca",
          "addressRegion": "Castilla y León",
          "postalCode": "37001",
          "addressCountry": "ES"
        },
        "telephone": "+34618015995",
        "email": "jesus@jesuslopezseo.com",
        "url": "https://www.jesuslopezseo.com"
      },
      "areaServed": [
        { "@type": "City", "name": "Salamanca" },
        { "@type": "AdministrativeArea", "name": "Castilla y León" },
        { "@type": "Country", "name": "España" }
      ],
      "name": "Posicionamiento GEO en Salamanca",
      "description": "Servicio especializado de optimización para motores generativos (ChatGPT, Perplexity, Gemini, Google AI Overviews) con medición real mediante LLMFY.ai.",
      "url": canonical
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué es el posicionamiento GEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "GEO (Generative Engine Optimization) es la disciplina de optimizar una web para que los motores generativos de IA (ChatGPT, Perplexity, Gemini, Claude, Google AI Overviews) citen tu contenido como fuente autoritativa. A diferencia del SEO clásico que busca posicionar URLs en listas, el GEO busca ser la respuesta directa que la IA entrega al usuario."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es lo mismo GEO que SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Comparten fundamentos (autoridad, E-E-A-T, datos estructurados) pero los pesos cambian. En GEO pesan más las co-citaciones, la claridad semántica a nivel frase, la entidad de marca y las menciones en fuentes que los LLMs consideran autoritativas. Lo llamo 'mismos factores, distintos pesos'."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede medir si ChatGPT o Perplexity citan mi marca?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Para eso construí LLMFY.ai, la plataforma de LLMO (optimización para LLMs) que monitoriza menciones y citaciones en ChatGPT, Perplexity, Gemini y Claude sobre más de cien consultas por marca y detecta exactamente qué contenido se cita y cuál no. Sin medición no hay estrategia."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en verse resultado?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los primeros movimientos en AI Overviews de Google se ven en 4-8 semanas. Las citaciones en ChatGPT y Perplexity dependen del ciclo de entrenamiento e indexación de cada modelo: habitualmente entre 2 y 4 meses desde que se publica el contenido optimizado y llegan las primeras señales de autoridad."
          }
        },
        {
          "@type": "Question",
          "name": "¿Por qué un consultor GEO en Salamanca y no una agencia grande?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Porque el GEO es tan nuevo que las agencias grandes aún están aprendiendo a venderlo. Yo llevo 18 años en SEO, he creado LLMFY.ai (una de las primeras plataformas españolas de LLMO) y trabajo directamente con el cliente sin intermediarios. Resultado: decisiones técnicas más rápidas y criterio real sobre qué funciona y qué es humo."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.jesuslopezseo.com" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://www.jesuslopezseo.com/#servicios" },
        { "@type": "ListItem", "position": 3, "name": "Posicionamiento GEO Salamanca", "item": canonical }
      ]
    }
  ]
});
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogType="website"
  schema={schema}
>
  <Header />

  <main class="geo-page">

    <!-- ═══════════ HERO ═══════════ -->
    <section class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="container hero-inner">
        <div class="hero-eyebrow">
          <span class="live-dot"></span>
          <span>GEO · Generative Engine Optimization</span>
        </div>

        <h1 class="hero-title">
          Que <span class="underline-accent">ChatGPT</span>,
          <span class="underline-accent">Perplexity</span> y
          <span class="underline-accent">Google&nbsp;AI</span><br/>
          citen <em class="italic-hi">tu negocio</em>,<br/>
          no a tu competencia.
        </h1>

        <p class="hero-lead">
          Posicionamiento GEO en Salamanca para empresas que ya no compiten por
          posiciones — compiten por <strong>ser la respuesta</strong>.
          Estrategia, medición real con <a href="https://llmfy.ai" target="_blank" rel="noopener" class="link-ghost">LLMFY.ai</a>
          y autoridad semántica construida sobre 18 años de SEO serio.
        </p>

        <div class="hero-cta">
          <a href="/pedir-presupuesto" class="btn-xl">
            Solicitar auditoría GEO
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#como-funciona" class="btn-xl btn-xl--ghost">
            Cómo funciona
          </a>
        </div>

        <div class="hero-proof">
          <div class="proof-item">
            <div class="proof-num">18<span class="proof-unit">años</span></div>
            <div class="proof-label">en SEO desde 2007</div>
          </div>
          <div class="proof-sep"></div>
          <div class="proof-item">
            <div class="proof-num">LLMFY<span class="proof-unit">.ai</span></div>
            <div class="proof-label">plataforma propia de LLMO</div>
          </div>
          <div class="proof-sep"></div>
          <div class="proof-item">
            <div class="proof-num">#1<span class="proof-unit"></span></div>
            <div class="proof-label">consultor SEO Salamanca</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ PROBLEM ═══════════ -->
    <section class="problem section-pad">
      <div class="container">
        <div class="pill pill--amber">El problema</div>
        <h2 class="h-display">
          Tu web aparece en Google.<br/>
          <span class="text-muted">Pero <em>no aparece</em> donde tus clientes están preguntando ahora.</span>
        </h2>

        <div class="problem-grid">
          <div class="problem-card">
            <div class="problem-num">01</div>
            <h3>Perdiste el <em>zero-click</em></h3>
            <p>El 58&nbsp;% de las búsquedas en Google terminan sin clic desde que llegaron los AI Overviews. Si no estás citado en el resumen, no existes — aunque tu web posicione primera.</p>
          </div>
          <div class="problem-card">
            <div class="problem-num">02</div>
            <h3>ChatGPT ya es el nuevo buscador</h3>
            <p>Más de 400&nbsp;M de usuarios semanales preguntan a ChatGPT antes que a Google. Si el modelo no te conoce como referente en tu sector, tu competencia se está llevando esas preguntas.</p>
          </div>
          <div class="problem-card">
            <div class="problem-num">03</div>
            <h3>Perplexity cita fuentes — y no eres tú</h3>
            <p>Perplexity y Gemini muestran las fuentes que respaldan cada respuesta. Estar ahí significa <strong>tráfico cualificado</strong> que ya confía en ti. No estarlo significa que otro se lo queda.</p>
          </div>
          <div class="problem-card">
            <div class="problem-num">04</div>
            <h3>Nadie te mide esto</h3>
            <p>Tu agencia te enseña ranking en Google. Pero, ¿cuántas veces te citó ChatGPT este mes? ¿Con qué contexto? ¿Frente a qué competidor? Sin medición, no hay estrategia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ COMO FUNCIONA ═══════════ -->
    <section class="how section-pad section-pad--dark" id="como-funciona">
      <div class="container">
        <div class="pill pill--mint">Metodología propia</div>
        <h2 class="h-display h-display--light">
          <em>Same factors,</em><br/>different&nbsp;weights.
        </h2>
        <p class="section-lead section-lead--light">
          Framework original desarrollado junto con <a href="https://llmfy.ai" target="_blank" rel="noopener" class="link-accent">LLMFY.ai</a>.
          El GEO comparte fundamentos con el SEO — pero los motores generativos ponderan las señales
          de forma radicalmente distinta. Esto es lo que cambia:
        </p>

        <div class="matrix">
          <div class="matrix-row matrix-row--head">
            <div class="matrix-cell">Señal</div>
            <div class="matrix-cell matrix-cell--num">Peso en SEO</div>
            <div class="matrix-cell matrix-cell--num">Peso en GEO</div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Backlinks clásicos</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5"></span><span class="num">Alto</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-2"></span><span class="num">Bajo</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Co-citaciones de marca <span class="tag-new">AI&nbsp;Building</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-2"></span><span class="num">Bajo</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5 bar-accent"></span><span class="num">Crítico</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Datos estructurados (Schema)</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-3"></span><span class="num">Medio</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5"></span><span class="num">Alto</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Claridad semántica por frase</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-2"></span><span class="num">Bajo</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5 bar-accent"></span><span class="num">Crítico</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Autoría real &amp; E-E-A-T</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-4"></span><span class="num">Alto</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5 bar-accent"></span><span class="num">Crítico</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Velocidad de carga</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-4"></span><span class="num">Alto</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-2"></span><span class="num">Bajo</span></div>
          </div>
          <div class="matrix-row">
            <div class="matrix-cell">Entidad de marca (Wikipedia, Wikidata, prensa)</div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-3"></span><span class="num">Medio</span></div>
            <div class="matrix-cell matrix-cell--num"><span class="bar bar-5 bar-accent"></span><span class="num">Crítico</span></div>
          </div>
        </div>

        <p class="matrix-caption">
          Las señales marcadas en <span class="dot-accent"></span> son donde se gana o se pierde el GEO.
          Trabajar solo las primeras tres — como hacen la mayoría de agencias — es posicionar para un juego
          que ya no existe.
        </p>
      </div>
    </section>

    <!-- ═══════════ LLMFY FEATURE ═══════════ -->
    <section class="llmfy section-pad">
      <div class="container">
        <div class="llmfy-layout">
          <div class="llmfy-content">
            <div class="pill pill--black">Nuestra ventaja</div>
            <h2 class="h-display">
              Soy el único consultor GEO en Salamanca que<br/>
              <em class="italic-hi">construyó su propia herramienta.</em>
            </h2>
            <p class="llmfy-lead">
              <a href="https://llmfy.ai" target="_blank" rel="noopener" class="link-ghost"><strong>LLMFY.ai</strong></a>
              es la plataforma que desarrollé desde cero para medir, diagnosticar y optimizar la visibilidad
              en motores generativos. No es un SaaS comprado: es una herramienta que uso a diario para mis
              propios clientes — y te la aplico a ti desde el día uno.
            </p>

            <ul class="llmfy-features">
              <li>
                <div class="lf-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
                </div>
                <div>
                  <strong>LLM Tracking</strong>
                  <span>Monitoriza si ChatGPT, Perplexity, Claude y Gemini te mencionan — y cómo te comparan con tus competidores en las consultas que importan a tu negocio.</span>
                </div>
              </li>
              <li>
                <div class="lf-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v6m0 8v6M4.93 4.93l4.24 4.24m5.66 5.66 4.24 4.24M2 12h6m8 0h6M4.93 19.07l4.24-4.24m5.66-5.66 4.24-4.24"/></svg>
                </div>
                <div>
                  <strong>E-E-A-T Audit</strong>
                  <span>Auditoría con Claude (Anthropic) de los 23 factores que los LLMs usan para decidir si eres una fuente citable. Informe específico por URL.</span>
                </div>
              </li>
              <li>
                <div class="lf-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                </div>
                <div>
                  <strong>AI Building</strong>
                  <span>Nuestro concepto original: las co-citaciones en LLMs son el nuevo link building. Identificamos las fuentes desde las que los modelos aprenden en tu sector y trabajamos para que te mencionen.</span>
                </div>
              </li>
              <li>
                <div class="lf-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong>Brand Sentiment</strong>
                  <span>Análisis profundo del sentimiento con que las IAs hablan de tu marca. Porque que te mencionen no sirve si te pintan como la peor opción del mercado.</span>
                </div>
              </li>
            </ul>

            <a href="https://llmfy.ai" target="_blank" rel="noopener" class="btn-xl btn-xl--outline">
              Ver LLMFY.ai
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M8 7h9v9"/></svg>
            </a>
          </div>

          <div class="llmfy-visual" aria-hidden="true">
            <div class="llmfy-terminal">
              <div class="term-head">
                <span class="term-dot"></span>
                <span class="term-dot"></span>
                <span class="term-dot"></span>
                <span class="term-title">llmfy.ai — brand tracker</span>
              </div>
              <div class="term-body">
                <div class="term-line"><span class="term-prompt">›</span> <span class="term-cmd">track</span> <span class="term-str">"consultor seo salamanca"</span></div>
                <div class="term-line term-out">→ Analizando en 4 modelos…</div>
                <div class="term-result">
                  <div class="term-row">
                    <span class="term-model">ChatGPT</span>
                    <span class="term-badge term-badge--good">Citado #1</span>
                  </div>
                  <div class="term-row">
                    <span class="term-model">Perplexity</span>
                    <span class="term-badge term-badge--good">Citado #2</span>
                  </div>
                  <div class="term-row">
                    <span class="term-model">Claude</span>
                    <span class="term-badge term-badge--good">Citado #1</span>
                  </div>
                  <div class="term-row">
                    <span class="term-model">Gemini</span>
                    <span class="term-badge term-badge--warn">No citado</span>
                  </div>
                </div>
                <div class="term-line term-out">→ Sentimiento: <span class="term-good">positivo · experto local · 18 años</span></div>
                <div class="term-line term-out">→ Co-citaciones con: LLMFY, Anthropic, Salamanca</div>
                <div class="term-line"><span class="term-prompt">›</span> <span class="term-cursor">▊</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ METODOLOGIA / PROCESO ═══════════ -->
    <section class="process section-pad">
      <div class="container">
        <div class="pill pill--amber">Proceso en 4 fases</div>
        <h2 class="h-display">Así trabajamos tu GEO.</h2>
        <p class="section-lead">
          Sin paquetes cerrados. Sin humo. Sin &laquo;aparecer en ChatGPT en 24 horas&raquo;.
          El trabajo real de GEO es diagnóstico, construcción de autoridad y medición continua.
        </p>

        <ol class="steps">
          <li class="step">
            <div class="step-num">01</div>
            <div class="step-body">
              <h3>Diagnóstico GEO inicial</h3>
              <p>
                Auditoría completa en <a href="https://llmfy.ai" target="_blank" rel="noopener">LLMFY.ai</a>:
                mapeamos dónde te citan hoy los LLMs, dónde no, qué dicen de ti y cómo te comparan con tus
                tres competidores directos. Incluye E-E-A-T audit técnico de tu web con Claude.
              </p>
              <div class="step-tag">Semana 1</div>
            </div>
          </li>
          <li class="step">
            <div class="step-num">02</div>
            <div class="step-body">
              <h3>Arquitectura semántica y schema</h3>
              <p>
                Rediseño de la estructura de contenidos para responder a consultas conversacionales.
                Implementación quirúrgica de Schema.org — Organization, Person, Service, FAQ, HowTo —
                para que las IAs entiendan qué eres, qué haces y por qué eres la opción.
              </p>
              <div class="step-tag">Semanas 2–4</div>
            </div>
          </li>
          <li class="step">
            <div class="step-num">03</div>
            <div class="step-body">
              <h3>Construcción de autoridad &amp; AI Building</h3>
              <p>
                Identificamos las fuentes desde donde los LLMs aprenden en tu sector (prensa sectorial,
                Wikipedia, podcasts, foros citados por modelos) y trabajamos para que te mencionen en esos
                contextos. Es link building — pero para modelos.
              </p>
              <div class="step-tag">Mes 2 en adelante</div>
            </div>
          </li>
          <li class="step">
            <div class="step-num">04</div>
            <div class="step-body">
              <h3>Medición continua y ajuste</h3>
              <p>
                Reporte mensual directo desde LLMFY: citaciones por modelo, sentimiento, posición
                competitiva y recomendación concreta para el siguiente mes. Sabrás exactamente qué funciona
                y qué hay que ajustar — sin interpretaciones ambiguas.
              </p>
              <div class="step-tag">Continuo</div>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ═══════════ PARA QUIEN / SECTORES SALAMANCA ═══════════ -->
    <section class="sectors section-pad section-pad--cream">
      <div class="container">
        <div class="pill pill--amber">GEO en Salamanca</div>
        <h2 class="h-display">
          Si vendes en Salamanca<br/>y tus clientes ya <em>preguntan a la IA</em>…
        </h2>
        <p class="section-lead">
          El GEO no es solo para grandes marcas. Cualquier negocio salmantino cuyos clientes consulten a
          ChatGPT, Perplexity o Gemini antes de decidir, se está quedando fuera si no lo trabaja.
          Estos son los sectores donde más impacto hemos visto en los últimos meses:
        </p>

        <div class="sector-grid">
          <div class="sector-card">
            <div class="sector-tag">Clínicas &amp; salud</div>
            <p>Dentistas, clínicas estéticas, fisioterapeutas, psicólogos — los pacientes consultan síntomas y opciones de clínica directamente a ChatGPT antes de pedir cita.</p>
          </div>
          <div class="sector-card">
            <div class="sector-tag">Despachos profesionales</div>
            <p>Abogados, peritos, asesorías, arquitectos — la IA ya responde a consultas de &laquo;mejor abogado laboralista en Salamanca&raquo; citando despachos concretos.</p>
          </div>
          <div class="sector-card">
            <div class="sector-tag">Hostelería &amp; turismo</div>
            <p>Hoteles, restaurantes, experiencias — los viajeros planifican viajes a Salamanca pidiendo recomendaciones a la IA. Aparece, o desapareces del itinerario.</p>
          </div>
          <div class="sector-card">
            <div class="sector-tag">Academias &amp; formación</div>
            <p>Entorno universitario, academias de idiomas, formación profesional — los estudiantes y sus familias ya usan la IA como primer filtro para comparar opciones.</p>
          </div>
          <div class="sector-card">
            <div class="sector-tag">Reformas &amp; construcción</div>
            <p>Empresas locales cuyos clientes preguntan a la IA &laquo;qué debo tener en cuenta al contratar una reforma&raquo; — y las respuestas citan nombres de empresas reales.</p>
          </div>
          <div class="sector-card">
            <div class="sector-tag">E-commerce de nicho</div>
            <p>Tiendas online salmantinas con producto especializado — los compradores comparan opciones con Perplexity antes de comprar. Quien está citado, vende.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ DIFERENCIA ═══════════ -->
    <section class="difference section-pad">
      <div class="container">
        <div class="pill pill--amber">Por qué yo</div>
        <h2 class="h-display">
          No soy una agencia.<br/>
          <em>Soy quien construyó la herramienta.</em>
        </h2>

        <div class="diff-compare">
          <div class="diff-col diff-col--other">
            <div class="diff-head">Agencias &laquo;que hacen GEO&raquo;</div>
            <ul>
              <li>Reempaquetan SEO clásico y lo llaman GEO</li>
              <li>No miden citaciones en LLMs — solo rankings de Google</li>
