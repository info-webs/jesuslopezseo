---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const features = [
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`, title: 'Keyword research para apps', desc: 'Investigación de palabras clave con mayor volumen de búsqueda en Google Play y App Store.' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>`, title: 'Optimización del título y descripción', desc: 'Redactamos títulos y descripciones optimizadas que posicionan y convencen al usuario de descargar.' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`, title: 'Optimización visual', desc: 'Screenshots, iconos y vídeos promocionales que maximizan la tasa de conversión en tienda.' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`, title: 'Estrategia de valoraciones', desc: 'Mejoramos la tasa y calidad de las reseñas para aumentar la credibilidad de tu aplicación.' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>`, title: 'Seguimiento de posiciones', desc: 'Monitorizamos el ranking de tu app para las keywords objetivo y ajustamos la estrategia.' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`, title: 'Análisis de la competencia', desc: 'Estudiamos las apps competidoras para encontrar oportunidades de diferenciación y posicionamiento.' },
];

const benefits = [
  'Estrategia ASO adaptada a Google Play y App Store',
  'Aumento orgánico de visibilidad y descargas sin pagar publicidad',
  'Mejora de la conversión de ficha de producto a descarga',
  'Seguimiento continuo y ajuste de la estrategia',
  'Informes mensuales con evolución de posiciones y descargas',
  'Experiencia en apps de múltiples categorías y sectores',
];

const faq = [
  { q: '¿El ASO funciona igual en Google Play y App Store?', a: 'Los principios son similares pero cada tienda tiene sus propios factores de posicionamiento. Google Play tiene más peso al texto indexado mientras que App Store prioriza el título y el campo de keywords. Optimizamos para cada plataforma específicamente.' },
  { q: '¿Cuánto tarda en verse resultados?', a: 'Los primeros resultados de mejora de visibilidad suelen verse en 4-8 semanas. El crecimiento en descargas orgánicas es progresivo y se consolida con el tiempo, especialmente al mejorar también las valoraciones.' },
];
---
<ServiceLayout
  title="Posicionamiento ASO Salamanca"
  metaTitle="Posicionamiento ASO en Salamanca — JesusLopezSEO"
  metaDescription="Servicio de posicionamiento ASO en Salamanca. Optimizamos tu app para Google Play y App Store para conseguir más descargas orgánicas."
  canonical="https://www.jesuslopezseo.com/servicios/posicionamiento-aso"
  hero={{
    badge: 'App Store Optimization',
    headline: '<em>Posicionamiento ASO</em><br/>más descargas para tu app en Salamanca',
    description: 'Conseguir descargas en una tienda de aplicaciones es complicado sin una buena estrategia ASO. Planificamos y ejecutamos las acciones para que tu app aparezca en los primeros lugares de Google Play y App Store.',
    cta: 'Solicitar presupuesto ASO',
  }}
  heroVisual="aso"
  features={features}
  benefits={benefits}
  faq={faq}
>
  <div></div>
</ServiceLayout>
<style>
.hero-highlight { color: var(--primary-dark); }
</style>
