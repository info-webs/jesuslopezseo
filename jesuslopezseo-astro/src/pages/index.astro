---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fihll="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Posicionamiento SEO',
    desc: 'Analizamos la competencia, optimizamos tu web y construimos autoridad con link building de calidad para posicionarte en los primeros resultados de Google.',
    href: '/posicionamiento-web',
    badge: 'Servicio principal',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Diseño Web',
    desc: 'Webs profesionales, autogestionables, adaptadas a todos los dispositivos y optimizadas para vender. Diseños que convierten visitantes en clientes.',
    href: '/servicios/diseno-web',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Community Manager',
    desc: 'Estrategia de redes sociales, creación de contenido diario e interacción con tu comunidad para impulsar tu marca en todas las plataformas.',
    href: '/servicios/community-manager',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Redacción de contenido',
    desc: 'Contenido 100% original, optimizado para SEO y adaptado a tu audiencia. Posts, notas de prensa, fichas de producto y páginas de servicio.',
    href: '/servicios/redaccion-contenido',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>`,
    title: 'Diseño gráfico',
    desc: 'Identidad visual, logotipos, materiales publicitarios y conceptos visuales que refuerzan el branding y diferencias tu marca de la competencia.',
    href: '/servicios/diseno-grafico',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: 'Posicionamiento ASO',
    desc: 'Optimizamos tu app para aparecer en los primeros resultados de Google Play y App Store, aumentando descargas de forma orgánica.',
    href: '/servicios/posicionamiento-aso',
    badge: null,
  },
];

const stats = [
  { value: '+18', label: 'Años de experiencia' },
  { value: '+150', label: 'Clientes satisfechos' },
  { value: '+500', label: 'Proyectos completados' },
  { value: '95%', label: 'Tasa de retención' },
];

const processSteps = [
  { num: '01', title: 'Auditoría gratuita', desc: 'Analizamos tu web y la competencia sin coste y sin compromiso para entender el punto de partida.' },
  { num: '02', title: 'Estrategia SEO', desc: 'Diseñamos un plan personalizado con objetivos claros, palabras clave y acciones priorizadas.' },
  { num: '03', title: 'Ejecución', desc: 'Implementamos las acciones on-page, off-page y técnicas con total transparencia.' },
  { num: '04', title: 'Resultados & reporting', desc: 'Informes mensuales con métricas reales: posiciones, tráfico, conversiones y ROI.' },
];
---

<Layout
  title="JesusLopezSEO — Consultor SEO en Salamanca | Posicionamiento Web"
  description="Jesús López, Consultor SEO experto en Salamanca. Posicionamiento web, diseño web y marketing digital para empresas que quieren crecer en Google."
>
  <Header />

  <main>

    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container hero-inner">

        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="live-dot"></span>
            Consultor SEO · Salamanca · 18 años
          </div>

          <h1 class="hero-title">
            Que Google y la IA<br/>
            <span class="hero-accent">recomienden</span><br/>
            <em class="hero-italic">tu negocio</em>.
          </h1>

          <p class="hero-desc">
            Posicionamiento <strong>SEO + GEO</strong> para empresas que quieren aparecer donde sus clientes ya están buscando: en Google, en ChatGPT, en Perplexity, en Gemini. Con medición real vía <a href="https://llmfy.ai" target="_blank" rel="noopener" class="hero-link">LLMFY.ai</a>.
          </p>

          <div class="hero-actions">
            <a href="/pedir-presupuesto" class="btn-hero">
              Pedir presupuesto gratis
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#servicios" class="btn-hero btn-hero--ghost">Ver servicios</a>
          </div>

          <div class="hero-proof-row">
            <div class="proof-cell">
              <div class="proof-val">+150</div>
              <div class="proof-cap">clientes</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val">#1</div>
              <div class="proof-cap">SEO Salamanca</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val">+340%</div>
              <div class="proof-cap">tráfico</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val proof-val--brand">LLMFY</div>
              <div class="proof-cap">herramienta propia</div>
            </div>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="hero-card hero-card--main">
            <div class="hcard-header">
              <span class="hcard-dot green"></span>
              <span class="hcard-dot amber"></span>
              <span class="hcard-dot red"></span>
              <span class="hcard-label">SEO · Posiciones en Google</span>
            </div>
            <div class="hcard-body">
              {[
                { kw: 'consultor seo salamanca', pos: 1, up: true },
                { kw: 'posicionamiento web salamanca', pos: 2, up: true },
                { kw: 'seo salamanca', pos: 1, up: true },
                { kw: 'diseño web salamanca', pos: 2, up: true },
              ].map(r => (
                <div class="rank-row">
                  <span class={`rank-pos rank-pos--${r.pos <= 1 ? 'gold' : r.pos <= 3 ? 'silver' : 'normal'}`}>#{r.pos}</span>
                  <span class="rank-kw">{r.kw}</span>
                  <span class={`rank-trend ${r.up ? 'up' : 'neutral'}`}>{r.up ? '↑' : '→'}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="hero-card hero-card--ai">
            <div class="hcard-header hcard-header--dark">
              <span class="hcard-dot-mini"></span>
              <span class="hcard-label-dark">GEO · Citaciones en IA</span>
            </div>
            <div class="hcard-body-dark">
              <div class="ai-row">
                <span class="ai-model">ChatGPT</span>
                <span class="ai-badge ai-badge--good">Citado</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Perplexity</span>
                <span class="ai-badge ai-badge--good">Citado</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Claude</span>
                <span class="ai-badge ai-badge--good">Citado</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Gemini</span>
                <span class="ai-badge ai-badge--good">Citado</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══ STATS ═══ -->
    <section class="stats-bar">
      <div class="container stats-inner">
        {stats.map(s => (
          <div class="stat-item">
            <strong class="stat-num">{s.value}</strong>
            <span class="stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ ABOUT ═══ -->
    <section class="about section-pad">
      <div class="container about-grid">

        <div class="about-visual">
          <div class="about-img-wrap">
            <!-- Placeholder: replace src with real photo -->
            <div class="about-img-placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--text-light)" stroke-width="1"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Foto de Jesús López</span>
            </div>
          </div>
          <div class="about-badge">
            <span class="about-badge-icon">🏆</span>
            <div>
              <strong>+18 años</strong>
              <span>en SEO</span>
            </div>
          </div>
        </div>

        <div class="about-content">
          <div class="section-label">Sobre mí</div>
          <h2>Soy Jesús López, <span class="serif">Consultor SEO</span> y CEO en JesusLopezSEO</h2>
          <p>
            Apasionado del posicionamiento web desde hace más de 18 años. Ayudo a empresas y negocios
            de todo tipo a mejorar su visibilidad en Google y conseguir resultados reales: más tráfico,
            más leads y más ventas.
          </p>
          <p>
            Si tienes una web, blog o tienda online, te conviene estar en la primera página de Google
            por encima de tu competencia. Para eso combino estrategias SEO on-page y off-page,
            manteniéndome al día con cada actualización del algoritmo.
          </p>
          <ul class="about-list">
            <li>
              <span class="list-check">✓</span>
              Auditoría web inicial gratuita y sin compromiso
            </li>
            <li>
              <span class="list-check">✓</span>
              Planes adaptados a cada presupuesto y sector
            </li>
            <li>
              <span class="list-check">✓</span>
              Reporting mensual con métricas reales
            </li>
            <li>
              <span class="list-check">✓</span>
              Equipo multidisciplinar (SEO, diseño, contenidos, RRSS)
            </li>
          </ul>
          <a href="/contactar" class="btn btn-outline">Conoce más sobre mí →</a>
        </div>

      </div>
    </section>

    <!-- ═══ SERVICIOS ═══ -->
    <section class="services section-pad bg-subtle" id="servicios">
      <div class="container">
        <div class="section-header text-center">
          <div class="section-label" style="justify-content:center">Qué hacemos</div>
          <h2>Servicios de marketing digital<br/><span class="serif">que generan resultados</span></h2>
          <p class="section-desc">
            Desde posicionamiento SEO hasta diseño gráfico, ofrecemos todos los servicios
            de marketing digital que tu negocio necesita para crecer online.
          </p>
        </div>

        <div class="services-grid">
          {services.map((s, i) => (
            <a href={s.href} class={`service-card ${i === 0 ? 'service-card--featured' : ''}`}>
              {s.badge && <span class="badge badge-amber service-badge">{s.badge}</span>}
              <div class="service-icon"><Fragment set:html={s.icon} /></div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span class="service-link">
                Ver servicio
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ PROCESO ═══ -->
    <section class="process section-pad">
      <div class="container">
        <div class="section-header text-center">
          <div class="section-label" style="justify-content:center">Cómo trabajamos</div>
          <h2>Un proceso claro<br/><span class="serif">orientado a resultados</span></h2>
        </div>

        <div class="process-grid">
          {processSteps.map(step => (
            <div class="process-step">
              <span class="process-num">{step.num}</span>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CTA BANNER ═══ -->
    <section class="cta-banner section-pad">
      <div class="container">
        <div class="cta-inner">
          <div class="cta-content">
            <div class="section-label">Sin compromiso</div>
            <h2>¿Quieres saber cómo está<br/>posicionada tu web?</h2>
            <p>
              Te hacemos una auditoría SEO gratuita. Analizamos tu web, la competencia y
              te decimos exactamente qué debes mejorar para crecer en Google.
            </p>
            <div class="cta-actions">
              <a href="/pedir-presupuesto" class="btn btn-primary btn-lg">Solicitar auditoría gratis</a>
              <a href="tel:+34618015995" class="btn btn-outline btn-lg">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Llamar ahora
              </a>
            </div>
          </div>
          <div class="cta-visual" aria-hidden="true">
            <div class="cta-glyph">📊</div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
/* ═════════════════ HERO — PREMIUM COMPACT ═════════════════ */
.hero {
  position: relative;
  padding: 4.5rem 0 3rem;
  min-height: calc(100vh - 72px);
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(15,14,12,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15,14,12,0.06) 1px, transparent 1px);
  background-size: 44px 44px;
  mask-image: radial-gradient(ellipse at 50% 30%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 20%, transparent 70%);
  opacity: 0.55;
  pointer-events: none;
}
.hero-glow {
  position: absolute;
  top: -180px;
  right: -180px;
  width: 520px;
  height: 520px;
  background: radial-gradient(circle, rgba(0,213,123,0.16), transparent 60%);
  filter: blur(40px);
  pointer-events: none;
}
.hero-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 4rem;
  align-items: center;
  width: 100%;
}
.hero-content { max-width: 620px; }

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.45rem 0.9rem;
  border: 1px solid rgba(15,14,12,0.14);
  border-radius: 999px;
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(8px);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}
.live-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #00d57b;
  box-shadow: 0 0 0 0 rgba(0,213,123,0.6);
  animation: hero-pulse 2s infinite;
}
@keyframes hero-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(0,213,123,0.6); }
  70%  { box-shadow: 0 0 0 10px rgba(0,213,123,0); }
  100% { box-shadow: 0 0 0 0 rgba(0,213,123,0); }
}

.hero-title {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: clamp(2.75rem, 5.2vw, 4.75rem);
  font-weight: 400;
  line-height: 1.02;
  letter-spacing: -0.025em;
  margin: 0 0 1.25rem;
  color: var(--text-primary);
}
.hero-accent {
  position: relative;
  display: inline-block;
  font-style: italic;
}
.hero-accent::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0.05em;
  height: 0.12em;
  background: var(--primary);
  border-radius: 2px;
  opacity: 0.85;
  z-index: -1;
}
.hero-italic {
  font-style: italic;
  color: var(--primary-dark);
  font-weight: 400;
}

.hero-desc {
  font-size: 1.0625rem;
  color: var(--text-secondary);
  line-height: 1.65;
  margin: 0 0 1.75rem;
  max-width: 560px;
}
.hero-desc strong { color: var(--text-primary); font-weight: 600; }
.hero-link {
  color: var(--text-primary);
  border-bottom: 1px solid var(--primary);
  font-weight: 500;
  transition: color 200ms ease;
}
.hero-link:hover { color: var(--primary-dark); }

.hero-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}
.btn-hero {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 1.5rem;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9375rem;
  letter-spacing: -0.005em;
  text-decoration: none;
  transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
  background: var(--text-primary);
  color: #faf9f7;
  border: 1px solid var(--text-primary);
}
.btn-hero:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 32px rgba(15,14,12,0.25);
}
.btn-hero--ghost {
  background: transparent;
  color: var(--text-primary);
  border-color: rgba(15,14,12,0.14);
}
.btn-hero--ghost:hover {
  background: rgba(15,14,12,0.04);
  border-color: var(--text-primary);
}

.hero-proof-row {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding-top: 1.75rem;
  border-top: 1px solid rgba(15,14,12,0.08);
  flex-wrap: wrap;
}
.proof-cell {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.proof-val {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: 1.75rem;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--text-primary);
}
.proof-val--brand {
  font-family: 'Instrument Serif', Georgia, serif;
  font-style: italic;
  color: var(--primary-dark);
}
.proof-cap {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: -0.005em;
}
.proof-sep {
  width: 1px;
  height: 28px;
  background: rgba(15,14,12,0.14);
}

/* ═══ Hero Visual ═══ */
.hero-visual {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: stretch;
}

.hero-card {
  background: #ffffff;
  border: 1px solid rgba(15,14,12,0.08);
  border-radius: 12px;
  overflow: hidden;
  box-shadow:
    0 2px 4px rgba(15,14,12,0.04),
    0 24px 48px -20px rgba(15,14,12,0.14);
}

.hero-card--main { transform: rotate(-0.5deg); }
.hero-card--ai {
  background: #0f0e0c;
  color: #faf9f7;
  border-color: rgba(250,249,247,0.08);
  transform: rotate(0.5deg);
  box-shadow:
    0 0 0 1px rgba(0,213,123,0.1),
    0 24px 48px -20px rgba(0,0,0,0.25),
    0 0 40px rgba(0,213,123,0.08);
}

.hcard-header {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.75rem 0.9rem;
  border-bottom: 1px solid rgba(15,14,12,0.08);
  background: #fafafa;
}
.hcard-header--dark {
  background: #121212;
  border-bottom-color: rgba(250,249,247,0.06);
}
.hcard-dot { width: 9px; height: 9px; border-radius: 50%; }
.hcard-dot.green { background: #28c840; }
.hcard-dot.amber { background: #febc2e; }
.hcard-dot.red   { background: #ff5f57; }
.hcard-dot-mini {
  width: 7px;
  height: 7px;
  background: #00d57b;
  border-radius: 50%;
  box-shadow: 0 0 8px #00d57b;
  animation: hero-pulse 2s infinite;
}
.hcard-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  color: var(--text-muted);
  margin-left: auto;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.hcard-label-dark {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  color: rgba(250,249,247,0.5);
  margin-left: 0.375rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.hcard-body {
  padding: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.hcard-body-dark {
  padding: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.45rem 0.65rem;
  border-radius: 6px;
  background: #f7f3eb;
}
.rank-pos {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  font-weight: 700;
  min-width: 26px;
  text-align: center;
  padding: 0.2rem 0.35rem;
  border-radius: 4px;
}
