---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fihll="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Posicionamiento SEO',
    desc: 'Analizamos la competencia, optimizamos tu web y construimos autoridad con link building de calidad para posicionarte en los primeros resultados de Google.',
    href: '/posicionamiento-web',
    badge: 'Servicio principal',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 2v10l8 2"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Posicionamiento GEO',
    desc: 'Que ChatGPT, Perplexity, Gemini y Google AI citen tu negocio. Optimización para motores generativos con medición real mediante LLMFY.ai, nuestra herramienta propia.',
    href: '/servicios/posicionamiento-geo-salamanca',
    badge: 'NUEVO',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Diseño Web',
    desc: 'Webs profesionales, autogestionables, adaptadas a todos los dispositivos y optimizadas para vender. Diseños que convierten visitantes en clientes.',
    href: '/servicios/diseno-web',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Community Manager',
    desc: 'Estrategia de redes sociales, creación de contenido diario e interacción con tu comunidad para impulsar tu marca en todas las plataformas.',
    href: '/servicios/community-manager',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Redacción de contenido',
    desc: 'Contenido 100% original, optimizado para SEO y adaptado a tu audiencia. Posts, notas de prensa, fichas de producto y páginas de servicio.',
    href: '/servicios/redaccion-contenido',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>`,
    title: 'Diseño gráfico',
    desc: 'Identidad visual, logotipos, materiales publicitarios y conceptos visuales que refuerzan el branding y diferencias tu marca de la competencia.',
    href: '/servicios/diseno-grafico',
    badge: null,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: 'Posicionamiento ASO',
    desc: 'Optimizamos tu app para aparecer en los primeros resultados de Google Play y App Store, aumentando descargas de forma orgánica.',
    href: '/servicios/posicionamiento-aso',
    badge: null,
  },
];

const stats = [
  { value: '+18', label: 'Años de experiencia' },
  { value: '+150', label: 'Clientes satisfechos' },
  { value: '+500', label: 'Proyectos completados' },
  { value: '95%', label: 'Tasa de retención' },
];

const processSteps = [
  { num: '01', title: 'Auditoría gratuita', desc: 'Analizamos tu web y la competencia sin coste y sin compromiso para entender el punto de partida.' },
  { num: '02', title: 'Estrategia SEO', desc: 'Diseñamos un plan personalizado con objetivos claros, palabras clave y acciones priorizadas.' },
  { num: '03', title: 'Ejecución', desc: 'Implementamos las acciones on-page, off-page y técnicas con total transparencia.' },
  { num: '04', title: 'Resultados & reporting', desc: 'Informes mensuales con métricas reales: posiciones, tráfico, conversiones y ROI.' },
];

const pricing = [
  {
    name: 'Posicionamiento SEO',
    tagline: 'El motor de adquisición orgánica',
    from: '499',
    period: '/ mes',
    featured: true,
    href: '/posicionamiento-web',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    items: [
      'Auditoría + keyword research',
      'Optimización on-page continua',
      'Link building mensual',
      'Reporting con posiciones y tráfico',
      'Incluye optimización GEO para IA',
    ],
  },
  {
    name: 'Diseño Web',
    tagline: 'Web profesional lista para posicionar',
    from: '599',
    period: 'proyecto',
    featured: false,
    href: '/servicios/diseno-web',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    items: [
      'Diseño responsive custom',
      'WordPress autogestionable',
      'Optimizado para Core Web Vitals',
      'Base SEO técnica lista',
    ],
  },
  {
    name: 'Hosting SEO',
    tagline: 'Alojamiento rápido y seguro',
    from: '99',
    period: '/ año',
    featured: false,
    href: '/servicios/hosting-seo',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="4" width="20" height="7" rx="2"/><rect x="2" y="13" width="20" height="7" rx="2"/><line x1="6" y1="7.5" x2="6.01" y2="7.5"/><line x1="6" y1="16.5" x2="6.01" y2="16.5"/></svg>`,
    items: [
      'SSD NVMe + caché LiteSpeed',
      'SSL + backups diarios',
      'Soporte técnico directo',
      'Migración gratis incluida',
    ],
  },
  {
    name: 'Contenidos SEO',
    tagline: 'Artículos que posicionan',
    from: '99',
    period: 'por post',
    featured: false,
    href: '/servicios/redaccion-contenido',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>`,
    items: [
      'Keyword research previo',
      '+1.200 palabras optimizadas',
      'H1/H2, meta y schema listos',
      'Investigación + redacción senior',
    ],
  },
];
---

<Layout
  title="JesusLopezSEO — Consultor SEO en Salamanca | Posicionamiento Web"
  description="Jesús López, Consultor SEO experto en Salamanca. Posicionamiento web, diseño web y marketing digital para empresas que quieren crecer en Google."
>
  <Header />

  <main>

    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container hero-inner">

        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="live-dot"></span>
            Consultor SEO · Salamanca · 18 años
          </div>

          <h1 class="hero-title">
            Que Google y la IA<br/>
            <span class="hero-accent">recomienden</span><br/>
            <em class="hero-italic">tu negocio</em>.
          </h1>

          <p class="hero-desc">
            Posicionamiento <strong>SEO + GEO</strong> para empresas que quieren aparecer donde sus clientes ya están buscando: en Google, en ChatGPT, en Perplexity, en Gemini. Con medición real vía <a href="https://llmfy.ai" target="_blank" rel="noopener" class="hero-link">LLMFY.ai</a>.
          </p>

          <div class="hero-actions">
            <a href="/pedir-presupuesto" class="btn-hero">
              Pedir presupuesto gratis
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#servicios" class="btn-hero btn-hero--ghost">Ver servicios</a>
          </div>

          <div class="hero-proof-row">
            <div class="proof-cell">
              <div class="proof-val">+150</div>
              <div class="proof-cap">clientes</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val">#1</div>
              <div class="proof-cap">SEO Salamanca</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val">+340%</div>
              <div class="proof-cap">tráfico</div>
            </div>
            <div class="proof-sep"></div>
            <div class="proof-cell">
              <div class="proof-val proof-val--brand">LLMFY</div>
              <div class="proof-cap">herramienta propia</div>
            </div>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="hero-card hero-card--ai">
            <div class="hcard-header hcard-header--dark">
              <span class="hcard-dot-mini"></span>
              <span class="hcard-label-dark">LLMFY · Brand tracking</span>
            </div>
            <div class="hcard-body-dark">
              <div class="ai-query">
                <span class="ai-q-prompt">›</span>
                <span class="ai-q-text">"consultor seo salamanca"</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">ChatGPT</span>
                <span class="ai-badge ai-badge--good">Citado #1</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Perplexity</span>
                <span class="ai-badge ai-badge--good">Citado #2</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Claude</span>
                <span class="ai-badge ai-badge--good">Citado #1</span>
              </div>
              <div class="ai-row">
                <span class="ai-model">Gemini</span>
                <span class="ai-badge ai-badge--good">Citado</span>
              </div>
              <div class="ai-summary">
                <span class="ai-summary-dot"></span>
                <span>Sentiment: <strong>positivo</strong> · 18 años · experto local</span>
              </div>
            </div>
          </div>

          <div class="hero-float-badge">
            <span class="hero-float-icon">⚡</span>
            <div>
              <div class="hero-float-num">+340%</div>
              <div class="hero-float-cap">tráfico orgánico</div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══ STATS ═══ -->
    <section class="stats-bar">
      <div class="container stats-inner">
        {stats.map(s => (
          <div class="stat-item">
            <strong class="stat-num">{s.value}</strong>
            <span class="stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ ABOUT ═══ -->
    <section class="about section-pad">
      <div class="container about-grid">

        <div class="about-visual">
          <div class="about-img-wrap">
            <div class="about-avatar">
              <div class="avatar-glow" aria-hidden="true"></div>
              <svg class="avatar-svg" viewBox="0 0 360 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración de Jesús López">
                <!-- Background circle with subtle gradient -->
                <defs>
                  <linearGradient id="bg-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#f7f3eb"/>
                    <stop offset="100%" stop-color="#f3efe7"/>
                  </linearGradient>
                  <linearGradient id="shirt-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#0f0e0c"/>
                    <stop offset="100%" stop-color="#2a2622"/>
                  </linearGradient>
                  <linearGradient id="amber-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#f59e0b"/>
                    <stop offset="100%" stop-color="#b45309"/>
                  </linearGradient>
                  <radialGradient id="face-grad" cx="50%" cy="45%" r="55%">
                    <stop offset="0%" stop-color="#fbe4cc"/>
                    <stop offset="100%" stop-color="#e8c9a8"/>
                  </radialGradient>
                </defs>

                <!-- Backdrop -->
                <circle cx="180" cy="180" r="180" fill="url(#bg-grad)"/>

                <!-- Decorative floating dots -->
                <circle cx="60" cy="80" r="3" fill="#f59e0b" opacity="0.6"/>
                <circle cx="310" cy="110" r="2.5" fill="#00d57b" opacity="0.7"/>
                <circle cx="300" cy="240" r="3.5" fill="#f59e0b" opacity="0.4"/>
                <circle cx="50" cy="220" r="2" fill="#0f0e0c" opacity="0.3"/>
                <path d="M 320 60 L 328 60 M 324 56 L 324 64" stroke="#f59e0b" stroke-width="1.5" opacity="0.6"/>
                <path d="M 40 160 L 48 160 M 44 156 L 44 164" stroke="#00d57b" stroke-width="1.5" opacity="0.5"/>

                <!-- Shoulders / shirt (dark) -->
                <path d="M 60 360 Q 60 280 130 260 Q 180 250 230 260 Q 300 280 300 360 Z" fill="url(#shirt-grad)"/>

                <!-- Shirt collar detail -->
                <path d="M 155 258 Q 180 275 205 258 L 200 290 L 180 298 L 160 290 Z" fill="#1a1612"/>

                <!-- Neck -->
                <path d="M 158 230 Q 180 245 202 230 L 205 260 Q 180 272 155 260 Z" fill="#e8c9a8"/>
                <path d="M 160 245 Q 180 253 200 245" stroke="#c8a888" stroke-width="1.5" fill="none" opacity="0.4"/>

                <!-- Head / Face -->
                <ellipse cx="180" cy="170" rx="75" ry="88" fill="url(#face-grad)"/>

                <!-- Hair: dark short modern -->
                <path d="M 110 155 Q 105 105 140 90 Q 160 75 180 78 Q 210 75 232 95 Q 258 110 252 158 Q 248 130 230 120 Q 215 138 200 135 Q 178 128 158 138 Q 140 130 128 138 Q 115 145 110 155 Z" fill="#1a1612"/>
                <!-- Hair texture strands -->
                <path d="M 130 110 Q 150 95 175 100" stroke="#0f0e0c" stroke-width="1" fill="none" opacity="0.6"/>
                <path d="M 200 95 Q 220 95 238 115" stroke="#0f0e0c" stroke-width="1" fill="none" opacity="0.6"/>

                <!-- Ears -->
                <ellipse cx="108" cy="175" rx="9" ry="14" fill="#e8c9a8"/>
                <ellipse cx="252" cy="175" rx="9" ry="14" fill="#e8c9a8"/>
                <path d="M 106 172 Q 110 178 106 184" stroke="#c8a888" stroke-width="1" fill="none"/>
                <path d="M 254 172 Q 250 178 254 184" stroke="#c8a888" stroke-width="1" fill="none"/>

                <!-- Eyebrows -->
                <path d="M 138 160 Q 152 154 168 160" stroke="#1a1612" stroke-width="4" stroke-linecap="round" fill="none"/>
                <path d="M 192 160 Q 208 154 222 160" stroke="#1a1612" stroke-width="4" stroke-linecap="round" fill="none"/>

                <!-- Glasses (subtle rounded frames — developer vibe) -->
                <circle cx="150" cy="180" r="20" fill="none" stroke="#0f0e0c" stroke-width="2.5"/>
                <circle cx="210" cy="180" r="20" fill="none" stroke="#0f0e0c" stroke-width="2.5"/>
                <line x1="170" y1="180" x2="190" y2="180" stroke="#0f0e0c" stroke-width="2.5"/>
                <!-- Lens reflection -->
                <path d="M 140 172 Q 145 168 152 170" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" opacity="0.7" fill="none"/>
                <path d="M 200 172 Q 205 168 212 170" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" opacity="0.7" fill="none"/>

                <!-- Eyes (inside glasses) -->
                <circle cx="150" cy="180" r="3" fill="#1a1612"/>
                <circle cx="210" cy="180" r="3" fill="#1a1612"/>
                <circle cx="151" cy="179" r="1" fill="#fff"/>
                <circle cx="211" cy="179" r="1" fill="#fff"/>

                <!-- Nose -->
                <path d="M 180 188 Q 175 210 178 218 Q 183 222 186 218 Q 189 210 185 193" stroke="#c8a888" stroke-width="1.8" fill="none" stroke-linecap="round"/>

                <!-- Mouth — small confident smile -->
                <path d="M 165 232 Q 180 242 198 232" stroke="#8b4a3a" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                <!-- Beard stubble hint -->
                <path d="M 145 215 Q 180 248 220 215" stroke="#3a3028" stroke-width="0.6" fill="none" opacity="0.3"/>

                <!-- Cheeks -->
                <ellipse cx="130" cy="212" rx="10" ry="5" fill="#e8a878" opacity="0.35"/>
                <ellipse cx="230" cy="212" rx="10" ry="5" fill="#e8a878" opacity="0.35"/>

                <!-- Amber accent chip on shirt (nod to brand) -->
                <rect x="165" y="310" width="30" height="4" rx="2" fill="url(#amber-grad)"/>
              </svg>

              <!-- Code comment floating bubble -->
              <div class="avatar-bubble avatar-bubble--1">
                <span class="avatar-bubble-dot"></span>
                <code>&lt;SEO /&gt;</code>
              </div>
              <div class="avatar-bubble avatar-bubble--2">
                <span class="avatar-bubble-spark">✦</span>
                LLMFY
              </div>
            </div>
          </div>
          <div class="about-badge">
            <span class="about-badge-icon">🏆</span>
            <div>
              <strong>+18 años</strong>
              <span>en SEO</span>
            </div>
          </div>
        </div>

        <div class="about-content">
          <div class="section-label">Sobre mí</div>
          <h2>Soy Jesús López, <span class="serif">Consultor SEO</span> y CEO en JesusLopezSEO</h2>
          <p>
            Apasionado del posicionamiento web desde hace más de 18 años. Ayudo a empresas y negocios
            de todo tipo a mejorar su visibilidad en Google y conseguir resultados reales: más tráfico,
            más leads y más ventas.
          </p>
          <p>
            Si tienes una web, blog o tienda online, te conviene estar en la primera página de Google
            por encima de tu competencia. Para eso combino estrategias SEO on-page y off-page,
            manteniéndome al día con cada actualización del algoritmo.
          </p>
          <ul class="about-list">
            <li>
              <span class="list-check">✓</span>
              Auditoría web inicial gratuita y sin compromiso
            </li>
            <li>
              <span class="list-check">✓</span>
              Planes adaptados a cada presupuesto y sector
            </li>
            <li>
              <span class="list-check">✓</span>
              Reporting mensual con métricas reales
            </li>
            <li>
              <span class="list-check">✓</span>
              Equipo multidisciplinar (SEO, diseño, contenidos, RRSS)
            </li>
          </ul>
          <a href="/contactar" class="btn btn-outline">Conoce más sobre mí →</a>
        </div>

      </div>
    </section>

    <!-- ═══ SERVICIOS ═══ -->
    <section class="services section-pad bg-subtle" id="servicios">
      <div class="container">
        <div class="section-header text-center">
          <div class="section-label" style="justify-content:center">Qué hacemos</div>
          <h2>Servicios de marketing digital<br/><span class="serif">que generan resultados</span></h2>
          <p class="section-desc">
            Desde posicionamiento SEO hasta diseño gráfico, ofrecemos todos los servicios
            de marketing digital que tu negocio necesita para crecer online.
          </p>
        </div>

        <div class="services-grid">
          {services.map((s, i) => (
            <a href={s.href} class={`service-card ${i === 0 ? 'service-card--featured' : ''}`}>
              {s.badge && <span class={`badge ${s.badge === 'NUEVO' ? 'badge-mint' : 'badge-amber'} service-badge`}>{s.badge}</span>}
              <div class="service-icon"><Fragment set:html={s.icon} /></div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span class="service-link">
                Ver servicio
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ PRICING ═══ -->
    <section class="pricing section-pad" id="precios">
      <div class="pricing-grid-bg" aria-hidden="true"></div>
      <div class="container">
        <div class="pricing-header">
          <div class="pricing-pill">
            <span class="pricing-pill-dot"></span>
            Precios transparentes
          </div>
          <h2 class="pricing-h2">
            Presupuestos claros,<br/>
            <em>desde el primer día.</em>
          </h2>
          <p class="pricing-lead">
            Publico los precios de partida porque creo en la transparencia.
            El importe final se ajusta a tu sector, competencia y objetivos — te lo confirmo en la auditoría inicial.
          </p>
        </div>

        <div class="pricing-grid">
          {pricing.map(p => (
            <div class={`price-card ${p.featured ? 'price-card--featured' : ''}`}>
              {p.featured && (
                <div class="price-ribbon">
                  <span class="price-ribbon-dot"></span>
                  Más contratado
                </div>
              )}
              <div class="price-icon" set:html={p.icon} />
              <h3 class="price-name">{p.name}</h3>
              <p class="price-tag">{p.tagline}</p>

              <div class="price-amount">
                <span class="price-from">desde</span>
                <span class="price-num">{p.from}<span class="price-currency">€</span></span>
                <span class="price-period">{p.period}</span>
              </div>

              <ul class="price-features">
                {p.items.map(it => (
                  <li>
                    <span class="price-check">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    {it}
                  </li>
                ))}
              </ul>

              <a href={p.href} class={`price-cta ${p.featured ? 'price-cta--primary' : ''}`}>
                {p.featured ? 'Ver servicio SEO' : 'Ver detalles'}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          ))}
        </div>

        <div class="pricing-footnote">
