---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contactar — JesusLopezSEO"
  description="Contacta con JesusLopezSEO. Llámanos, escríbenos o ven a vernos en Salamanca. Te respondemos en menos de 24 horas."
  canonical="https://www.jesuslopezseo.com/contactar"
>
  <Header />

  <main>
    <section class="contact-hero">
      <div class="contact-hero-bg" aria-hidden="true"></div>
      <div class="container contact-hero-inner">
        <div class="contact-hero-text animate-fade-up">
          <div class="section-label">Hablemos</div>
          <h1>Cuéntanos tu proyecto</h1>
          <p>
            Si quieres posicionar tu web, hacer una nueva o gestionar tus redes sociales,
            estamos aquí para ayudarte. Te respondemos en menos de 24 horas.
          </p>
        </div>
      </div>
    </section>

    <section class="contact-body">
      <div class="container contact-grid">

        <!-- Info -->
        <div class="contact-info animate-fade-up">
          <div class="contact-profile">
            <div class="profile-avatar">JL</div>
            <div>
              <strong>JesusLopezSEO</strong>
              <span>CEO — Director de Operaciones</span>
              <p>Apasionado del posicionamiento web. El SEO es mi gran pasión y donde me gusta seguir adquiriendo conocimientos día a día.</p>
            </div>
          </div>

          <div class="contact-channels">
            <a href="tel:+34618015995" class="channel-card">
              <div class="channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <strong>Móvil</strong>
                <span>(+34) 618 015 995</span>
              </div>
            </a>
            <a href="tel:+34923161866" class="channel-card">
              <div class="channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <strong>Teléfono</strong>
                <span>(+34) 923 16 18 66</span>
              </div>
            </a>
            <a href="mailto:jesus@jesuslopezseo.com" class="channel-card">
              <div class="channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <strong>Email</strong>
                <span>jesus@jesuslopezseo.com</span>
              </div>
            </a>
            <div class="channel-card channel-card--location">
              <div class="channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong>Dirección</strong>
                <span>Plaza Mayor 11, Ático Derecha<br/>37002 Salamanca</span>
              </div>
            </div>
          </div>

          <div class="contact-hours">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div>
              <strong>Horario de atención</strong>
              <span>Lunes a Viernes · 9:00 – 18:00</span>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="contact-form-wrap animate-fade-up delay-200">
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-grid">
              <div class="form-group">
                <label class="form-label" for="nombre">Nombre *</label>
                <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="email">Email *</label>
                <input class="form-input" type="email" id="email" name="email" placeholder="tu@email.com" required />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="telefono">Teléfono</label>
              <input class="form-input" type="tel" id="telefono" name="telefono" placeholder="+34 600 000 000" />
            </div>
            <div class="form-group">
              <label class="form-label" for="web">Tu web (si tienes)</label>
              <input class="form-input" type="url" id="web" name="web" placeholder="https://tuweb.com" />
            </div>
            <div class="form-group">
              <label class="form-label" for="servicio">¿Qué necesitas?</label>
              <select class="form-input form-select" id="servicio" name="servicio">
                <option value="">Selecciona un servicio</option>
                <option>Posicionamiento SEO</option>
                <option>Diseño web</option>
                <option>Community Manager</option>
                <option>Redacción de contenido</option>
                <option>Diseño gráfico</option>
                <option>Posicionamiento ASO</option>
                <option>Hosting SEO</option>
                <option>Otro / No sé todavía</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="mensaje">Cuéntanos tu proyecto *</label>
              <textarea class="form-input form-textarea" id="mensaje" name="mensaje" rows="5" placeholder="Describe brevemente tu proyecto, objetivos y cualquier información relevante..." required></textarea>
            </div>
            <div class="form-check">
              <input type="checkbox" id="privacidad" name="privacidad" required />
              <label for="privacidad">
                Acepto la <a href="/politica-de-cookies" target="_blank">política de privacidad</a>
              </label>
            </div>
            <button type="submit" class="btn btn-primary btn-lg form-submit">
              Enviar mensaje
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>

            <div class="form-success" id="form-success" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>¡Mensaje enviado!</strong>
              <p>Te responderemos en menos de 24 horas.</p>
            </div>
          </form>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
/* Hero */
.contact-hero {
  position: relative;
  padding: 6rem 0 4rem;
  overflow: hidden;
}
.contact-hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 80% 0%, rgba(245,158,11,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.contact-hero-inner { max-width: 640px; }
.contact-hero-text h1 { margin: 0.75rem 0 1rem; }
.contact-hero-text p { font-size: 1.0625rem; color: var(--text-muted); line-height: 1.75; }

/* Body */
.contact-body { padding: 4rem 0 6rem; }
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 4rem;
  align-items: start;
}

/* Profile */
.contact-profile {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
  padding: 1.5rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-lg);
}
.profile-avatar {
  flex-shrink: 0;
  width: 52px; height: 52px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800;
  font-size: 1rem;
  color: #fff;
}
.contact-profile strong { display: block; font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.contact-profile span { display: block; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 0.375rem; }
.contact-profile p { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; }

/* Channels */
.contact-channels { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
.channel-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  transition: all 200ms;
}
.channel-card:not(.channel-card--location):hover {
  border-color: var(--amber-200);
  background: var(--amber-50);
}
.channel-icon {
  flex-shrink: 0;
  width: 40px; height: 40px;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  color: var(--primary-dark);
}
.channel-card strong { display: block; font-size: 0.8125rem; font-weight: 700; color: var(--text-primary); line-height: 1; margin-bottom: 0.25rem; }
.channel-card span { font-size: 0.875rem; color: var(--text-secondary); }

/* Hours */
.contact-hours {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1.25rem;
  background: var(--cream-100);
  border-radius: var(--radius-md);
  color: var(--text-muted);
}
.contact-hours strong { display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-primary); }
.contact-hours span { font-size: 0.8125rem; }

/* Form */
.contact-form-wrap {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  padding: 2.5rem;
  box-shadow: var(--shadow-md);
}
.contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.form-group { display: flex; flex-direction: column; gap: 0.375rem; }
.form-label { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); }
.form-input {
  padding: 0.75rem 1rem;
  border: 1.5px solid var(--surface-border);
  border-radius: var(--radius-md);
  font-size: 0.9375rem;
  font-family: var(--font-sans);
  color: var(--text-primary);
  background: var(--cream-50);
  transition: border-color 200ms, box-shadow 200ms;
  width: 100%;
}
.form-input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(245,158,11,0.1);
}
.form-input::placeholder { color: var(--text-light); }
.form-select { cursor: pointer; }
.form-textarea { resize: vertical; min-height: 120px; }

.form-check {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  font-size: 0.875rem;
  color: var(--text-muted);
}
.form-check a { color: var(--primary-dark); text-decoration: underline; }
.form-check input[type="checkbox"] { margin-top: 3px; accent-color: var(--primary); }

.form-submit { width: 100%; justify-content: center; }

.form-success {
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 2rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-lg);
  text-align: center;
}
.form-success.visible { display: flex; }
.form-success strong { font-size: 1rem; color: var(--text-primary); }
.form-success p { font-size: 0.875rem; color: var(--text-muted); }

/* Responsive */
@media (max-width: 1024px) {
  .contact-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .form-grid { grid-template-columns: 1fr; }
  .contact-form-wrap { padding: 1.5rem; }
  .contact-hero { padding: 4rem 0 3rem; }
}
</style>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const success = document.getElementById('form-success');

form?.addEventListener('submit', (e) => {
  e.preventDefault();
  // Simulate form submission
  // Replace with actual form handler (Netlify, Formspree, Astro API route, etc.)
  success?.classList.add('visible');
  success?.setAttribute('aria-hidden', 'false');
  form.style.display = 'none';
});
</script>
