---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  metaTitle?: string;
  metaDescription?: string;
  canonical?: string;
  hero: {
    badge: string;
    headline: string;
    subheadline?: string;
    description: string;
    cta?: string;
  };
  features?: Array<{ icon: string; title: string; desc: string }>;
  benefits?: Array<string>;
  faq?: Array<{ q: string; a: string }>;
}

const {
  title,
  metaTitle,
  metaDescription,
  canonical,
  hero,
  features = [],
  benefits = [],
  faq = [],
} = Astro.props;
---

<Layout title={metaTitle || title + ' — JesusLopezSEO'} description={metaDescription} canonical={canonical}>
  <Header />

  <main>

    <!-- Hero del servicio -->
    <section class="svc-hero">
      <div class="svc-hero-bg" aria-hidden="true"></div>
      <div class="container svc-hero-inner">
        <div class="svc-hero-content animate-fade-up">
          <div class="section-label">{hero.badge}</div>
          <h1 set:html={hero.headline} />
          {hero.subheadline && <p class="svc-hero-sub">{hero.subheadline}</p>}
          <p class="svc-hero-desc">{hero.description}</p>
          <div class="svc-hero-actions">
            <a href="/pedir-presupuesto" class="btn btn-primary btn-lg">
              {hero.cta || 'Solicitar presupuesto'}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:+34618015995" class="btn btn-outline btn-lg">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Llamar ahora
            </a>
          </div>
        </div>
        <div class="svc-hero-aside animate-fade-up delay-300">
          <slot name="hero-aside" />
        </div>
      </div>
    </section>

    <!-- Main content slot -->
    <slot />

    <!-- Features grid (if provided) -->
    {features.length > 0 && (
      <section class="svc-features section-pad bg-subtle">
        <div class="container">
          <div class="section-header text-center">
            <div class="section-label" style="justify-content:center">Qué incluye</div>
            <h2>Todo lo que necesitas<br/><span class="serif">en un solo servicio</span></h2>
          </div>
          <div class="features-grid">
            {features.map(f => (
              <div class="feature-card">
                <div class="feature-icon" set:html={f.icon} />
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Benefits -->
    {benefits.length > 0 && (
      <section class="svc-benefits section-pad">
        <div class="container svc-benefits-grid">
          <div class="benefits-content">
            <div class="section-label">Por qué elegirnos</div>
            <h2>Ventajas de trabajar<br/>con <span class="serif">JesusLopezSEO</span></h2>
            <ul class="benefits-list">
              {benefits.map(b => (
                <li>
                  <span class="benefit-check">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  {b}
                </li>
              ))}
            </ul>
            <a href="/pedir-presupuesto" class="btn btn-primary" style="margin-top:1.5rem">Solicitar presupuesto sin compromiso</a>
          </div>
          <div class="benefits-cta-box">
            <h3>¿Tienes dudas?</h3>
            <p>Contáctanos ahora y te asesoramos sin compromiso. Analizamos tu proyecto y te explicamos cómo podemos ayudarte.</p>
            <div class="contact-options">
              <a href="mailto:jesus@jesuslopezseo.com" class="contact-opt">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                jesus@jesuslopezseo.com
              </a>
              <a href="tel:+34618015995" class="contact-opt">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                618 015 995
              </a>
              <a href="tel:+34923161866" class="contact-opt">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                923 16 18 66
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="svc-faq section-pad bg-subtle">
        <div class="container" style="max-width:780px">
          <div class="section-header text-center">
            <div class="section-label" style="justify-content:center">FAQ</div>
            <h2>Preguntas frecuentes</h2>
          </div>
          <div class="faq-list">
            {faq.map(item => (
              <details class="faq-item">
                <summary class="faq-question">
                  {item.q}
                  <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </summary>
                <div class="faq-answer">
                  <p>{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="section-pad">
      <div class="container">
        <div class="bottom-cta">
          <div class="section-label" style="justify-content:center">Sin compromiso</div>
          <h2>¿Listo para mejorar tu presencia online?</h2>
          <p>Pide tu presupuesto gratuito ahora. Te respondemos en menos de 24 horas.</p>
          <a href="/pedir-presupuesto" class="btn btn-primary btn-lg">Solicitar presupuesto gratis →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
/* Hero */
.svc-hero {
  position: relative;
  padding: 6rem 0 5rem;
  overflow: hidden;
}
.svc-hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 100% 0%, rgba(245,158,11,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.svc-hero-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: center;
}
.svc-hero-content { max-width: 580px; }
.svc-hero-content h1 { margin: 0.75rem 0 1rem; }
.svc-hero-sub {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 0.75rem;
}
.svc-hero-desc {
  font-size: 1.0625rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 2rem;
}
.svc-hero-actions { display: flex; gap: 0.875rem; flex-wrap: wrap; }

/* Features */
.section-pad { padding: 6rem 0; }
.bg-subtle { background: var(--surface-subtle); }
.section-header { margin-bottom: 3rem; }
.section-header h2 { margin-bottom: 0.5rem; }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.feature-card {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  transition: all var(--transition-base);
}
.feature-card:hover {
  border-color: var(--amber-200);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.feature-icon {
  width: 44px; height: 44px;
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  color: var(--primary-dark);
  margin-bottom: 1rem;
}
.feature-card h3 { font-size: 1rem; margin-bottom: 0.5rem; }
.feature-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }

/* Benefits */
.svc-benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}
.benefits-list {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
  margin-top: 1.5rem;
}
.benefits-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.9375rem;
  color: var(--text-secondary);
  line-height: 1.5;
}
.benefit-check {
  flex-shrink: 0;
  width: 22px; height: 22px;
  background: var(--primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  margin-top: 1px;
}

.benefits-cta-box {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-xl);
  padding: 2.5rem;
  box-shadow: var(--shadow-md);
}
.benefits-cta-box h3 { margin-bottom: 0.75rem; }
.benefits-cta-box p { font-size: 0.9375rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 1.5rem; }

.contact-options { display: flex; flex-direction: column; gap: 0.75rem; }
.contact-opt {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.875rem 1rem;
  background: var(--cream-50);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 200ms;
}
.contact-opt:hover {
  border-color: var(--amber-200);
  color: var(--primary-dark);
  background: var(--amber-50);
}

/* FAQ */
.faq-list { display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item {
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: border-color 200ms;
}
.faq-item[open] { border-color: var(--amber-300); }
.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  font-weight: 600;
  font-size: 0.9375rem;
  color: var(--text-primary);
  cursor: pointer;
  list-style: none;
}
.faq-question::-webkit-details-marker { display: none; }
.faq-question:hover { color: var(--primary-dark); }
.faq-icon { flex-shrink: 0; transition: transform 200ms; color: var(--primary); }
.faq-item[open] .faq-icon { transform: rotate(180deg); }
.faq-answer {
  padding: 0 1.5rem 1.25rem;
}
.faq-answer p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }

/* Bottom CTA */
.bottom-cta {
  background: linear-gradient(135deg, var(--amber-50) 0%, #fff 100%);
  border: 1px solid var(--amber-200);
  border-radius: var(--radius-xl);
  padding: 4rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.bottom-cta h2 { font-size: clamp(1.5rem, 3vw, 2rem); }
.bottom-cta p { color: var(--text-muted); max-width: 440px; line-height: 1.7; }

/* Responsive */
@media (max-width: 1024px) {
  .svc-hero-inner { grid-template-columns: 1fr; }
  .svc-hero-aside { display: none; }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
  .svc-benefits-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .svc-hero { padding: 4rem 0 3rem; }
  .features-grid { grid-template-columns: 1fr; }
  .bottom-cta { padding: 2.5rem 1.5rem; }
}
</style>
