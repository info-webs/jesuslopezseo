---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  metaTitle?: string;
  metaDescription?: string;
  canonical?: string;
  hero: {
    badge: string;
    headline: string;
    subheadline?: string;
    description: string;
    cta?: string;
  };
  heroVisual?: 'web' | 'aso' | 'hosting' | 'content' | 'graphic' | 'social' | 'seo';
  features?: Array<{ icon: string; title: string; desc: string }>;
  benefits?: Array<string>;
  faq?: Array<{ q: string; a: string }>;
}

const {
  title,
  metaTitle,
  metaDescription,
  canonical,
  hero,
  heroVisual = 'web',
  features = [],
  benefits = [],
  faq = [],
} = Astro.props;
---

<Layout title={metaTitle || title + ' — JesusLopezSEO'} description={metaDescription} canonical={canonical}>
  <Header />

  <main class="svc">

    <!-- ═══ Hero ═══ -->
    <section class="svc-hero">
      <div class="svc-grid" aria-hidden="true"></div>
      <div class="svc-glow" aria-hidden="true"></div>

      <div class="container svc-hero-inner">
        <div class="svc-hero-content">
          <div class="svc-eyebrow">
            <span class="svc-dot"></span>
            {hero.badge}
          </div>

          <h1 class="svc-hero-title" set:html={hero.headline} />

          {hero.subheadline && <p class="svc-hero-sub">{hero.subheadline}</p>}
          <p class="svc-hero-desc">{hero.description}</p>

          <div class="svc-hero-actions">
            <a href="/pedir-presupuesto" class="svc-btn">
              {hero.cta || 'Solicitar presupuesto'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:+34618015995" class="svc-btn svc-btn--ghost">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Llamar
            </a>
          </div>
        </div>

        <div class="svc-hero-aside" aria-hidden="true">
          <slot name="hero-aside">

            {heroVisual === 'web' && (
              <div class="viz-stack">
                <div class="viz-card viz-browser viz-tilt-1">
                  <div class="viz-browser-head">
                    <span class="viz-dot viz-dot--r"></span>
                    <span class="viz-dot viz-dot--y"></span>
                    <span class="viz-dot viz-dot--g"></span>
                    <div class="viz-url">tu-web.es</div>
                  </div>
                  <div class="viz-browser-body">
                    <div class="viz-nav">
                      <div class="viz-logo-bar"></div>
                      <div class="viz-nav-items">
                        <span></span><span></span><span></span>
                        <div class="viz-cta-mini"></div>
                      </div>
                    </div>
                    <div class="viz-hero-mock">
                      <div class="viz-h1-line viz-h1-line--lg"></div>
                      <div class="viz-h1-line viz-h1-line--md"></div>
                      <div class="viz-p-line"></div>
                      <div class="viz-p-line viz-p-line--short"></div>
                      <div class="viz-btn-mock"></div>
                    </div>
                    <div class="viz-grid-mock">
                      <div class="viz-box viz-shimmer"></div>
                      <div class="viz-box viz-shimmer" style="animation-delay:.3s"></div>
                      <div class="viz-box viz-shimmer" style="animation-delay:.6s"></div>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle">✨</span>
                  <div>
                    <div class="viz-badge-num">98</div>
                    <div class="viz-badge-cap">PageSpeed</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'seo' && (
              <div class="viz-stack">
                <div class="viz-card viz-rank-card viz-tilt-1">
                  <div class="viz-browser-head">
                    <span class="viz-dot viz-dot--r"></span>
                    <span class="viz-dot viz-dot--y"></span>
                    <span class="viz-dot viz-dot--g"></span>
                    <div class="viz-url">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
                      google.com
                    </div>
                  </div>
                  <div class="viz-rank-body">
                    <div class="viz-query">
                      <span class="viz-q-label">Buscando:</span>
                      <span class="viz-q-kw">consultor seo salamanca<span class="viz-cursor">|</span></span>
                    </div>
                    <div class="viz-rank-row viz-rank-row--1 viz-slide-in">
                      <span class="viz-rank-pos">#1</span>
                      <div class="viz-rank-info">
                        <div class="viz-rank-title"></div>
                        <div class="viz-rank-url">jesuslopezseo.com</div>
                      </div>
                      <span class="viz-arrow viz-arrow--up">↑</span>
                    </div>
                    <div class="viz-rank-row viz-rank-row--2 viz-slide-in" style="animation-delay:.2s">
                      <span class="viz-rank-pos viz-rank-pos--2">#2</span>
                      <div class="viz-rank-info">
                        <div class="viz-rank-title viz-rank-title--short"></div>
                        <div class="viz-rank-url viz-rank-url--muted"></div>
                      </div>
                      <span class="viz-arrow viz-arrow--up">↑</span>
                    </div>
                    <div class="viz-rank-row viz-slide-in" style="animation-delay:.4s">
                      <span class="viz-rank-pos viz-rank-pos--3">#3</span>
                      <div class="viz-rank-info">
                        <div class="viz-rank-title viz-rank-title--md"></div>
                        <div class="viz-rank-url viz-rank-url--muted"></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle viz-sparkle--amber">↗</span>
                  <div>
                    <div class="viz-badge-num">+340%</div>
                    <div class="viz-badge-cap">tráfico</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'aso' && (
              <div class="viz-stack">
                <div class="viz-phone viz-float-slow">
                  <div class="viz-phone-notch"></div>
                  <div class="viz-phone-screen">
                    <div class="viz-phone-top">
                      <div class="viz-search-bar">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
                        <span>tu app</span>
                      </div>
                    </div>
                    <div class="viz-app-row viz-slide-in">
                      <div class="viz-app-icon viz-app-icon--1"></div>
                      <div class="viz-app-info">
                        <div class="viz-app-name"></div>
                        <div class="viz-stars">★★★★★</div>
                      </div>
                      <div class="viz-app-cta">GET</div>
                    </div>
                    <div class="viz-app-row viz-slide-in" style="animation-delay:.15s">
                      <div class="viz-app-icon viz-app-icon--2"></div>
                      <div class="viz-app-info">
                        <div class="viz-app-name viz-app-name--short"></div>
                        <div class="viz-stars">★★★★☆</div>
                      </div>
                      <div class="viz-app-cta viz-app-cta--ghost">GET</div>
                    </div>
                    <div class="viz-app-row viz-slide-in" style="animation-delay:.3s">
                      <div class="viz-app-icon viz-app-icon--3"></div>
                      <div class="viz-app-info">
                        <div class="viz-app-name viz-app-name--mid"></div>
                        <div class="viz-stars">★★★★☆</div>
                      </div>
                      <div class="viz-app-cta viz-app-cta--ghost">GET</div>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle">📲</span>
                  <div>
                    <div class="viz-badge-num">#1</div>
                    <div class="viz-badge-cap">App Store</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'hosting' && (
              <div class="viz-stack">
                <div class="viz-card viz-terminal viz-tilt-1">
                  <div class="viz-browser-head viz-browser-head--dark">
                    <span class="viz-dot viz-dot--r"></span>
                    <span class="viz-dot viz-dot--y"></span>
                    <span class="viz-dot viz-dot--g"></span>
                    <div class="viz-term-title">server.log</div>
                  </div>
                  <div class="viz-term-body">
                    <div class="viz-term-line">
                      <span class="viz-prompt">›</span>
                      <span class="viz-cmd">curl</span>
                      <span class="viz-arg">-I tu-web.es</span>
                    </div>
                    <div class="viz-term-out viz-fade-in">HTTP/2 200 OK</div>
                    <div class="viz-term-out viz-fade-in" style="animation-delay:.3s">server: nginx/1.27</div>
                    <div class="viz-term-out viz-fade-in" style="animation-delay:.5s">x-cache: HIT</div>
                    <div class="viz-metric-grid viz-fade-in" style="animation-delay:.8s">
                      <div class="viz-metric">
                        <div class="viz-metric-val viz-metric-val--good">0.18s</div>
                        <div class="viz-metric-cap">TTFB</div>
                      </div>
                      <div class="viz-metric">
                        <div class="viz-metric-val viz-metric-val--good">99.9%</div>
                        <div class="viz-metric-cap">Uptime</div>
                      </div>
                      <div class="viz-metric">
                        <div class="viz-metric-val viz-metric-val--good">A+</div>
                        <div class="viz-metric-cap">SSL</div>
                      </div>
                    </div>
                    <div class="viz-term-line">
                      <span class="viz-prompt">›</span>
                      <span class="viz-cursor viz-cursor--block">▊</span>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle viz-sparkle--mint">⚡</span>
                  <div>
                    <div class="viz-badge-num">180ms</div>
                    <div class="viz-badge-cap">respuesta</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'content' && (
              <div class="viz-stack">
                <div class="viz-card viz-editor viz-tilt-1">
                  <div class="viz-browser-head">
                    <span class="viz-dot viz-dot--r"></span>
                    <span class="viz-dot viz-dot--y"></span>
                    <span class="viz-dot viz-dot--g"></span>
                    <div class="viz-url">editor · post SEO</div>
                  </div>
                  <div class="viz-editor-body">
                    <div class="viz-editor-h1 viz-type"></div>
                    <div class="viz-editor-meta">
                      <span class="viz-chip viz-chip--amber">H1</span>
                      <span class="viz-chip">KW density 2.1%</span>
                      <span class="viz-chip viz-chip--green">SEO 94</span>
                    </div>
                    <div class="viz-editor-par">
                      <div class="viz-par-line"></div>
                      <div class="viz-par-line viz-par-line--short"></div>
                      <div class="viz-par-line"></div>
                    </div>
                    <div class="viz-editor-hl viz-fade-in" style="animation-delay:.5s">
                      <span class="viz-hl-icon">✓</span>
                      <span>Legibilidad: Muy buena</span>
                    </div>
                    <div class="viz-editor-hl viz-fade-in" style="animation-delay:.8s">
                      <span class="viz-hl-icon">✓</span>
                      <span>Keyword en H1, H2, primer párrafo</span>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle viz-sparkle--amber">✎</span>
                  <div>
                    <div class="viz-badge-num">+1,2K</div>
                    <div class="viz-badge-cap">palabras</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'graphic' && (
              <div class="viz-stack">
                <div class="viz-card viz-design viz-tilt-1">
                  <div class="viz-browser-head">
                    <span class="viz-dot viz-dot--r"></span>
                    <span class="viz-dot viz-dot--y"></span>
                    <span class="viz-dot viz-dot--g"></span>
                    <div class="viz-url">identity.fig</div>
                  </div>
                  <div class="viz-design-body">
                    <div class="viz-swatches">
                      <div class="viz-swatch viz-swatch--1 viz-fade-in"></div>
                      <div class="viz-swatch viz-swatch--2 viz-fade-in" style="animation-delay:.15s"></div>
                      <div class="viz-swatch viz-swatch--3 viz-fade-in" style="animation-delay:.3s"></div>
                      <div class="viz-swatch viz-swatch--4 viz-fade-in" style="animation-delay:.45s"></div>
                    </div>
                    <div class="viz-type-sample viz-fade-in" style="animation-delay:.5s">
                      <div class="viz-type-display">Aa</div>
                      <div class="viz-type-info">
                        <div class="viz-type-name">Instrument Serif</div>
                        <div class="viz-type-meta">Display · 48pt</div>
                      </div>
                    </div>
                    <div class="viz-logo-grid">
                      <div class="viz-logo-mark viz-fade-in" style="animation-delay:.7s">J</div>
                      <div class="viz-logo-mark viz-logo-mark--2 viz-fade-in" style="animation-delay:.85s">✦</div>
                      <div class="viz-logo-mark viz-logo-mark--3 viz-fade-in" style="animation-delay:1s">◈</div>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle viz-sparkle--amber">🎨</span>
                  <div>
                    <div class="viz-badge-num">∞</div>
                    <div class="viz-badge-cap">iteraciones</div>
                  </div>
                </div>
              </div>
            )}

            {heroVisual === 'social' && (
              <div class="viz-stack">
                <div class="viz-phone viz-phone--social viz-float-slow">
                  <div class="viz-phone-notch"></div>
                  <div class="viz-phone-screen viz-phone-screen--light">
                    <div class="viz-post">
                      <div class="viz-post-head">
                        <div class="viz-avatar"></div>
                        <div class="viz-post-meta">
                          <div class="viz-post-user"></div>
                          <div class="viz-post-time"></div>
                        </div>
                      </div>
                      <div class="viz-post-img"></div>
                      <div class="viz-post-actions">
                        <span class="viz-icon-heart viz-pulse">♥</span>
                        <span class="viz-icon">💬</span>
                        <span class="viz-icon">↗</span>
                      </div>
                      <div class="viz-post-likes">2.4K me&nbsp;gusta</div>
                    </div>
                  </div>
                </div>
                <div class="viz-card viz-badge viz-float">
                  <span class="viz-sparkle">💬</span>
                  <div>
                    <div class="viz-badge-num">+847%</div>
                    <div class="viz-badge-cap">engagement</div>
                  </div>
                </div>
              </div>
            )}

          </slot>
        </div>
      </div>
    </section>

    <!-- Main content slot -->
    <slot />

    <!-- ═══ Features ═══ -->
    {features.length > 0 && (
      <section class="svc-features">
        <div class="container">
          <div class="svc-pill">Qué incluye</div>
          <h2 class="svc-h2">
            Todo lo que necesitas,<br/>
            <em>en un solo servicio.</em>
          </h2>
          <div class="svc-features-grid">
            {features.map(f => (
              <div class="svc-feature">
                <div class="svc-feature-icon" set:html={f.icon} />
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Benefits ═══ -->
    {benefits.length > 0 && (
      <section class="svc-benefits">
        <div class="container svc-benefits-grid">
          <div class="svc-benefits-content">
            <div class="svc-pill svc-pill--ink">Por qué elegirnos</div>
            <h2 class="svc-h2">
              Ventajas de trabajar con<br/>
              <em>JesusLopezSEO.</em>
            </h2>
            <ul class="svc-benefits-list">
              {benefits.map(b => (
                <li>
                  <span class="svc-check">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  {b}
                </li>
              ))}
            </ul>
            <a href="/pedir-presupuesto" class="svc-btn" style="margin-top:2rem">
              Solicitar presupuesto sin compromiso
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="svc-contact-card">
            <div class="svc-contact-bg" aria-hidden="true"></div>
            <div class="svc-contact-eyebrow">
              <span class="live-dot-s"></span>
              Atención directa
            </div>
            <h3>¿Tienes dudas?</h3>
            <p>Hablas directamente conmigo. Sin intermediarios, sin comerciales, sin rodeos. Analizo tu proyecto y te digo si encaja o no.</p>

            <div class="svc-contact-list">
              <a href="mailto:jesus@jesuslopezseo.com" class="svc-contact-row">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>jesus@jesuslopezseo.com</span>
              </a>
              <a href="tel:+34618015995" class="svc-contact-row">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>+34 618 015 995</span>
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ═══ FAQ ═══ -->
    {faq.length > 0 && (
      <section class="svc-faq">
        <div class="container" style="max-width:820px">
          <div class="svc-pill">Preguntas frecuentes</div>
          <h2 class="svc-h2">
            Todo lo que nos preguntan<br/>
            <em>antes de empezar.</em>
          </h2>
          <div class="svc-faq-list">
            {faq.map(item => (
              <details class="svc-faq-item">
                <summary>
                  <span>{item.q}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </summary>
                <div class="svc-faq-answer">
                  <p set:html={item.a} />
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Bottom CTA ═══ -->
    <section class="svc-cta">
      <div class="svc-cta-grid" aria-hidden="true"></div>
      <div class="container svc-cta-inner">
        <div class="svc-pill svc-pill--mint">Sin compromiso</div>
        <h2 class="svc-cta-h2">
          ¿Listo para mejorar<br/>tu presencia online?
        </h2>
        <p>Pide tu presupuesto gratis. Te respondo en menos de 24 horas con una propuesta concreta.</p>
        <div class="svc-cta-actions">
          <a href="/pedir-presupuesto" class="svc-btn svc-btn--mint">
            Solicitar presupuesto gratis
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="tel:+34618015995" class="svc-btn svc-btn--ghost-light">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            618 015 995
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .svc {
    --s-ink: #0f0e0c;
    --s-ink-soft: #2a2622;
    --s-mid: #5a524a;
    --s-mute: #8a8078;
    --s-paper: #faf9f7;
    --s-cream: #f3efe7;
    --s-border: rgba(15,14,12,0.08);
    --s-border-strong: rgba(15,14,12,0.14);
    --s-amber: #f59e0b;
    --s-amber-dark: #b45309;
    --s-mint: #00d57b;
    --s-display: 'Instrument Serif', Georgia, serif;
    --s-mono: 'JetBrains Mono', monospace;
  }

  .svc .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  /* ═══════ HERO ═══════ */
  .svc-hero {
    position: relative;
    padding: 6rem 0 4.5rem;
    overflow: hidden;
    background: var(--s-paper);
  }
  .svc-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--s-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--s-border) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(ellipse at 30% 40%, black 10%, transparent 65%);
    -webkit-mask-image: radial-gradient(ellipse at 30% 40%, black 10%, transparent 65%);
    opacity: 0.6;
    pointer-events: none;
  }
  .svc-glow {
    position: absolute;
    top: -150px; right: -150px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(245,158,11,0.12), transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }
  .svc-hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 4rem;
    align-items: center;
  }
  .svc-hero-content { max-width: 620px; }
  .svc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--s-border-strong);
    border-radius: 999px;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(8px);
    font-family: var(--s-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--s-ink-soft);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .svc-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--s-amber);
  }
  .svc-hero-title {
    font-family: var(--s-display);
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin: 0 0 1.25rem;
    color: var(--s-ink);
  }
  .svc-hero-title :global(em) {
    font-style: italic;
    color: var(--s-amber-dark);
  }
  .svc-hero-sub {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--s-ink-soft);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .svc-hero-desc {
    font-size: 1.0625rem;
    color: var(--s-mid);
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 560px;
  }
  .svc-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .svc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
    background: var(--s-ink);
    color: var(--s-paper);
    border: 1px solid var(--s-ink);
  }
  .svc-btn:hover { transform: translateY(-1px); box-shadow: 0 12px 32px rgba(15,14,12,0.25); }
  .svc-btn--ghost {
    background: transparent;
    color: var(--s-ink);
    border-color: var(--s-border-strong);
  }
  .svc-btn--ghost:hover { background: rgba(15,14,12,0.04); border-color: var(--s-ink); }
  .svc-btn--mint {
    background: var(--s-mint);
    color: var(--s-ink);
    border-color: var(--s-mint);
    box-shadow: 0 0 40px rgba(0,213,123,0.25);
  }
  .svc-btn--mint:hover { box-shadow: 0 0 60px rgba(0,213,123,0.35), 0 12px 32px rgba(0,0,0,0.3); }
  .svc-btn--ghost-light {
    background: transparent;
    color: var(--s-paper);
    border: 1px solid rgba(250,249,247,0.25);
  }
  .svc-btn--ghost-light:hover { border-color: var(--s-paper); background: rgba(250,249,247,0.06); }

  /* ═══════ SHARED H2 ═══════ */
  .svc-h2 {
    font-family: var(--s-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 1rem 0 3rem;
    color: var(--s-ink);
  }
  .svc-h2 em { font-style: italic; color: var(--s-amber-dark); }

  .svc-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: rgba(245,158,11,0.10);
    color: var(--s-amber-dark);
    border: 1px solid rgba(245,158,11,0.22);
  }
  .svc-pill--ink {
    background: var(--s-ink);
    color: var(--s-paper);
    border-color: var(--s-ink);
  }
  .svc-pill--mint {
    background: rgba(0,213,123,0.12);
    color: var(--s-mint);
    border-color: rgba(0,213,123,0.3);
  }

  /* ═══════ FEATURES ═══════ */
  .svc-features {
    background: var(--s-cream);
    padding: 6rem 0;
  }
  .svc-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .svc-feature {
    background: var(--s-paper);
    border: 1px solid var(--s-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .svc-feature:hover {
    border-color: var(--s-ink);
    transform: translateY(-3px);
    box-shadow: 0 16px 40px -10px rgba(15,14,12,0.12);
  }
  .svc-feature-icon {
    width: 44px;
    height: 44px;
    background: var(--s-ink);
    color: var(--s-paper);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: all 200ms;
  }
  .svc-feature-icon :global(svg) { width: 20px; height: 20px; }
  .svc-feature:hover .svc-feature-icon { background: var(--s-amber); color: var(--s-ink); }
  .svc-feature h3 {
    font-family: var(--s-display);
    font-size: 1.375rem;
    font-weight: 400;
    margin: 0 0 0.5rem;
    line-height: 1.2;
    color: var(--s-ink);
  }
  .svc-feature p {
    font-size: 0.9375rem;
    color: var(--s-mid);
    line-height: 1.6;
    margin: 0;
  }

  /* ═══════ BENEFITS ═══════ */
  .svc-benefits {
    padding: 6rem 0;
    background: var(--s-paper);
  }
  .svc-benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .svc-benefits-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .svc-benefits-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--s-ink-soft);
    line-height: 1.55;
  }
  .svc-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: var(--s-ink);
    color: var(--s-paper);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .svc-contact-card {
    position: relative;
    background: var(--s-ink);
    color: var(--s-paper);
    border-radius: 16px;
    padding: 2.5rem;
    overflow: hidden;
    box-shadow: 0 24px 60px -20px rgba(15,14,12,0.3);
  }
  .svc-contact-bg {
    position: absolute;
    top: -100px; right: -100px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(0,213,123,0.2), transparent 60%);
    filter: blur(30px);
  }
  .svc-contact-eyebrow {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--s-mono);
    font-size: 0.7rem;
    color: rgba(250,249,247,0.5);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .live-dot-s {
    width: 6px;
    height: 6px;
    background: var(--s-mint);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--s-mint);
    animation: live-pulse 2s ease-in-out infinite;
  }
  @keyframes live-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .svc-contact-card h3 {
    position: relative;
    font-family: var(--s-display);
    font-size: 1.75rem;
    font-weight: 400;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .svc-contact-card p {
    position: relative;
    color: rgba(250,249,247,0.72);
    line-height: 1.6;
    font-size: 0.9375rem;
    margin: 0 0 1.5rem;
  }
  .svc-contact-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .svc-contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: rgba(250,249,247,0.04);
    border: 1px solid rgba(250,249,247,0.08);
    border-radius: 10px;
    font-size: 0.9375rem;
    color: var(--s-paper);
    text-decoration: none;
    transition: all 200ms;
  }
  .svc-contact-row:hover {
    background: rgba(0,213,123,0.1);
    border-color: rgba(0,213,123,0.3);
  }
  .svc-contact-row svg { color: var(--s-mint); flex-shrink: 0; }

  /* ═══════ FAQ ═══════ */
  .svc-faq {
    padding: 6rem 0;
    background: var(--s-cream);
  }
  .svc-faq-list {
    margin-top: 3rem;
    border-top: 1px solid var(--s-border-strong);
  }
  .svc-faq-item {
    border-bottom: 1px solid var(--s-border-strong);
  }
  .svc-faq-item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 0;
    cursor: pointer;
    font-family: var(--s-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--s-ink);
    transition: color 200ms;
  }
  .svc-faq-item summary::-webkit-details-marker { display: none; }
  .svc-faq-item summary:hover { color: var(--s-amber-dark); }
  .svc-faq-item summary svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 300ms ease;
  }
  .svc-faq-item[open] summary svg { transform: rotate(180deg); }
  .svc-faq-answer {
    padding: 0 0 1.5rem;
    color: var(--s-mid);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 700px;
  }
  .svc-faq-answer p { margin: 0; }

  /* ═══════ BOTTOM CTA ═══════ */
  .svc-cta {
    position: relative;
    background: var(--s-ink);
    color: var(--s-paper);
    overflow: hidden;
    padding: 6rem 0;
  }
  .svc-cta-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(250,249,247,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(250,249,247,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 10%, transparent 60%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 60%);
    pointer-events: none;
  }
  .svc-cta::after {
    content: '';
    position: absolute;
    bottom: -200px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(0,213,123,0.2), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
  .svc-cta-inner { position: relative; z-index: 2; text-align: center; max-width: 720px; }
  .svc-cta-h2 {
    font-family: var(--s-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 1rem 0 1.25rem;
  }
  .svc-cta p {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(250,249,247,0.72);
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .svc-cta-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ═══════════ HERO VISUALS (RIGHT SIDE) ═══════════ */
  .svc-hero-aside {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }
  .viz-stack {
    position: relative;
    width: 100%;
    max-width: 440px;
  }
  .viz-card {
    background: #ffffff;
    border: 1px solid var(--s-border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 2px 4px rgba(15,14,12,0.04),
      0 30px 60px -25px rgba(15,14,12,0.25);
  }
  .viz-tilt-1 { transform: rotate(-0.8deg); }
  .viz-float { animation: viz-float 4s ease-in-out infinite; }
  .viz-float-slow { animation: viz-float 5s ease-in-out infinite; }
  @keyframes viz-float {
    0%,100% { transform: translateY(0) rotate(0deg); }
    50%     { transform: translateY(-8px) rotate(0.5deg); }
  }

  /* Browser chrome */
  .viz-browser-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 0.85rem;
    background: #fafafa;
    border-bottom: 1px solid var(--s-border);
  }
  .viz-browser-head--dark { background: #121212; border-bottom-color: rgba(250,249,247,0.06); }
  .viz-dot { width: 9px; height: 9px; border-radius: 50%; }
  .viz-dot--r { background: #ff5f57; }
  .viz-dot--y { background: #febc2e; }
  .viz-dot--g { background: #28c840; }
  .viz-url {
    flex: 1;
    text-align: center;
    font-family: var(--s-mono);
    font-size: 0.7rem;
    color: var(--s-mute);
    background: rgba(15,14,12,0.04);
    padding: 0.2rem 0.65rem;
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    max-width: 220px;
    margin: 0 auto;
  }
  .viz-term-title {
    flex: 1;
    text-align: center;
    font-family: var(--s-mono);
    font-size: 0.7rem;
    color: rgba(250,249,247,0.4);
  }

  /* ══ Floating Badge ══ */
  .viz-badge {
    position: absolute;
    bottom: -16px;
    right: -14px;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 1rem;
    background: var(--s-ink);
    color: var(--s-paper);
    border-radius: 12px;
    box-shadow: 0 16px 32px -8px rgba(15,14,12,0.3);
    border: none;
  }
  .viz-sparkle {
    display: inline-flex;
    width: 28px;
    height: 28px;
    background: var(--s-amber);
    color: var(--s-ink);
    border-radius: 8px;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .viz-sparkle--amber { background: var(--s-amber); }
  .viz-sparkle--mint { background: var(--s-mint); color: var(--s-ink); }
  .viz-badge-num {
    font-family: var(--s-display);
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .viz-badge-cap {
    font-size: 0.7rem;
    color: rgba(250,249,247,0.6);
    margin-top: 2px;
    letter-spacing: -0.005em;
  }

  /* ══════ WEB VISUAL ══════ */
  .viz-browser-body { padding: 0.9rem; }
  .viz-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--s-border);
    margin-bottom: 1rem;
  }
  .viz-logo-bar {
    width: 56px;
    height: 12px;
    background: var(--s-ink);
    border-radius: 3px;
  }
  .viz-nav-items {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .viz-nav-items span {
    width: 26px;
    height: 6px;
    background: rgba(15,14,12,0.15);
    border-radius: 2px;
  }
  .viz-cta-mini {
    width: 50px;
    height: 20px;
    background: var(--s-amber);
    border-radius: 4px;
    margin-left: 0.3rem;
  }
  .viz-hero-mock { padding: 0.5rem 0 1rem; }
  .viz-h1-line {
    height: 14px;
    background: var(--s-ink);
    border-radius: 4px;
    margin-bottom: 0.4rem;
  }
  .viz-h1-line--lg { width: 90%; }
  .viz-h1-line--md { width: 65%; }
  .viz-p-line {
    height: 6px;
    background: rgba(15,14,12,0.12);
    border-radius: 3px;
    margin-bottom: 0.3rem;
    margin-top: 0.6rem;
  }
  .viz-p-line--short { width: 70%; }
  .viz-btn-mock {
    width: 100px;
    height: 26px;
    background: var(--s-ink);
    border-radius: 5px;
    margin-top: 0.9rem;
  }
  .viz-grid-mock {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .viz-box {
    height: 50px;
    background: linear-gradient(90deg, rgba(15,14,12,0.06) 0%, rgba(245,158,11,0.15) 50%, rgba(15,14,12,0.06) 100%);
    background-size: 200% 100%;
    border-radius: 6px;
  }
  .viz-shimmer { animation: shimmer 2.5s infinite linear; }
  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ══════ SEO VISUAL ══════ */
  .viz-rank-body { padding: 1rem 0.85rem; }
  .viz-query {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: rgba(15,14,12,0.04);
    border-radius: 6px;
    margin-bottom: 0.85rem;
    font-family: var(--s-mono);
    font-size: 0.75rem;
  }
  .viz-q-label { color: var(--s-mute); }
  .viz-q-kw { color: var(--s-ink); font-weight: 500; }
  .viz-cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: var(--s-amber);
    font-weight: 700;
  }
  @keyframes blink { 0%,50%{opacity:1} 51%,100%{opacity:0} }

  .viz-rank-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-radius: 6px;
    background: #f7f3eb;
    margin-bottom: 0.35rem;
    opacity: 0;
    transform: translateX(-12px);
  }
  .viz-slide-in { animation: viz-slide-in 0.6s ease-out forwards; }
  @keyframes viz-slide-in {
    from { opacity: 0; transform: translateX(-12px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .viz-rank-row--1 {
    background: linear-gradient(90deg, rgba(245,158,11,0.18), rgba(245,158,11,0.05));
    border: 1px solid rgba(245,158,11,0.3);
  }
  .viz-rank-pos {
    font-family: var(--s-mono);
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 26px;
    text-align: center;
    padding: 0.2rem 0.35rem;
    border-radius: 4px;
    background: rgba(245,158,11,0.2);
    color: var(--s-amber-dark);
  }
  .viz-rank-pos--2 { background: rgba(15,14,12,0.08); color: var(--s-ink-soft); }
  .viz-rank-pos--3 { background: rgba(15,14,12,0.06); color: var(--s-mute); }
  .viz-rank-info { flex: 1; min-width: 0; }
  .viz-rank-title {
    height: 8px;
    width: 80%;
    background: var(--s-ink);
    border-radius: 3px;
    margin-bottom: 4px;
  }
  .viz-rank-title--short { width: 60%; background: var(--s-ink-soft); }
  .viz-rank-title--md { width: 70%; background: var(--s-ink-soft); }
  .viz-rank-url {
    font-family: var(--s-mono);
    font-size: 0.65rem;
    color: var(--s-amber-dark);
  }
  .viz-rank-url--muted { color: var(--s-mute); }
  .viz-arrow { font-size: 0.95rem; font-weight: 800; }
  .viz-arrow--up { color: #10b981; }

  /* ══════ ASO / PHONE VISUAL ══════ */
  .viz-phone {
    width: 240px;
    margin: 0 auto;
    background: #0f0e0c;
    border-radius: 32px;
    padding: 10px;
    border: 1.5px solid #2a2622;
    box-shadow:
      0 2px 0 rgba(255,255,255,0.05) inset,
      0 30px 60px -20px rgba(15,14,12,0.35);
    position: relative;
  }
  .viz-phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 65px;
    height: 18px;
    background: #0f0e0c;
    border-radius: 0 0 12px 12px;
    z-index: 2;
  }
  .viz-phone-screen {
